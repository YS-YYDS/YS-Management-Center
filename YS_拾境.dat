function Eng.LoadPianoSession() if EngIO and EngIO.LoadPianoSession then return EngIO.LoadPianoSession() end end

function Eng.InsertSample(d, p, t) if EngIO and EngIO.InsertSample then EngIO.InsertSample(d, p, t) end end
function Eng.PreviewSample(p) if EngIO and EngIO.PreviewSample then EngIO.PreviewSample(p) end end
function Eng.InsertScene(n, p, t) if EngIO and EngIO.InsertScene then EngIO.InsertScene(n, p, t) end end
