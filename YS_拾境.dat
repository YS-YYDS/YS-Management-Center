end)()
local UI =  (function()
  local _m = (function()
--[[
 * Auth_UI.lua
 * Premium UI Rendering for YS_Auth
--]]

local r = reaper
local UI = {}

function UI.DrawProxyBackground(ctx, wx, wy, ww, wh)
    local dl = r.ImGui_GetWindowDrawList(ctx)
    local x2, y2 = wx + ww - 1.0, wy + wh - 1.0
    
    -- 磨砂玻璃质感外壳 (Glassmorphism effect)
    r.ImGui_DrawList_AddRectFilled(dl, wx, wy, x2, y2, 0x1A1C1EFF, 12) -- 深色基座
    r.ImGui_DrawList_AddRectFilled(dl, wx, wy, x2, wy+40, 0x2A2E33FF, 12, r.ImGui_DrawFlags_RoundCornersTop()) -- 标题栏背景
    
    -- 渐变边框 (Gradient border)
    r.ImGui_DrawList_AddRect(dl, wx, wy, x2, y2, 0x555566FF, 12, nil, 1.2) 
    
    -- 高光微光
    r.ImGui_DrawList_AddLine(dl, wx + 12, wy + 1, x2 - 12, wy + 1, 0xFFFFFF15, 1.0)
end

function UI.CenterNextWindow(ctx)
    local vp = r.ImGui_GetMainViewport(ctx)
    local vx, vy = r.ImGui_Viewport_GetCenter(vp)
    r.ImGui_SetNextWindowPos(ctx, vx, vy, r.ImGui_Cond_Appearing(), 0.5, 0.5)
end

function UI.DrawTrialNag(ctx, cfg, Core)
    if not cfg.show_trial_nag_modal then return true end
    
    UI.CenterNextWindow(ctx)
    r.ImGui_SetNextWindowFocus(ctx) -- [UX-FIX] 强制聚焦
    r.ImGui_SetNextWindowSize(ctx, 360, 0, r.ImGui_Cond_Always())
    local f = r.ImGui_WindowFlags_AlwaysAutoResize() | r.ImGui_WindowFlags_NoBackground() | r.ImGui_WindowFlags_NoTitleBar() | r.ImGui_WindowFlags_NoSavedSettings() | r.ImGui_WindowFlags_TopMost()
    local visible, _ = r.ImGui_Begin(ctx, "软件试用状态", nil, f)
    if visible then
        local wx, wy = r.ImGui_GetWindowPos(ctx)
        local ww, wh = r.ImGui_GetWindowSize(ctx)
        UI.DrawProxyBackground(ctx, wx, wy, ww, wh)
        
        r.ImGui_Dummy(ctx, 0, 10); r.ImGui_Indent(ctx, 20)
        r.ImGui_TextColored(ctx, 0xFFFFFFFF, "★ 您当前正在试用")
        r.ImGui_Unindent(ctx, 20); r.ImGui_Dummy(ctx, 0, 15) -- [UX-FIX] 移除冗余黑线，仅保留间距
        r.ImGui_Indent(ctx, 20)
        
        -- [V1.2 RECOVERY] 动态计算剩余天数
        local remain_days = 0
        if not cfg.Passport then return true end -- [FIX] Passport nil guard
        local status, info = cfg.Passport.CheckStatus(cfg.product_id)
        if cfg.expiry_ts and cfg.expiry_ts > os.time() then
            remain_days = math.ceil((cfg.expiry_ts - os.time() - 3600) / 86400)
            if remain_days < 1 then remain_days = 1 end
        end
        r.ImGui_TextColored(ctx, 0xBBBBBBFF, string.format("当前试用权有效期剩余: %d 天", remain_days))
        r.ImGui_Dummy(ctx, 0, 15)
        
        -- [V1.2 RECOVERY] 还原双按钮决策布局
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), 0xEA6815FF)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonHovered(), 0xF37A2DFF)
        
        local can_continue = (status ~= "STATUS_LOCKDOWN")
        if r.ImGui_Button(ctx, can_continue and "继续使用" or "试用结束", 145, 40) then 
            if can_continue then
                cfg.show_trial_nag_modal = false 
                cfg.session_nag_done = true
            else
                r.MB("试用期已结束，请激活授权以继续使用。", "授权提示", 0)
                cfg.force_exit = true
            end
        end
        r.ImGui_PopStyleColor(ctx, 2)
        
        r.ImGui_SameLine(ctx, 0, 20)
        
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), 0x5B6EE1FF)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonHovered(), 0x6A7BFFFF)
        if r.ImGui_Button(ctx, "获取正式版", 145, 40) then 
            cfg.force_show_ui = true
            cfg.show_trial_nag_modal = false 
            cfg.auth_input_buf = "" 
            cfg.auth_diag_log = "" -- [UX-FIX] 进入授权界面前清理旧的错误提示
        end
        r.ImGui_PopStyleColor(ctx, 2)
        
        r.ImGui_Unindent(ctx, 20); r.ImGui_Dummy(ctx, 0, 15); r.ImGui_End(ctx)
    end
    return false
end

function UI.DrawAnnouncement(ctx, cfg, Core)
    UI.CenterNextWindow(ctx)
    r.ImGui_SetNextWindowFocus(ctx) -- [UX-FIX] 强制聚焦
    r.ImGui_SetNextWindowSize(ctx, 400, 0, r.ImGui_Cond_Always())
    local f = r.ImGui_WindowFlags_AlwaysAutoResize() | r.ImGui_WindowFlags_NoBackground() | r.ImGui_WindowFlags_NoTitleBar() | r.ImGui_WindowFlags_NoSavedSettings() | r.ImGui_WindowFlags_TopMost()
    local visible, _ = r.ImGui_Begin(ctx, "系统公告", nil, f)
    if visible then
        local wx, wy = r.ImGui_GetWindowPos(ctx); local ww, wh = r.ImGui_GetWindowSize(ctx)
        UI.DrawProxyBackground(ctx, wx, wy, ww, wh)
        
        r.ImGui_Dummy(ctx, 0, 10); r.ImGui_Indent(ctx, 20)
        r.ImGui_TextColored(ctx, 0xFFFFFFFF, "★ 验证成功!")
        r.ImGui_Unindent(ctx, 20); r.ImGui_Dummy(ctx, 0, 15)
        r.ImGui_Indent(ctx, 20)
        
        -- [V1.2 FIX] 对云端公告进行 Unicode 解码，确保中文显示正常
        local display_text = (cfg.announcement and cfg.announcement ~= "") and cfg.announcement or "欢迎使用 YS_拾境，全功能已激活。"
        if display_text:find("\\u") then display_text = Core.DecodeUnicode(display_text) end
        
        r.ImGui_PushTextWrapPos(ctx, 380)
        r.ImGui_TextWrapped(ctx, display_text)
        r.ImGui_PopTextWrapPos(ctx)
        r.ImGui_Dummy(ctx, 0, 15)
        
        if cfg.is_trial then
            r.ImGui_TextColored(ctx, 0xFFAA55FF, "注意：本产品当前处于试用状态。")
            r.ImGui_Dummy(ctx, 0, 10)
        end
        
