--- @version 2.1.0
--- @description YS 拾境 - 核心调度引擎 (Main Engine Dispatcher)
--- @author YS / Antigravity
--- @about 负责将业务逻辑转发至专精模块 (Engine_DB/IO)。
--- @param Utils table? 注入 Utils 模块以支持安全反序列化
function State.Init(Utils)
    local r = reaper
    local G = State.G
    
    G.ui_font_size = tonumber(r.GetExtState(PRODUCT_ID, "UIFontSize")) or 16
    G.result_font_size = tonumber(r.GetExtState(PRODUCT_ID, "ResultFontSize")) or 18
    G.script_font_idx = tonumber(r.GetExtState(PRODUCT_ID, "ScriptFontIdx")) or 1
    G.theme_idx = tonumber(r.GetExtState(PRODUCT_ID, "ThemeIndex")) or 1 -- [关键修复] 默认索引回归至有效区间 1-4
    G.sidebar_width = tonumber(r.GetExtState(PRODUCT_ID, "SidebarWidth")) or 250
    G.is_collapsed = (r.GetExtState(PRODUCT_ID, "Collapsed") == "1")
    G.insert_mode = tonumber(r.GetExtState(PRODUCT_ID, "InsertMode")) or 0
    G.skip_fx = (r.GetExtState(PRODUCT_ID, "SkipFX") == "1")
    G.auto_close = (r.GetExtState(PRODUCT_ID, "AutoClose") == "1")
    G.is_filter_locked = (r.GetExtState(PRODUCT_ID, "SearchLock") == "1")
    G.smart_crop = (r.GetExtState(PRODUCT_ID, "SmartCrop") ~= "0")
    G.hide_tooltip_main = (r.GetExtState(PRODUCT_ID, "HideTooltipMain") == "1")
    G.hide_tooltip_piano = (r.GetExtState(PRODUCT_ID, "HideTooltipPiano") == "1")
