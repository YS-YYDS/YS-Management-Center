-- [内部状态] 全局状态表引用 (由主程序通过 Init 注入)
local G_ref = nil

--- 注入全局状态表引用 (由 Engine_IO_Async.Init 调用)
--- @param g table 全局状态表
function Utils.Init(g)
    G_ref = g
end

--- [异步节拍控制] 更新最后一次删除操作的时间戳
--- 供 Main 循环调用，实现非阻塞的删除节拍心跳
function Utils.UpdateDeletionTick()
    if G_ref then
        G_ref.deletion_last_tick = reaper.time_precise()
    end
end

-- ===================== [YS_Industrial] 持久化引擎 (Robust Table Serializer) =====================

---@param tbl table
---@return string
function Utils.SerializeTable(tbl)
    local function serialize(v)
        if type(v) == "string" then return string.format("%q", v)
        elseif type(v) == "number" or type(v) == "boolean" then return tostring(v)
        elseif type(v) == "table" then
            local res = {"{"}
            for k, v2 in pairs(v) do
                local k_str = type(k) == "string" and string.format("[%q]", k) or string.format("[%d]", k)
                table.insert(res, string.format("%s=%s,", k_str, serialize(v2)))
            end
            table.insert(res, "}")
            return table.concat(res)
        end
        return "nil"
    end
    return serialize(tbl)
end

---@param key string ExtState Key
---@param tbl table
function Utils.SaveTable(key, tbl)
    local str = Utils.SerializeTable(tbl)
    reaper.SetExtState("YS_Archive", key, str, true)
end

--- [SEC-002] 工业级安全反序列化 (防范 RCE 攻击)
--- 仅解析 Lua Table 文本，禁止执行任何外部函数
--- @param str string
--- @return table|nil
function Utils.SafeTableLoad(str)
    if not str or str == "" then return nil end
    -- 严格沙盒环境: 仅允许加载文本 ("t")，环境表为空 ({})
    local func, err = load("return " .. str, "RestrictedData", "t", {})
    if func then
        local ok, res = pcall(func)
        if ok and type(res) == "table" then return res end
    end
    return nil
end

---@param key string ExtState Key
---@return table|nil
function Utils.LoadTable(key)
    local str = reaper.GetExtState("YS_Archive", key)
    if str == "" then return nil end
    return Utils.SafeTableLoad(str)
end

-- ===================== [YS_Industrial] 物理安全引擎 (IO Safety) =====================

--- [YS_Industrial] 极速路径预检 (支持 Windows UTF-8)
--- 相比 os.rename，io.open 对中文多字节路径的读取探测更可靠
--- @param path string
--- @return boolean
function Utils.FileExistsFast(path)
    if not path or path == "" then return false end
    if reaper.JS_File_Exists then return reaper.JS_File_Exists(path) end
    local f = io.open(path, "rb")
    if f then f:close(); return true end
    return false
end

--- 高性能路径预检 (保留向上兼容)
function Utils.FileExists(path)
    if Utils.FileExistsFast(path) then return true end
    
    -- 为目录/根驱动器设计的探测方案：
    -- 1. 如果是根目录 (如 J:)
    if path:match("^%a:[\\/]?$") then
        return reaper.EnumerateFiles(path, 0) ~= nil or reaper.EnumerateSubdirectories(path, 0) ~= nil
    end

    -- [V3.3] 工业级降级方案：使用 REAPER 目录枚举 (100% UTF-8 安全)
    local dir = path:match("(.*)[/\\]")
    local file = path:match("([^/\\]+)$")
    if dir and file then
        dir = dir:gsub("[/\\]+$", "")
        local i = 0
        while true do
            local f = reaper.EnumerateFiles(dir, i)
            if not f then break end
            if f == file then return true end
            if i > 1000 then break end
            i = i + 1
        end
        i = 0
        while true do
            local d = reaper.EnumerateSubdirectories(dir, i)
            if not d then break end
            if d == file then return true end
            if i > 1000 then break end
            i = i + 1
        end
    end

    local ok, err, code = os.rename(Utils.FromUTF8(path), Utils.FromUTF8(path))
    if not ok then
        if code == 13 or code == 5 then return true end
    end
    return ok == true
end

--- [YS_Industrial] 目录存在探测 
--- @param path string
--- @return boolean
function Utils.DirExists(path)
    if not path or path == "" then return false end
    -- Windows 下 JS_File_Exists 对目录同样有效
    if reaper.JS_File_Exists then
        return reaper.JS_File_Exists(path)
    end
    -- Fallback: 尝试重命名为自身 (os.rename 对文件夹在非独占锁时有效)
    local ok, err = os.rename(Utils.FromUTF8(path), Utils.FromUTF8(path))
    if not ok and (err:match("denied") or err:match("exists")) then return true end
    return ok or false
end

--- 工业级文件名安全检查 (去除非法字符)
function Utils.SafeName(name)
    return tostring(name):gsub('"', ''):gsub("'", ""):gsub("[<>:\\/|?*]", "_")
end

--- [V4.0] 高斯分布 (正态分布) 随机数生成器
--- 基于 Box-Muller 变换
--- @param sigma number 标准差 (决定了随机分布的离散程度)
--- @return number 均值为0、标准差为sigma的随机数，已夹紧在 [-2*sigma, 2*sigma]
function Utils.GaussianRandom(sigma)
    if not sigma or sigma == 0 then return 0 end
    -- 生成两个均匀分布的随机数 [0, 1)
    local u1 = math.random()
    local u2 = math.random()
    -- 防止 log(0)
    if u1 < 1e-9 then u1 = 1e-9 end
    
    -- u1 决定幅度，u2 决定角度 (Box-Muller)
    local mag = math.sqrt(-2.0 * math.log(u1))
    local z = mag * math.cos(2.0 * math.pi * u2)
    
    -- 夹紧到 2-sigma (覆盖约 95.4% 的情况)，防止极端的长尾异常值破坏音效
    z = math.max(-2.0, math.min(2.0, z))
    
    return z * sigma
end

--- [V4.0] 高斯分布 (正态分布) 随机数生成器
--- 基于 Box-Muller 变换
--- @param sigma number 标准差 (决定了随机分布的离散程度)
--- @return number 均值为0、标准差为sigma的随机数，已夹紧在 [-2*sigma, 2*sigma]
function Utils.GaussianRandom(sigma)
    if not sigma or sigma == 0 then return 0 end
    -- 生成两个均匀分布的随机数 [0, 1)
    local u1 = math.random()
    local u2 = math.random()
    -- 防止 log(0)
    if u1 < 1e-9 then u1 = 1e-9 end
    
    -- u1 决定幅度，u2 决定角度 (Box-Muller)
    local mag = math.sqrt(-2.0 * math.log(u1))
    local z = mag * math.cos(2.0 * math.pi * u2)
    
    -- 夹紧到 2-sigma (覆盖约 95.4% 的情况)，防止极端的长尾异常值破坏音效
    z = math.max(-2.0, math.min(2.0, z))
    
    return z * sigma
end

--- 工业级目录确保机制
function Utils.EnsureDir(path)
    if not path or path == "" then return end
    reaper.RecursiveCreateDirectory(path, 0)
end

--- 工业级递归清理并移除文件夹到 Trash (原本逻辑)
--- @param path string 待清理路径
--- @param lib_path string 项目根目录，用于定位 _Trash
function Utils.SafeRemoveDir(path, lib_path)
    if not path or path == "" then return end
    if not (Utils.FileExistsFast(path) or Utils.DirExists(path)) then return end
    
    local sep = package.config:sub(1,1)
    
    -- 1. 递归物理删除内容 (同时释放锁定)
    local function recursive_cleanup(p)
        p = p:gsub("\\", "/"):gsub("/+$", "")
        
        -- A. 删除子文件
        local f_idx = 0
        while true do
            local f = reaper.EnumerateFiles(p, f_idx)
            if not f then break end
            local full = p .. "/" .. f
            if not os.remove(Utils.FromUTF8(full)) then f_idx = f_idx + 1 end
        end
        
        -- B. 递归子目录并尝试物理删除空文件夹 (从最深处开始)
        local d_idx = 0
        while true do
            local d = reaper.EnumerateSubdirectories(p, d_idx)
            if not d then break end
            local sub = p .. "/" .. d
            recursive_cleanup(sub)
            
            -- 子目录递归结束后，如果它现在是空的，尝试物理删除它
            if not os.remove(Utils.FromUTF8(sub)) then d_idx = d_idx + 1 end
        end
    end
    
    recursive_cleanup(path)
    
    -- 2. 最终处理根部文件夹
    if lib_path and lib_path ~= "" then
        -- 既然是 Preset/Library 删除，移动到 _Trash 归档
        local trash_root = lib_path:gsub("\\", "/"):gsub("/+$", "") .. "/_Trash"
        reaper.RecursiveCreateDirectory(trash_root, 0)
        
        local folder_name = path:match("([^/\\]+)$") or "unknown_del"
        local suffix = os.date("%m%d_%H%M%S_") .. math.floor(reaper.time_precise() * 1000) % 1000
        local dest = (trash_root .. "/" .. suffix .. "_" .. folder_name):gsub("//", "/")
        
        local move_ok = os.rename(Utils.FromUTF8(path), Utils.FromUTF8(dest))
        
        -- [CRITICAL FIX] 如果 rename 失败 (通常是因为 REAPER PCM 引擎锁定了子音频文件)
        -- 则使用系统命令强制物理删除整个目录
        if not move_ok then
            local is_win = package.config:sub(1,1) == "\\"
            if is_win then
                local win_path = path:gsub("/", "\\")
                os.execute('rd /s /q "' .. Utils.FromUTF8(win_path) .. '"')
            else
                os.execute('rm -rf "' .. path .. '"')
            end
        end
    else
        -- 没有提供 lib_path，说明是临时目录清理 (如 Archive_Exchange)，直接物理尝试删除
        local ok = os.remove(Utils.FromUTF8(path))
        if not ok then
            local is_win = package.config:sub(1,1) == "\\"
            if is_win then
                local win_path = path:gsub("/", "\\")
                os.execute('rd /s /q "' .. Utils.FromUTF8(win_path) .. '"')
            else
                os.execute('rm -rf "' .. path .. '"')
            end
        end
    end
end

--- 工业级目录拷贝 (Sync)
function Utils.CopyDirFiles(src, dst)
    local i = 0
    Utils.EnsureDir(dst)
    while true do
        local file = reaper.EnumerateFiles(src, i)
        if not file then break end
        local in_f = io.open(src .. "/" .. file, "rb")
        if in_f then
            local data = in_f:read("*all"); in_f:close()
            local out_f = io.open(dst .. "/" .. file, "wb")
            if out_f then out_f:write(data); out_f:close() end
        end
        i = i + 1
    end
end

--- 高性能递归序列化
--- @param val any
function Utils.Serialize(val)
    local t = {}
    local function _ser(v)
        if type(v) == "table" then
            table.insert(t, "{")
            local is_list = (#v > 0)
            if is_list then
                for i, item in ipairs(v) do _ser(item); table.insert(t, ",") end
            else
                for k, item in pairs(v) do
                    if type(k) == "number" then table.insert(t, "["..k.."]=")
                    else table.insert(t, k .. "=") end
                    _ser(item); table.insert(t, ",")
                end
            end
            table.insert(t, "}")
        elseif type(v) == "string" then table.insert(t, string.format("%q", v))
        elseif type(v) == "number" then table.insert(t, tostring(v))
        elseif type(v) == "boolean" then table.insert(t, (v and "true" or "false"))
        else table.insert(t, "nil") end
    end
    _ser(val)
    return table.concat(t)
end

--- 工业级字符串截断 (中间省略)
function Utils.TruncateString(str, max_l)
    if not str or #str <= max_l then return str end
    local half = math.floor((max_l - 3) / 2)
    return str:sub(1, half) .. "..." .. str:sub(-half)
end

--- 工业级物理删除 (含跨平台回收站逻辑)
--- @param file_path string
--- @param lib_path string
function Utils.SafePhysicalDelete(file_path, lib_path)
    if not file_path or not Utils.FileExists(file_path) then return end
    
    local trash_dir = lib_path .. "/_Trash"
    reaper.RecursiveCreateDirectory(trash_dir, 0)
    
    local filename = file_path:match("([^/]+)$") or file_path:match("([^\\]+)$") or "unknown"
    local suffix = os.time() .. "_" .. math.floor((os.clock() % 1) * 1000)
    local temp_path = trash_dir .. "/" .. suffix .. "_" .. filename
    
    -- Handle peaks
    local peaks = file_path .. ".reapeaks"
    if Utils.FileExists(peaks) then os.rename(Utils.FromUTF8(peaks), Utils.FromUTF8(temp_path .. ".reapeaks")) end

    if os.rename(Utils.FromUTF8(file_path), Utils.FromUTF8(temp_path)) then
        if reaper.APIExists("JS_File_Recycle") then
            local recycle_path = temp_path
            if reaper.GetOS():match("Win") then recycle_path = temp_path:gsub("/", "\\")
            else recycle_path = temp_path:gsub("\\", "/") end
            reaper.JS_File_Recycle(recycle_path)
        else
            os.remove(Utils.FromUTF8(temp_path))
        end
        return true
    end
    return false
end

--- 路径标准化器 
function Utils.NormalizePath(p)
    if not p then return "" end
    return p:gsub("\\", "/"):gsub("/+", "/"):gsub("/$", "")
end

--- 工业级编码转换 (UTF-8 卫士)
--- @param str string
--- @return string
function Utils.ToUTF8(str)
    if not str or str == "" then return "" end
    
    -- [V3.2.4] 预处理：移除 Windows 常见的尾部空字符
    str = str:gsub("%z+$", "")
    
    local function is_valid_utf8(s)
        -- [V3.2.4] 强化判定逻辑：如果包含非法字节序，gsub 后的长度将不为 0
        local matching = s:gsub("[\z\x01-\x7F]", "")
                          :gsub("[\xC2-\xDF][\x80-\xBF]", "")
                          :gsub("\xE0[\xA0-\xBF][\x80-\xBF]", "")
                          :gsub("[\xE1-\xEC][\x80-\xBF][\x80-\xBF]", "")
                          :gsub("\xED[\x80-\x9F][\x80-\xBF]", "")
                          :gsub("[\xEE-\xEF][\x80-\xBF][\x80-\xBF]", "")
                          :gsub("\xF0[\x90-\xBF][\x80-\xBF][\x80-\xBF]", "")
                          :gsub("[\xF1-\xF3][\x80-\xBF][\x80-\xBF][\x80-\xBF]", "")
                          :gsub("\xF4[\x80-\x8F][\x80-\xBF][\x80-\xBF]", "")
        return #matching == 0
    end

    if is_valid_utf8(str) then 
        return str 
    end
    
    -- [Industrial Fix] 尝试二次净化：如果由于尾部杂质导致的判定失败，尝试截断后再判定
    local clean_str = str:match("^([^\x00-\x7F\xC2-\xF4][\x80-\xBF]*)")
    if clean_str and is_valid_utf8(clean_str) then return clean_str end

    -- 仅在检测到非 UTF-8 且为 Windows 时尝试 ANSI 转换
    if reaper.JS_String_ANSItoUTF8 and reaper.GetOS():match("Win") then
        local ok, res = pcall(reaper.JS_String_ANSItoUTF8, str)
        if ok then return res end
    end
    
    return str
end

function Utils.FromUTF8(str)
    if not str or str == "" then return "" end
    if reaper.JS_String_UTF8toANSI and reaper.GetOS():match("Win") then
        return reaper.JS_String_UTF8toANSI(str)
    end
    return str
end


--- 极致性能探测器 (探测存在性比枚举目录快 100 倍)
function Utils.GetSystemFonts()
    local fonts = {}
    local os_str = reaper.GetOS()
    
    -- 无需枚举，直接探测预设路径
    local probes = {}
    if os_str:match("Win") then
        local win_dir = "C:/Windows/Fonts/"
        probes = {
            { text = "微软雅黑", file = win_dir .. "msyh.ttc" },
            { text = "微软雅黑 (Bold)", file = win_dir .. "msyhbd.ttc" },
            { text = "宋体", file = win_dir .. "simsun.ttc" },
            { text = "黑体", file = win_dir .. "simhei.ttf" },
            { text = "楷体", file = win_dir .. "simkai.ttf" },
            { text = "Arial", file = win_dir .. "arial.ttf" },
            { text = "Segoe UI", file = win_dir .. "segoeui.ttf" },
            { text = "Consolas", file = win_dir .. "consola.ttf" },
            { text = "思源黑体", file = win_dir .. "SourceHanSansSC-Regular.otf" },
        }
    elseif os_str:match("OSX") or os_str:match("mac") then
        probes = {
            { text = "苹方", file = "/System/Library/Fonts/PingFang.ttc" },
            { text = "华文黑体", file = "/System/Library/Fonts/STHeiti Light.ttc" },
            { text = "Arial", file = "/Library/Fonts/Arial.ttf" },
            { text = "Courier", file = "/System/Library/Fonts/Courier.dfont" },
        }
    end

    -- 1. 通用字族 (Always present)
    local generic = {
        { text = "sans-serif", file = "sans-serif", is_generic = true },
        { text = "serif",      file = "serif",      is_generic = true },
        { text = "monospace",  file = "monospace",  is_generic = true },
    }
    for _, g in ipairs(generic) do table.insert(fonts, g) end

    -- 2. 探针执行 (IO.open 极速检查)
    for _, p in ipairs(probes) do
        local f = io.open(p.file, "r")
        if f then
            f:close()
            table.insert(fonts, { text = p.text, file = p.file, is_system = true })
        end
    end

    return fonts
end

--- ===================== Tree Helpers =====================

--- [V1.2] 统一树结构扫描引擎
--- @param node table 根节点
--- @param target_name string 场景或分类名
--- @param mode string? "exists" (默认), "path" (获取路径), "node" (获取节点对象)
function Utils.ScanTree(node, target_name, mode)
    if not node or not target_name then return nil end
    mode = mode or "exists"
    
    local function _scan(n, current_path)
        -- 检查场景
        if n.scenes then
            for _, s in pairs(n.scenes) do
                if s == target_name then
                    if mode == "exists" then return true end
                    if mode == "path" then return current_path end
                    if mode == "node" then return n end
                end
            end
        end
        -- 检查分类名本身 (如果是查找分类层级)
        if n.name == target_name then
            if mode == "exists" then return true end
            if mode == "path" then return current_path end
            if mode == "node" then return n end
        end
        -- 递归子节点
        if n.children then
            for _, child in ipairs(n.children) do
                local next_path = (current_path == "") and child.name or (current_path .. "/" .. child.name)
                local res = _scan(child, next_path)
                if res then return res end
            end
        end
        return nil
    end
    
    return _scan(node, "")
end

--- [V1.2.1] 获取节点的层级名称路径 (数组形式)
--- @param root table 根节点
--- @param target_node table 目标节点
--- @return table|nil 路径数组 (如 {"Root", "环境音"})
function Utils.GetNodePath(root, target_node)
    if not root or not target_node then return nil end
    local function _find(n, current_path)
        if n == target_node then return current_path end
        if n.children then
            for _, child in ipairs(n.children) do
                local new_path = {}
                for _, p in ipairs(current_path) do table.insert(new_path, p) end
                table.insert(new_path, child.name)
                local res = _find(child, new_path)
                if res then return res end
            end
        end
        return nil
    end
    return _find(root, {root.name})
end

--- [V1.2.1] 根据路径数组查找节点
--- @param root table 根节点
--- @param path_array table 路径名数组
--- @return table|nil 找到的节点
function Utils.LookupNodeByPath(root, path_array)
    if not root or not path_array or #path_array == 0 then return nil end
    if root.name ~= path_array[1] then return nil end
    if #path_array == 1 then return root end
    
    local curr = root
    Utils.Debug("Lookup Start: " .. table.concat(path_array, " -> "))
    for i = 2, #path_array do
        local found = false
        if curr.children then
            for _, child in ipairs(curr.children) do
                if child.name == path_array[i] then
                    curr = child
                    found = true
                    break
                end
            end
        end
        if not found then 
            Utils.Debug("Lookup Failed at segment: " .. tostring(path_array[i]))
            return nil 
        end
    end
    Utils.Debug("Lookup Success: " .. tostring(curr.name))
    return curr
end

--- [V1.2] 获取树中所有场景的集合 (Set)
--- @param node table 根节点
function Utils.GetAllScenes(node)
    local scenes = {}
    local function _scan(n)
        if not n then return end
        if n.scenes then
            for _, s in pairs(n.scenes) do scenes[tostring(s)] = true end
        end
        if n.children then
            for _, c in pairs(n.children) do _scan(c) end
        end
    end
    _scan(node)
    return scenes
end

--- [V1.3] 工业级历史记录引擎
--- @param G table Global reference
--- @param name string Entry name
function Utils.AddToHistory(G, name)
    if not name or name == "" then return end
    G.history = G.history or {}
    for i, h in ipairs(G.history) do
        if h == name then table.remove(G.history, i); break end
    end
    table.insert(G.history, 1, name)
    if #G.history > 50 then table.remove(G.history) end
end

--- [V1.3] 获取轨道在 TCP 中的可见索引
--- @param track MediaTrack
--- @return number
function Utils.GetVisibleTrackIndex(track)
    if not track then return -1 end
    local vis_idx = 0
    for i = 0, reaper.CountTracks(0) - 1 do
        local t = reaper.GetTrack(0, i)
        if reaper.GetMediaTrackInfo_Value(t, "B_SHOWINTCP") ~= 0 then
            if t == track then return vis_idx end
            vis_idx = vis_idx + 1
        end
    end
    return vis_idx
end

--- [V1.3] 根据可见索引获取轨道对象
--- @param target_vis_idx number
--- @return MediaTrack|nil
function Utils.GetTrackFromVisibleIndex(target_vis_idx)
    if target_vis_idx < 0 then return nil end
    local cur_vis = 0
    for i = 0, reaper.CountTracks(0) - 1 do
        local t = reaper.GetTrack(0, i)
        if reaper.GetMediaTrackInfo_Value(t, "B_SHOWINTCP") ~= 0 then
            if cur_vis == target_vis_idx then return t end
            cur_vis = cur_vis + 1
        end
    end
    return nil
end

--- [V1.3] 高性能格式化序列化 (用于 .rsdata)
--- @param val any
--- @param name string|nil
--- @param skipnewlines boolean|nil
--- @param depth number|nil
function Utils.SerializeFormatted(val, name, skipnewlines, depth)
    skipnewlines = skipnewlines or false
    depth = depth or 0
    local tmp = string.rep(" ", depth)
    if name then tmp = tmp .. name .. " = " end
    if type(val) == "table" then
        tmp = tmp .. "{" .. (not skipnewlines and "\n" or "")
        for k, v in pairs(val) do
            local key_str
            if type(k) == "string" then
                if k:match("^[a-zA-Z_][a-zA-Z0-9_]*$") then key_str = k
                else key_str = string.format("[%q]", k) end
            else key_str = "[" .. tostring(k) .. "]" end
            tmp = tmp .. Utils.SerializeFormatted(v, key_str, skipnewlines, depth + 2) .. "," .. (not skipnewlines and "\n" or "")
        end
        tmp = tmp .. string.rep(" ", depth) .. "}"
    elseif type(val) == "number" or type(val) == "boolean" then tmp = tmp .. tostring(val)
    elseif type(val) == "string" then tmp = tmp .. string.format("%q", val)
    else tmp = tmp .. '"[unsupported data type]"' end
    return tmp
end

return Utils

  end)(); package.loaded['Archive_Utils'] = _m; return _m
end)()

local EXTSTATE_SECTION = "YS_Archive"
local lib_path_raw = reaper.GetExtState(EXTSTATE_SECTION, "LibraryPath") or ""
local lib_path = (Utils and Utils.ToUTF8(lib_path_raw) or lib_path_raw):gsub("\\","/"):gsub("/+$","")

-- [Phase 1.5] 校验路径有效性，若失效则要求用户重新选择 (防止搬家后失效)
local function RequestLibPath()
    local retval, folder = reaper.JS_Dialog_BrowseForFolder("请选择‘音效资源库’根目录 (如：J:/音效库)", "", "", 1024)
    if retval > 0 and folder ~= "" then
        -- [V1.3.2] Intelligent Encoding Safeguard via Utils
        local decoded_f = Utils and Utils.ToUTF8(folder) or folder
        local p = decoded_f:gsub("\\","/"):gsub("/+$","")
        reaper.SetExtState(EXTSTATE_SECTION, "LibraryPath", p, true)
        return p
    end
    return nil
end

-- [Phase 1.5] 校验路径是否为空，如果是空则要求用户重新选择 (防止首次启动无路径)
local is_path_valid = (lib_path ~= "")

if not is_path_valid then
    -- [UX] 详细科普提示，仅在首次使用或路径失效时弹出
    local title = "资源库路径已失效 - 拾境 (YS_Archive)"
    local msg = (lib_path == "") and "【什么是资源库？】\n" ..
                "资源库是存放您所有‘音效文件’、‘预设’以及‘分类数据库’的根目录。\n\n" ..
                "【操作指引】\n" ..
                "请在接下来的弹窗中，选择您存放音效资源的文件夹。"
                or "【路径失效提示】\n" ..
                "检测到您之前的资源库路径已失效：\n" .. lib_path .. "\n\n" ..
                "可能是因为您移动了文件夹或更改了驱动器盘符。\n\n" ..
                "【操作指引】\n" ..
                "请在接下来的弹窗中，重新选取当前的‘资源库’根目录。"
    
    reaper.MB(msg, title, 0)
    
    local new_p = RequestLibPath()
    if not new_p then return end
    lib_path = new_p
    is_path_valid = true
end

-- [Phase 1.8] 极速引导层 (Bootloader - <50ms)
local Theme        =  (function()
  local _m = (function()
--[[
 * ReaScript Name: YS_Theme
 * Description: YS Platform 全局 UI 主题工厂
 * Author: YS
 * Version: 17.2
 * About: Soundminer 风格。全局同色基底 + 激活态凸起 + 行分割线。零特效。
--]]

local Theme = (function()
    local r = reaper
    local M = {}

    -- =========================================================
    -- 核心配色 (Soundminer 对标)
    -- 规则：BASE_BG 是绝对主色，所有区域统一用它；
    --       层次感来自 RAISED_BG（激活/选中项变浅）。
    -- =========================================================
    M.COLORS = {
        title_bg    = 0x1A1C1EFF, -- 标题栏 (Obsidian Matte - Option A) [UPDATE]
        title_text  = 0xF5E6C4FF, -- 标题文字 (Champagne Gold - 对齐新 Logo) [UPDATE]
        sidebar_fixed_bg = 0x272A2DFF, -- 侧边栏固定区 (收藏夹/全部) [NEW]
        sidebar_bg  = 0x373A3EFF, -- 侧边栏主要区域 (Mac 陨石灰 Sync) [UPDATE]
        base_bg     = 0x2D2D2DFF, -- 基础框架/工具栏 (Precision Charcoal - 对齐 REAPER 参考) [UPDATE]
        content_bg  = 0x1A1C1EFF, -- 结果区/内容池 (深黑对齐) [UPDATE]
        raised_bg   = 0x2A2E33FF, -- 标签栏底色 (更明显的凸起) [UPDATE]
        input_bg    = 0x383C42FF, -- 输入组件统一底色 (Matte Charcoal 全域对齐) [UPDATE]
        accent_blue = 0x4080FFFF, -- 1px 工业电光蓝 (Active Frame) [NEW]
        frame_black = 0x000000FF, -- 2px 物理框架黑 (Construction Base) [NEW]
        sep         = 0x111111FF, -- 1px 物理拼装缝 (Deep Recess) [UPDATE]
        sep_hi      = 0xFFFFFF33, -- 1px 物理高光边 (Razor Silver Highlight) [UPDATE]
        sidebar_header = 0x7A7E8AFF, -- 侧边栏小标题 (Dimmed)
        sep_lo      = 0x00000040, -- 1px 落影

        text        = 0xFFFFFFFF, -- 一级文字 (Pure White) [UPDATE]
        text_dim    = 0xC8C8C8FF, -- 二级文字 (Lighter Gray) [UPDATE]
        text_deep   = 0x555A65FF, -- 三级文字 (占位符)

        accent      = 0x4488FFFF, -- 统一全域高亮色 (Vibrant Electric Blue)
        accent_dim  = 0x4488FFFF99, -- 强调色 (60% 不透明)
        accent_soft = 0x4488FFFF33, -- 强调色 (20% 不透明，用于背景点缀)
        
        select_bg   = 0x4488FF77, -- 选中背景 (中度透明电光蓝，平衡高亮与压抑感)
        hover_bg    = 0xFFFFFF0D, -- 悬停背景 (~5% 白)
        
        tree_line   = 0xFFFFFF1A, -- 树状层级引导线 (10% 不透明)

        fav         = 0xF4A732FF, -- 收藏标记（暖黄）
        icon_folder = 0xEEF4F9FF, -- 文件夹图标颜色 (Mac 冰白) [NEW]
        close_hover = 0xE05050FF, -- 关闭按鈕悬停
    }

    M.rounding = 12.0 -- 全局圆角参数 (Blueprint Sync)

    -- 预设主题（保留，供未来扩展）
    M.PRESETS = {
        { name = "经典默认",  accent = 0x5E8CF4FF, select_bg = 0x232B3AFF }, -- 还原了原来的核心色
        { name = "商务深海",  accent = 0x2D8B8BFF, select_bg = 0x1F3A3AFF },
        { name = "日落大道",  accent = 0xE76F51FF, select_bg = 0x3A2520FF },
        { name = "极地冰霜",  accent = 0x4A6FA5FF, select_bg = 0x1E2C3AFF },
        { name = "科技创新",  accent = 0x0066FFFF, select_bg = 0x1A2040FF },
    }

    function M.GetUS()
        -- [V13.8] Dual-Track Scale: Prioritize UIScale (float) over legacy FontSize (int)
        local scale = tonumber(r.GetExtState("YS_Archive", "UIScale"))
        if not scale then
            local fs = tonumber(r.GetExtState("YS_Archive", "FontSize")) or 16
            scale = fs / 16.0
        end
        return scale
    end

    function M.Select(idx)
        local p = M.PRESETS[idx]
        if not p then return end
        M.COLORS.accent    = p.accent
        M.COLORS.select_bg = p.select_bg
    end

    -- =========================================================
    -- Push/Pop：全局 ImGui 样式
    -- =========================================================
    function M.Push(ctx)
        if not ctx or not r.ImGui_ValidatePtr(ctx, "ImGui_Context*") then return false end
        local US = M.GetUS()
        local C  = M.COLORS

        local stats = { color = 0, var = 0 }
        local function push_c(col, val) r.ImGui_PushStyleColor(ctx, col, val); stats.color = stats.color + 1 end
        local function push_v(var, val, v2) r.ImGui_PushStyleVar(ctx, var, val, v2); stats.var = stats.var + 1 end

        push_v(r.ImGui_StyleVar_WindowRounding(),    0)
        push_v(r.ImGui_StyleVar_FrameRounding(),     M.rounding * US)
        push_v(r.ImGui_StyleVar_ScrollbarSize(),     4 * US)
        push_v(r.ImGui_StyleVar_ScrollbarRounding(), 12 * US)
        push_v(r.ImGui_StyleVar_ItemSpacing(),       6 * US, 2 * US)
        push_v(r.ImGui_StyleVar_WindowPadding(),     0, 0)
        push_v(r.ImGui_StyleVar_ChildRounding(),     0)
        push_v(r.ImGui_StyleVar_PopupRounding(),     0)
        push_v(r.ImGui_StyleVar_WindowBorderSize(),  0)
        push_v(r.ImGui_StyleVar_ChildBorderSize(),   0)
        -- [V115.5] 兼容性补丁：部分旧版 ReaImGui 缺少以下常量
        if r.ImGui_StyleVar_FrameBorderSize     then push_v(r.ImGui_StyleVar_FrameBorderSize(),   0) end
        if r.ImGui_StyleVar_SelectableTextAlign then push_v(r.ImGui_StyleVar_SelectableTextAlign(), 0, 0.5) end

        push_c(r.ImGui_Col_WindowBg(),              C.base_bg)
        push_c(r.ImGui_Col_ChildBg(),               0x00000000)
        push_c(r.ImGui_Col_Header(),                0x00000000)
        push_c(r.ImGui_Col_HeaderHovered(),         C.hover_bg)
        push_c(r.ImGui_Col_HeaderActive(),          C.select_bg)
        push_c(r.ImGui_Col_FrameBg(),               C.input_bg)
        push_c(r.ImGui_Col_FrameBgHovered(),        0x454A52FF)
        push_c(r.ImGui_Col_CheckMark(),             C.accent)
        push_c(r.ImGui_Col_Button(),                0x00000000)
        push_c(r.ImGui_Col_ButtonHovered(),         C.hover_bg)
        push_c(r.ImGui_Col_ButtonActive(),          C.raised_bg)
        push_c(r.ImGui_Col_Text(),                  C.text)
        push_c(r.ImGui_Col_TextDisabled(),          C.text_dim)
        push_c(r.ImGui_Col_ScrollbarBg(),           0x00000000)
        push_c(r.ImGui_Col_ScrollbarGrab(),         0xFFFFFF18)
        push_c(r.ImGui_Col_ScrollbarGrabHovered(),  0xFFFFFF30)
        push_c(r.ImGui_Col_ScrollbarGrabActive(),   C.accent)
        push_c(r.ImGui_Col_Separator(),             C.sep)
        push_c(r.ImGui_Col_PopupBg(),               C.raised_bg)
        if r.ImGui_Col_NavHighlight then push_c(r.ImGui_Col_NavHighlight(), 0x00000000) end
        if r.ImGui_Col_Border       then push_c(r.ImGui_Col_Border(),       0x00000000) end

        return true, stats
    end

    function M.Pop(ctx, stats)
        if not ctx or not r.ImGui_ValidatePtr(ctx, "ImGui_Context*") then return end
        if not stats then return end
        if stats.var   and stats.var   > 0 then r.ImGui_PopStyleVar(ctx,   stats.var)   end
        if stats.color and stats.color > 0 then r.ImGui_PopStyleColor(ctx, stats.color) end
    end

    -- =========================================================
    -- 工具函数：绘制 1px 分割线（水平）
    -- =========================================================
    function M.DrawSep(dl, x, y, w)
        if not dl then return end
        r.ImGui_DrawList_AddLine(dl, x, y, x + w, y, M.COLORS.sep, 1.0)
    end

    -- =========================================================
    -- 工具函数：绘制 2px 左侧选中竖条 (Glowing Light-Pipe)
    -- =========================================================

    -- =========================================================
    -- [工业级] 性能动态评估引擎 (Performance Adaptive Engine)
    -- =========================================================
    function M.GetPerfScore()
        -- 基础算法：若列表项 > 500 项, 分数降至 60；若 FPS 稳定则回升
        -- 这里简化为基于数据库规模的静态评估，后续可接入实时 FPS
        local g = package.loaded["ExtState_G"]
        if not g then return 100 end

        local score = 100
        if g.tabs and g.tabs[g.active_tab_idx] then
            local count = #(g.tabs[g.active_tab_idx].filtered_scenes or {})
            if count > 2000 then score = 40
            elseif count > 800 then score = 65
            elseif count > 300 then score = 85
            end
        end
        return score
    end

    -- =========================================================
    -- 工具函数：绘制 1px 分割线 (垂直)
    -- =========================================================
    function M.DrawVerticalSep(dl, x, y, h)
        if not dl then return end
        reaper.ImGui_DrawList_AddLine(dl, x, y, x, y + h, M.COLORS.sep, 1.0)
    end

    return M
end)()

return Theme

  end)(); package.loaded['YS_Theme'] = _m; return _m
end)()
local Icons        =  (function()
  local _m = (function()
--[[
 * ReaScript Name: YS_Icons
 * Description: YS Platform 矢量图标绘制模块 (Vector Icons)
 * Author: YS
 * Version: 1.1
 * About: 使用 ImGui DrawList 直接绘制图形或从 Base64 加载贴图，无需外部图片文件。
--]]

local Icons = (function()
    local r = reaper
    local M = { Textures = {} }

    local script_path = debug.getinfo(1, "S").source:match("@?(.*[\\/])") or ""
    local IconsData = nil
    local LoadPending = false
    
    local function LoadGeneBank()
        if IconsData then return IconsData end
        
        -- [PERFORMANCE-FIX] 288KB data is tiny. Load synchronously to ensure 
        -- icons are ready on the VERY FIRST frame, avoiding 'flicker' or 'delay'.
        local status, res = pcall(require, "YS_IconsData")
        if status and type(res) == "table" then
            IconsData = res
        else
            -- Fallback to dofile if require fails
            local path = script_path .. "YS_IconsData.lua"
            status, res = pcall(dofile, path)
            if status then IconsData = res end
        end
        return IconsData
    end

    M.FullColorIcons = { 
        ["piano"] = true, ["piano_off"] = true, ["Piano"] = true,
        ["settings"] = true, ["Lock_Open"] = true, ["Lock_Close"] = true,
        ["history"] = true, ["new"] = true, ["smart_toy"] = true,
        ["AutoClose"] = true, ["Scissor"] = true, ["function"] = true,
        ["download"] = true, ["YS_logo"] = true, ["YS_logo 透"] = true,
        ["save"] = true, ["close"] = true -- [V81.0] Added lowercase variants for new mappings
    } -- 包含全彩资产，用于 stylized 渲染

    local function decodeB64(data)
        local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
        local dec_t = {}; for i = 1, 64 do dec_t[b:sub(i,i)] = i-1 end
        data = string.gsub(data, '[^'..b..'=]', '')
        return (data:gsub('....', function(x)
            if x == "" then return "" end
            local r, c = 0, 0
            for i = 1, 4 do
                local char = x:sub(i,i)
                local v = dec_t[char]
                if v then
                    r = (r << 6) | v
                    c = c + 1
                end
            end
            local res = ""
            if c > 1 then res = res .. string.char((r >> 16) & 255) end
            if c > 2 then res = res .. string.char((r >> 8) & 255) end
            if c > 3 then res = res .. string.char(r & 255) end
            return res
        end))
    end

    function M.GetTexture(ctx, name)
        if not r.ImGui_CreateImageFromMem then return nil end
        
        M.Textures[ctx] = M.Textures[ctx] or {}
        local tex = M.Textures[ctx][name]
        if tex and r.ImGui_ValidatePtr(tex, 'ImGui_Image*') then return tex end

        -- 工业级资源调度 (Gene Bank Only)
        local data = LoadGeneBank()
        if not data then return nil end

        -- 别名与映射：Logo 换成透明版
        local key = name
        if name == "YS_logo" or name == "Logo" then
            key = "YS_logo 透"
        end

        local b64 = data[key]
        
        -- 归一化查找序列：原样 -> 首字母大写 -> 全小写
        if not b64 then
            local alt_key = key:sub(1,1):upper() .. key:sub(2)
            b64 = data[alt_key]
        end
        if not b64 then
            b64 = data[key:lower()]
        end

        -- 占位符兜底
        if not b64 and M.FullColorIcons[key] then
            b64 = data["placeholder"] or data["settings"]
        end
        
        if not b64 then return nil end
        
        local binary = decodeB64(b64)
        local img = r.ImGui_CreateImageFromMem(binary)
        if img then 
            M.Textures[ctx][name] = img
            return img 
        end
        return nil
    end

    --- @param dl any ImGui DrawList
    --- @param x number Screen X
    --- @param y number Screen Y
    --- @param size number Total size (px)
    --- @param active boolean? Is the icon in an active/selected state
    --- @param rounding number? Optional rounding (px) [NEW]
    function M.DrawMacIconBase(dl, x, y, size, active, hov, is_close, rounding)
        local Theme = require("YS_Theme")
        local US = size / 24.0
        local rounding = rounding or (size * 0.24) -- 兜底逻辑
        local shadow_col = 0x00000088 -- [V87.0] 恢复适度投影深度
        
        -- [V113.0] 统一状态：底座归一化使用全局 Theme.COLORS.accent
        local base_col   = 0x3A3A3AFF
        local border_col = 0xFFFFFF33
        if active then
            base_col = Theme.COLORS.accent
            border_col = hov and 0xFFFFFF77 or 0xFFFFFF66
        elseif hov then
            base_col = hov and 0x5599FFFF or Theme.COLORS.accent
            border_col = 0xFFFFFF66
        end
        
        -- 1. 绘制底层软阴影 (Balanced Elevation)
        local s_off = 1.5 * US
        r.ImGui_DrawList_AddRectFilled(dl, x + s_off, y + s_off, x + size + s_off, y + size + s_off, shadow_col, rounding)
        
        -- 2. 绘制主体底座 (Satin Charcoal Tab)
        r.ImGui_DrawList_AddRectFilled(dl, x, y, x + size, y + size, base_col, rounding)
        
        -- 3. 解析矢量高光 (Analytical Vector Sheen)
        -- [V5.1 Ultimate] 彻底抛弃切片！通过逆三角函数实时算出完美圆弧切角，利用原生矢量引擎 (PathArcTo) 堆叠纯正高光穹顶。无任何阶梯锯齿、无分割线。
        local peak_alpha = active and 50 or (hov and 35 or 25)
        local steps = 15
        local layer_alpha = math.ceil(peak_alpha / steps)
        local R = rounding - 1*US
        local x_center_l = x + 1*US + R
        local x_center_r = x + size - 1*US - R
        local y_center = y + 1*US + R
        
        local function GetArcAngle(h_val, is_left)
            local sin_a = math.max(-1.0, math.min(1.0, (h_val - R) / R))
            local cos_a = math.sqrt(math.max(0, 1.0 - sin_a * sin_a))
            return math.atan(sin_a, is_left and -cos_a or cos_a)
        end
        
        for i = 1, steps do
            local h = R * (i / steps)
            r.ImGui_DrawList_PathClear(dl)
            
            local a_left = GetArcAngle(h, true)
            local a_right = GetArcAngle(h, false)
            
            r.ImGui_DrawList_PathArcTo(dl, x_center_l, y_center, R, a_left, -0.5 * math.pi, 0)
            r.ImGui_DrawList_PathArcTo(dl, x_center_r, y_center, R, -0.5 * math.pi, a_right, 0)
            r.ImGui_DrawList_PathFillConvex(dl, 0xFFFFFF00 | layer_alpha)
        end
        
        -- 4. 绘制纤细高光导轨 (Crisp Beveled Edge)
        -- 注：高光导轨必须在渐变**之后**绘制，以作为物理外框将其封死，避免 ImGui 的抗锯齿导致子像素溢出 (Bleeding)
        r.ImGui_DrawList_AddRect(dl, x, y, x + size, y + size, border_col, rounding, nil, 1.0 * US)
        
        -- 5. [V87.0] 适度底部压深 (Subtle Occlusion)
        local occ_col = active and 0x00000066 or 0x00000044
        r.ImGui_DrawList_AddLine(dl, x + rounding, y + size - 0.5*US, x + size - rounding, y + size - 0.5*US, occ_col, 1.0 * US)
    end





    function M.DrawIconButton(ctx, id, tex_name, x, y, size, is_active, col_norm, col_hov, col_act, no_base, hov_override)
        local img = M.GetTexture(ctx, tex_name)
        r.ImGui_SetCursorScreenPos(ctx, x, y)
        
        -- [V115.0] 全域透明屏蔽：图标热区严禁产生原生背景，防止 1px 的 FrameRounding 溢出产生“幽灵角”
        local c_cnt = 3
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(),         0x00000000)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonHovered(),  0x00000000)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonActive(),   0x00000000)
        
        -- [V115.5] 兼容性补丁：屏蔽导航高亮与边框（仅当常量存在时）
        if r.ImGui_Col_NavHighlight then r.ImGui_PushStyleColor(ctx, r.ImGui_Col_NavHighlight(), 0x00000000); c_cnt = c_cnt + 1 end
        if r.ImGui_Col_Border       then r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Border(),       0x00000000); c_cnt = c_cnt + 1 end
        
        -- [V115.1] 热区精确对位：消除 FramePadding 导致的 3px-4px 背景延展
        r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_FramePadding(), 0, 0)
        r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_ItemSpacing(), 0, 0)
        
        local clicked = r.ImGui_InvisibleButton(ctx, id, size, size)
        
        r.ImGui_PopStyleVar(ctx, 2)
        r.ImGui_PopStyleColor(ctx, c_cnt)

        local hov_internal, act = r.ImGui_IsItemHovered(ctx), r.ImGui_IsItemActive(ctx)
        local hov = hov_override ~= nil and hov_override or hov_internal
        
        local dl = r.ImGui_GetWindowDrawList(ctx)
        local scale = act and 0.94 or (hov and 1.06 or 1.0)
        local anim_size = size * scale; local delta = (size - anim_size) * 0.5
        local i_x1, i_y1 = x + delta, y + delta
        
        -- 渲染策略判定：MacOS 风格化重建 (Hybrid Zoom Mode)
        if M.FullColorIcons[tex_name] then
            -- [V28.5 Hybrid Reconstruction] 
            -- 通过 UV 裁剪 (UV Zoom) 剔除 PNG 边缘的透明阴影，改由代码绘制，解决“小且模糊”的问题。
            if img then
                -- [V104.5] 严格限定 is_close 只对真正的标题栏关闭按钮生效，防止误杀带 "close" 的业务按钮
                local is_close = (id == "title_Close")
                -- 只有在没有禁用底座时才画底座 (V76.4 Logic)
                if not no_base then
                    local Theme = require("YS_Theme")
                    local rd = math.min(Theme.rounding, 8.0) * (size/24) -- 锁定工具栏为小圆角，防止 12.0 导致的小图标变圆形
                    M.DrawMacIconBase(dl, i_x1, i_y1, anim_size, is_active, hov, is_close, rd)
                end
                
                -- 2. UV 裁剪叠加：将 512x512 的 PNG 缩放至内框，并裁剪边缘 12% 的透明区。
                -- [V78.4] 修正：大幅减少 UV 裁剪 (0.12 -> 0.01)，防止高密度 PNG 图标边缘显示不全
                local padding = anim_size * 0.01 
                local icon_size = anim_size - padding * 2
                local i_off = padding
                
                -- UV 坐标：[0.01, 0.01] 到 [0.99, 0.99] (接近全屏，保留 1% 呼吸感)
                local u1, v1 = 0.01, 0.01
                local u2, v2 = 0.99, 0.99
                
                -- [V104.0 / V105.0] 符号不再随悬停变色，保持物理白色；但如果无底座（如标题栏）则允许传参染色覆盖
                local tint = 0xFFFFFFFF
                if no_base then
                    if is_close and hov then
                        tint = 0xEE4444FF
                    elseif (act or is_active) and col_act then
                        tint = col_act
                    elseif hov and col_hov then
                        tint = col_hov
                    end
                end
                r.ImGui_DrawList_AddImage(dl, img, i_x1 + i_off, i_y1 + i_off, i_x1 + i_off + icon_size, i_y1 + i_off + icon_size, u1, v1, u2, v2, tint)
            end




        else
            -- 普通图标策略：根据状态染色
            local color = col_norm
            if act or is_active then color = col_act or col_norm
            elseif hov then color = col_hov or col_norm end
            
            if id == "title_Close" and (hov or act) then color = 0xEE4444FF end
            if img then r.ImGui_DrawList_AddImage(dl, img, i_x1, i_y1, i_x1 + anim_size, i_y1 + anim_size, 0, 0, 1, 1, color) end
        end

        return clicked, hov
    end



    function M.DrawStandardHeaderBtn(ctx, id, tex_name, right_margin, cursor_y, header_h, UI_SCALE, Theme)
        local sz = header_h * 0.65; local spacing = 8 * UI_SCALE
        local x = right_margin - sz
        local col_hov = Theme and Theme.COLORS.button_hover or 0xDDDDDDFF
        -- [V82.0] Header 专用：强制禁用底座 (no_base = true)
        local c, h = M.DrawIconButton(ctx, id, tex_name, x, cursor_y + (header_h-sz)/2, sz, false, 0xAAAAAAFF, col_hov, 0xFFFFFFFF, true)
        return c, x - spacing, h
    end

    return M
end)()

return Icons

  end)(); package.loaded['YS_Icons'] = _m; return _m
