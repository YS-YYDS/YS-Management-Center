    return false
end

function UI.DrawAuthUI(ctx, cfg, M, Core, Logger)
    if cfg.is_auth_passed and not cfg.force_show_ui and not cfg.show_trial_nag_modal and not cfg.show_anno_modal then
        return true
    end

    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_WindowPadding(), 0.0, 0.0)
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_WindowRounding(), 12.0)
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_FrameRounding(), 6.0)
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_WindowBg(), 0x00000000)
    
