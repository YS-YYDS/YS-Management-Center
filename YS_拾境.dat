        name = name or "新标签",
        search_text = "",
        selected_cat_node = nil,
        selected_scene = nil,
        filtered_scenes = {},
        search_focused = false
    }
end

function State.RestoreLastUsed(callback)
    if callback then callback() end
end

return State

