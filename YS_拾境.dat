    EngDB        =  (function()
  local _m = (function()
-- ==========================================
-- Engine_DB.lua (Database & Match Engine)
-- ==========================================

local DB = {}
local PRODUCT_ID = "YS_Archive"

local lib_path = ""
local G = nil
local Utils = nil
local Dbg = function() end -- [V1.9.0 Industrial] Default silent dummy

-- For dependencies
local Eng = nil
local Logger = nil -- [INDUCTED] 可观测性基座

function DB.Init(lp, g, u, dbg_fn, eng)
    lib_path = lp; G = g; Utils = u; Eng = eng
    Dbg = dbg_fn or function() end -- Ensure Dbg is never nil
    
    -- 动态感知 Logger
    if package.loaded["Archive_Logger"] then
        Logger = package.loaded["Archive_Logger"]
    end
    
    -- [NEW] 这里的 Registry 由外部注入或动态加载
    local Registry = package.loaded["Modules/Engine_Registry"] or package.loaded["Engine_Registry"]
    if Registry and Registry.Init then
        Registry.Init(lib_path)
    end
end

-- ===================== 数据库 I/O = [Defensive Mode] =====================
local function SanitizeNode(node)
    if not node or type(node) ~= "table" then return end
    
    -- [V3.0.2 Industrial Fix] 强制类型收敛，杜绝损坏数据导致的 ipairs 崩溃
    if type(node.children) ~= "table" then node.children = {} end
    if type(node.scenes) ~= "table" then node.scenes = {} end
    
    for _, child in ipairs(node.children) do
        SanitizeNode(child)
    end
end

local function SerializeNode(node, depth)
    depth = depth or 0
    local indent = string.rep("  ", depth)
    local res = "{\n"
    if node.id then
        res = res .. indent .. string.format('  ["id"] = %q,\n', tostring(node.id))
    end
    if node.name then
        res = res .. indent .. string.format('  ["name"] = %q,\n', node.name)
    end
    -- [Compatibility] Support both 'expanded' and 'is_expanded'
    local exp = (node.expanded ~= nil) and node.expanded or node.is_expanded
    if exp ~= nil then
        res = res .. indent .. '  ["expanded"] = ' .. tostring(exp) .. ',\n'
    end
    if node.scenes and #node.scenes > 0 then
        res = res .. indent .. '  ["scenes"] = {\n'
        for i, s in ipairs(node.scenes) do
            res = res .. indent .. string.format('    [%d] = %q,\n', i, s)
        end
        res = res .. indent .. '  },\n'
    end
    if node.children and #node.children > 0 then
        res = res .. indent .. '  ["children"] = {\n'
        for i, child in ipairs(node.children) do
            res = res .. indent .. string.format('    [%d] = %s,\n', i, SerializeNode(child, depth + 1))
        end
        res = res .. indent .. '  }\n'
    end
    res = res .. indent .. "}"
    return res
end

function DB.SaveDatabase()
    if lib_path == "" or not G.virtual_tree then return end
    local data_dir = lib_path .. "/_Data"
    reaper.RecursiveCreateDirectory(data_dir, 0)
    
    local ok, content = pcall(SerializeNode, G.virtual_tree)
    if not ok or not content then
        if Logger then Logger.error("DB.Save", "serialization_failed", {error = tostring(content or "unknown")}) end
        if G then G._HUD_text_next = "Fatal Serialization Error: 数据库序列化失败" end
        return
    end
    
    local path = (data_dir .. "/hierarchy.db"):gsub("/", "\\")
    local tmp_path = path .. ".tmp"
    
    -- [Industrial] Global handle for writing to avoid frequent reopen
    local f = io.open(tmp_path, "wb")
    if f then
        f:write("return " .. content)
        f:close()
        
        -- [Bug 2 Fix] Robust Overwrite for Windows: os.remove + os.rename
        local success = false
        for i = 1, 10 do -- Increased retry count for high-load systems
            os.remove(path) 
            if os.rename(tmp_path, path) then
                success = true
                if Logger then Logger.info("DB.Save", "ok", {file = "hierarchy.db"}) end
                break
            end
            -- Precise blocking wait to let OS release handles
            local start_t = reaper.time_precise()
            while reaper.time_precise() - start_t < 0.05 do end 
        end
        
        if not success then
            os.remove(tmp_path) 
            if Logger then Logger.error("DB.Save", "write_failed", "Locked or No Permission") end
            if G then G._HUD_text_next = "数据库锁定错误: 无法覆盖 hierarchy.db，请检查权限！" end
        end
    else
        if Logger then Logger.error("DB.Save", "io_create_failed", tmp_path) end
        if G then G._HUD_text_next = "文件IO错误: 无法创建临时数据库文件" end
    end
end

function DB.RescanPhysicalScenes()
    if not G.virtual_tree then Dbg("SCANNER ERROR: G.virtual_tree is nil."); return end
    if not lib_path or lib_path == "" then Dbg("SCANNER ERROR: lib_path is empty."); return end
    
    local scan_dir = lib_path .. "/_Scenes/"
    if Logger then Logger.info("DB.Scan", "start", {path = scan_dir}) end
    Dbg("Scanning Directory: " .. scan_dir)
    
    local existing = Utils.GetAllScenes(G.virtual_tree)
    
    local added_count = 0
    local file_idx = 0
    local total_files_seen = 0
    
    local function GetOrphanCat()
        if not G.virtual_tree.children then G.virtual_tree.children = {} end
        for _, c in ipairs(G.virtual_tree.children) do
            if c.name == "【数据自愈】" then return c end
        end
        local new_node = { name = "【数据自愈】", scenes = {}, children = {}, is_expanded = true }
        table.insert(G.virtual_tree.children, new_node)
        return new_node
    end
    
    -- [V2.2.6] 获取待删除队列索引，避免自愈冲突
    local deleting_files = {}
    if G.delete_queue then
        for _, dq_item in ipairs(G.delete_queue) do
            if dq_item.rs_path then
                local sf = dq_item.rs_path:match("([^/]+)$") or dq_item.rs_path:match("([^\\]+)$")
                if sf then deleting_files[sf:lower()] = true end
            end
        end
    end

    local target_node = nil -- [FIX] Global variable leak fixed
    while true do
        local file = reaper.EnumerateFiles(scan_dir, file_idx)
        if not file then break end
        total_files_seen = total_files_seen + 1
        
        if file:lower():match("%.rsdata$") and not deleting_files[file:lower()] then
            local scene_name = file:gsub("%.[Rr][Ss][Dd][Aa][Tt][Aa]$", "")
            if not existing[scene_name] then
                if not target_node then target_node = GetOrphanCat() end
                table.insert(target_node.scenes, scene_name)
                added_count = added_count + 1
            end
        end
        file_idx = file_idx + 1
    end
    
    Dbg("Scan Complete. Total Files: " .. total_files_seen .. ", Added: " .. added_count)
    if Logger then Logger.info("DB.Scan", "finished", {total = total_files_seen, added = added_count}) end
    
    if added_count > 0 then
        -- [V2.2] 统一隐藏控制台弹窗，保持后台自愈静默执行
        -- reaper.ShowConsoleMsg("\n[YS_Archive] 数据自愈成功: 侦测到物理目录有 " .. added_count .. " 个隐藏（孤儿）搭建，已全部自动检获至【数据自愈】分类！\n")
        DB.SaveDatabase()
    end
end

function DB.LoadDatabase()
    local path = lib_path .. "/_Data/hierarchy.db"
    local f = io.open(path, "r")
    if not f then 
        -- [V3.0.2] 统一诊断：物理文件缺失时输出警告
        if Logger then Logger.warn("DB.Load", "file_missing", {path = path, lib_path = lib_path}) end
        G.virtual_tree = { name = "Root", children = {}, scenes = {} }
        return false 
    end
    local content = f:read("*all")
    f:close()
    
    if content == "" then
        G.virtual_tree = { name = "Root", children = {}, scenes = {} }
        return false
    end

    local fn, load_err = load(content, "DB_DATA", "t", {})
    if not fn then
        if Logger then Logger.error("DB.Load", "syntax_error", {error = tostring(load_err)}) end
        Dbg("Database Syntax Error: " .. (load_err or "Unknown"))
        G.virtual_tree = { name = "Root", children = {}, scenes = {} }
        return false
    end

    local ok, res = pcall(fn)
    if ok and type(res) == "table" then
        -- [V3.0.1 Industrial Fix] 递归自愈：确保所有节点都有 children/scenes 表
        SanitizeNode(res)
        G.virtual_tree = res
        
        local child_count = (res.children and #res.children) or 0
        if Logger then Logger.info("DB.Load", "ok", {node_count = child_count}) end
        Dbg("Database Loaded Successfully.")
        return true
    else
        if Logger then Logger.error("DB.Load", "execution_failed", {error = tostring(res)}) end
        Dbg("Database Execution Error: " .. (res or "Unknown"))
        G.virtual_tree = { name = "Root", children = {}, scenes = {} }
        return false
    end
end


-- ===================== [REDACTED] 匹配引擎已迁移至 Engine_Match.lua =====================

function DB.SaveTabs()
    if not G.tabs then return end
    local tab_data = {}
    for _, t in ipairs(G.tabs) do
        table.insert(tab_data, { name = t.name, search_text = t.search_text })
    end
    Utils.SaveTable("TabsV3", tab_data)
end

function DB.LoadTabs(create_tab_fn)
    local tab_data = Utils.LoadTable("TabsV3")
    if not tab_data then
        -- 为向后兼容，尝试加载旧版
        local old_val = reaper.GetExtState(PRODUCT_ID, "Tabs")
        if old_val == "" then return false end
        tab_data = {}
        for entry in old_val:gmatch("([^;]+)") do
            local name, search = entry:match("([^|]+)|(.*)")
            if name then table.insert(tab_data, { name = name, search_text = search or "" }) end
        end
    end

    if #tab_data == 0 then return false end
    local new_tabs = {}
    for _, d in ipairs(tab_data) do
        local t = create_tab_fn(d.name)
        t.search_text = d.search_text or ""
        table.insert(new_tabs, t)
    end
    G.tabs = new_tabs
    G.active_tab_idx = 1
    return true
end

function DB.LoadFavorites()
    G.favorite_scenes = Utils.LoadTable("FavoritesV3") or {}
    -- 向后兼容
    if next(G.favorite_scenes) == nil then
        local old_val = reaper.GetExtState(PRODUCT_ID, "Favorites")
        if old_val ~= "" then
            for s in old_val:gmatch("([^;]+)") do G.favorite_scenes[s] = true end
        end
    end
end

function DB.SaveFavorites()
    Utils.SaveTable("FavoritesV3", G.favorite_scenes or {})
end

function DB.SetFavoriteStatus(name, status)
    if not G.favorite_scenes then G.favorite_scenes = {} end
    if status then G.favorite_scenes[name] = true
    else G.favorite_scenes[name] = nil end
    DB.SaveFavorites()
    if Eng and Eng.ApplyFilter then Eng.ApplyFilter() end
end

function DB.DeleteScene(name, node, silent)
    if not name then return end
    
    -- [V2.2] 统一场景删除路径：优先使用子文件夹方式，适配 Async 处理器
    local sub_rs = lib_path .. "/_Scenes/" .. name .. "/" .. name .. ".rsdata"
    local flat_rs = lib_path .. "/_Scenes/" .. name .. ".rsdata"
    local rs_path = sub_rs
    if not Utils.FileExistsFast(sub_rs) and Utils.FileExistsFast(flat_rs) then
        rs_path = flat_rs
    end
    
    table.insert(G.delete_queue, { rs_path = rs_path, name = name })
    
    -- [V2.0] 取消注册
    local Registry = package.loaded["Modules/Engine_Registry"] or package.loaded["Engine_Registry"]
    if Registry then Registry.Unregister(name) end
    
    -- [V2.2] 强化删除逻辑：如果提供了 node 则优先从中删除；否则执行全树扫描清理以防 UI 留存
    local removed_from_provided = false
    if node and node.scenes then
        for i, s in ipairs(node.scenes) do
            if s == name then 
                table.remove(node.scenes, i)
                removed_from_provided = true
                break 
            end
        end
    end
    
    -- [V2.2] 全局清理方案 (针对批量删除时节点引用失效或 Context 丢失的情况)
    local function GlobalCleanup(root)
        if not root then return end
        if root.scenes then
            for i = #root.scenes, 1, -1 do
                if root.scenes[i] == name then table.remove(root.scenes, i) end
            end
        end
        if root.children then
            for _, child in ipairs(root.children) do GlobalCleanup(child) end
        end
    end
    if not removed_from_provided then GlobalCleanup(G.virtual_tree) end
    
    -- Remove from favorites
    if G.favorite_scenes then G.favorite_scenes[name] = nil end
    
    if not silent then
        DB.SaveFavorites()
        DB.SaveDatabase()
        if Eng and Eng.ApplyFilter then Eng.ApplyFilter() end
    end
end

--- [V2.0] 批量删除场景
function DB.DeleteScenes(scenes_data)
    if not scenes_data or #scenes_data == 0 then return end
    
    for _, s in ipairs(scenes_data) do
        if s.name then
            DB.DeleteScene(s.name, s.node, true) -- Silent inside loop
        end
    end
    
    DB.SaveFavorites()
    DB.SaveDatabase()
    if Eng and Eng.ApplyFilter then Eng.ApplyFilter() end
end

--- [V2.0] 工业级遗留数据迁移：将旧的平铺结构搬迁到子文件夹结构
function DB.MigrateLegacyData()
    local scan_dir = lib_path .. "/_Scenes/"
    if not Utils.FileExists(scan_dir) then return end
    
    local files_to_migrate = {}
    local file_idx = 0
    while true do
        local f = reaper.EnumerateFiles(scan_dir, file_idx)
        if not f then break end
        if f:lower():match("%.rsdata$") then
            table.insert(files_to_migrate, f)
        end
        file_idx = file_idx + 1
    end
    
    if #files_to_migrate == 0 then return end
    
    local moved_count = 0
    for _, rs_file in ipairs(files_to_migrate) do
        local name = rs_file:gsub("%.[Rr][Ss][Dd][Aa][Tt][Aa]$", "")
        local scene_dir = scan_dir .. name
        
        -- 如果还没文件夹，说明需要迁移
        if not Utils.FileExists(scene_dir) then
            Utils.EnsureDir(scene_dir)
            -- 1. 移动 .rsdata
            os.rename(scan_dir .. rs_file, scene_dir .. "/" .. rs_file)
            
            -- 2. 移动配套音频 (按照旧版命名规则：name_N.ext 或 name_crop_N.wav)
            local audio_idx = 0
            while true do
                local af = reaper.EnumerateFiles(scan_dir, audio_idx)
                if not af then break end
                
                local is_match = false
                if af:match("^" .. name .. "_%d+%.") or af:match("^" .. name .. "_crop_%d+%.") then
                    is_match = true
                end
                
                if is_match then
                    os.rename(scan_dir .. af, scene_dir .. "/" .. af)
                    -- 由于删除了文件，索引不需要加 1 (REAPER 特性)
                else
                    audio_idx = audio_idx + 1
                end
            end
            moved_count = moved_count + 1
            
            -- 3. 注册到 Registry
            local Registry = package.loaded["Modules/Engine_Registry"] or package.loaded["Engine_Registry"]
            if Registry then Registry.Register(name, {}, name) end
        end
    end
    
    if moved_count > 0 and Logger then
        Logger.info("DB.Migrate", "legacy_data_migrated", {count = moved_count})
    end
end

--- [V2.1] 工业级物理索引重建 (Manual Sync)
function DB.RescanPhysicalScenes()
    local scan_dir = lib_path .. "/_Scenes/"
    if not Utils.FileExists(scan_dir) then return true end
    
    local Registry = package.loaded["Modules/Engine_Registry"] or package.loaded["Engine_Registry"]
    if not Registry then return true end
    
    local subdirs = {}
    local d_idx = 0
    while true do
        local d = reaper.EnumerateSubdirectories(scan_dir, d_idx)
        if not d then break end
        table.insert(subdirs, d)
        d_idx = d_idx + 1
    end
    
    local total = #subdirs
    for i, d in ipairs(subdirs) do
        G.rescan_pct = i / total
        G.rescan_status = string.format("正在同步: %s (%d/%d)", d, i, total)
        
        local scene_path = scan_dir .. d
        local rs_file = nil
        local f_idx = 0
        while true do
            local f = reaper.EnumerateFiles(scene_path, f_idx)
            if not f then break end
            if f:lower():match("%.rsdata$") then rs_file = f; break end
            f_idx = f_idx + 1
        end
        
        if rs_file then
            local name = rs_file:gsub("%.[Rr][Ss][Dd][Aa][Tt][Aa]$", "")
            -- 1. 注册物理存在
            Registry.Register(name, {}, d)
            
            -- 2. 如果 UI 树里还没这个场景，加到未分类
            if not Utils.ScanTree(G.virtual_tree, name, "exists") then
                local uncat = Utils.LookupNodeByPath(G.virtual_tree, {G.virtual_tree.name, "未分类"})
                if not uncat then
                    table.insert(G.virtual_tree.children, {name = "未分类", children = {}, scenes = {}})
                    uncat = G.virtual_tree.children[#G.virtual_tree.children]
                end
                table.insert(uncat.scenes, name)
            end
        end
    end
    
    DB.SaveDatabase()
    if Eng and Eng.ApplyFilter then Eng.ApplyFilter() end
    return true
end

--- [V2.1] 工业级孤立资源清理 (Process Cleanup)
function DB.ProcessOrphanSweep(silent)
    local scan_dir = lib_path .. "/_Scenes/"
    if not Utils.FileExists(scan_dir) then return true end
    
    local Registry = package.loaded["Modules/Engine_Registry"] or package.loaded["Engine_Registry"]
    if not Registry then return true end
    
    -- 1. 收集所有已注册的文件夹
    local registered_folders = {}
    local reg_data = {} -- Assuming we can get all registry data
    -- Note: Registry doesn't have an 'GetAll' yet, let's assume it's small enough or add it.
    -- Better: Registry.GetEntry for each scene in the tree.
    local all_scenes = Utils.GetAllScenes(G.virtual_tree)
    for name, _ in pairs(all_scenes) do
        local entry = Registry.GetEntry(name)
        if entry and entry.folder then
            registered_folders[entry.folder:lower()] = true
        end
    end
    
    -- 2. 扫描物理目录，查找不在注册表中的文件夹
    local orphans = {}
    local d_idx = 0
    while true do
        local d = reaper.EnumerateSubdirectories(scan_dir, d_idx)
        if not d then break end
        if not registered_folders[d:lower()] then
            table.insert(orphans, {path = scan_dir .. d, is_dir = true})
        end
        d_idx = d_idx + 1
    end
    
    -- 查找根目录下的孤儿文件 (不在任何子文件夹中的 .rsdata 或其他文件)
    local f_idx = 0
    while true do
        local f = reaper.EnumerateFiles(scan_dir, f_idx)
        if not f then break end
        -- 旧版遗留文件如果不属于任何场景，也是孤儿
        table.insert(orphans, {path = scan_dir .. f, is_dir = false})
        f_idx = f_idx + 1
    end
    
    if #orphans == 0 then return true end
    
    -- 3. 执行清理
    local trash_dir = lib_path .. "/_Trash"
    Utils.EnsureDir(trash_dir)
    
    local total = #orphans
    for i, orphan in ipairs(orphans) do
        G.clean_pct = i / total
        local name = orphan.path:match("([^/\\]+)$")
        G.clean_status = string.format("清理中: %s (%d/%d)", name, i, total)
        
        if orphan.is_dir then
            Utils.SafeRemoveDir(orphan.path, lib_path)
        else
            Utils.SafePhysicalDelete(orphan.path, lib_path)
        end
    end
    
    return true
end

return DB

  end)(); package.loaded['Engine_DB'] = _m; return _m
end)()
    EngIO        =  (function()
  local _m = (function()
--- @version 1.2
--- @description YS 拾境 - 物理级 IO 与自动化引擎 (FileSystem & Automation - Proxy Layer)
--- @author YS / Antigravity
--- [CORE ENGINE: IO PROXY]

local IO = {}

-- [[ 私有状态 ]]
local lib_path = ""
local G = nil
local Utils = nil
local DB = nil
local Logger = nil

-- [[ 子模块引用 ]]
local Piano = nil
local Async = nil
local Scene = nil

--- 初始化 IO 引擎及子引擎
function IO.Init(lp, g_ref, utils_ref, dbg_fn, db_ref)
    lib_path = lp; G = g_ref; Utils = utils_ref; DB = db_ref
    
    if package.loaded["Archive_Logger"] then Logger = package.loaded["Archive_Logger"] end

    -- 动态注入与初始化子引擎
    Piano = package.loaded["Engine_IO_Piano"]
    if Piano then Piano.Init(lp, g_ref, utils_ref, Logger) end
    
    Async = package.loaded["Engine_IO_Async"]
    if Async then Async.Init(lp, g_ref, utils_ref, Logger) end

    Scene = package.loaded["Engine_IO_Scene"]
    if Scene then Scene.Init(lp, g_ref, utils_ref, Logger) end
end

-- ===================== [Piano Proxy] =====================
function IO.SavePianoSession() if Piano then Piano.SavePianoSession() end end
function IO.LoadPianoSession() return Piano and Piano.LoadPianoSession() or false end
function IO.ScanPianoPresets(force) return Piano and Piano.ScanPianoPresets(force) or {} end
function IO.SavePianoPreset(name) return Piano and Piano.SavePianoPreset(name) or false end
function IO.LoadPianoPreset(name) return Piano and Piano.LoadPianoPreset(name) or false end
function IO.DeletePianoPreset(name) 
    return Piano and Piano.DeletePianoPreset(name, Async and Async.SoftRemoveDir) or false 
end
function IO.InsertSample(data, pos, tr) 
    if Piano then 
        Piano.InsertSample(data, pos, tr) 
        if G and G.auto_close then G.force_exit = true end
    end 
end
function IO.PreviewSample(path) if Piano then Piano.PreviewSample(path) end end

-- ===================== [Scene Proxy] =====================
function IO.InsertScene(name, pos, tr) 
    if Scene then 
        Scene.InsertScene(name, pos, tr) 
        if G and G.auto_close then G.force_exit = true end
    end 
end
function IO.SaveScene(name) if Scene then Scene.SaveScene(name) end end

-- ===================== [Async Proxy] =====================
function IO.ProcessAsyncCopyQueue() if Async and Async.ProcessAsyncCopyQueue then Async.ProcessAsyncCopyQueue() end end
function IO.ProcessDeleteQueue() if Async and Async.ProcessDeleteQueue then Async.ProcessDeleteQueue() end end
function IO.ProcessOrphanSweep() if Async and Async.ProcessOrphanSweep then Async.ProcessOrphanSweep() end end

return IO

  end)(); package.loaded['Engine_IO'] = _m; return _m
end)()
    EngMatch     =  (function()
  local _m = (function()
--- @version 1.0
--- @description YS 拾境 - 匹配与过滤引擎 (Match Engine)
--- @author YS / Antigravity

local Match = {}

local G = nil
local lib_path = ""
local Logger = nil
local EngDB = nil

local Utils = nil

function Match.Init(lp, g_ref, db_module, u)
    lib_path = lp
    G = g_ref
    EngDB = db_module
    Utils = u
    
    if package.loaded["Archive_Logger"] then
        Logger = package.loaded["Archive_Logger"]
    end
end

Match._has_scanned_once = false

--- [CORE] 核心过滤逻辑：支持文本搜索与环境音标签过滤
function Match.ApplyFilter()
    if not Match._has_scanned_once then
        if EngDB and EngDB.RescanPhysicalScenes then
            EngDB.RescanPhysicalScenes()
        end
        Match._has_scanned_once = true
    end
    
    if not G.tabs or #G.tabs == 0 then return end
    G.active_tab_idx = math.max(1, math.min(G.active_tab_idx or 1, #G.tabs))
    local active_tab = G.tabs[G.active_tab_idx]
    if not active_tab then return end
    
    local results = {}
    local search = (active_tab.search_text or ""):lower()
    
    if not active_tab.active_tag or active_tab.active_tag == "" then active_tab.active_tag = "全部" end

    local function Scan(node, recursive, depth, res_list)
        if not node then return end
        depth = depth or 0
        if depth > 32 then return end

        if node.scenes then
            for _, sname in pairs(node.scenes) do
                if type(sname) == "string" then
                    local match = (search == "" or sname:lower():find(search, 1, true))
                    
                    if match and active_tab.active_tag ~= "全部" then
                        local is_ambient = (sname:match("环境") or sname:lower():match("ambient"))
                        if active_tab.active_tag == "环境音" then
                            if not is_ambient then match = false end
                        elseif active_tab.active_tag == "默认" then
                            if is_ambient then match = false end
                        end
                    end

                    if match then
                        table.insert(res_list, { name = sname, id = sname, node = node })
                    end
                end
            end
        end
        
        if recursive and node.children then 
            for _, c in pairs(node.children) do Scan(c, true, depth + 1, res_list) end 
        end
    end
    
    local selected = active_tab.selected_cat_node
    local use_global = (not G.is_filter_locked and search ~= "") or (selected == "__ALL__")

    if selected == "__FAVORITES__" then
        if G.favorite_scenes then
            for sname, _ in pairs(G.favorite_scenes or {}) do
                local match = (search == "" or sname:lower():find(search, 1, true))
                if match and active_tab.active_tag ~= "全部" then
                    local is_ambient = (sname:match("环境") or sname:lower():match("ambient"))
                    if active_tab.active_tag == "环境音" then
                        if not is_ambient then match = false end
                    elseif active_tab.active_tag == "默认" then
                        if is_ambient then match = false end
                    end
                end
                if match then table.insert(results, { name = sname, id = sname }) end
            end
        end
    elseif use_global then
        Scan(G.virtual_tree, true, 0, results)
    elseif selected and type(selected) == "table" then
        Scan(selected, true, 0, results)
    else
        Scan(G.virtual_tree, true, 0, results)
    end
    
    table.sort(results, function(a, b) 
        if not a.name or not b.name then return false end
        return a.name < b.name 
    end)
    active_tab.filtered_scenes = results
    
    if Logger then Logger.debug("Match", "filter_applied", {count = #results, search = search, tag = active_tab.active_tag}) end
end

--- [STRUCT] 工业级分类删除逻辑 (Migrated from DB)
function Match.DeleteCategory(cat_node)
    if not cat_node or cat_node == G.virtual_tree then return end
    
    -- [V2.2] UI 刷新优化：如果删除的是当前选中分类或其父级，重置视图到“全部”
    for _, tab in ipairs(G.tabs or {}) do
        local sel = tab.selected_cat_node
        local function IsOrChildOf(node, target)
            if node == target then return true end
            if node.children then
                for _, sub in ipairs(node.children) do
                    if IsOrChildOf(sub, target) then return true end
                end
            end
            return false
        end
        if sel and type(sel) == "table" and IsOrChildOf(cat_node, sel) then
            tab.selected_cat_node = "__ALL__"
        end
    end

    if Logger then Logger.warn("Match.DeleteCategory", "start", {name = cat_node.name}) end
    
    local function find_and_remove(parent, target)
        if not parent.children then return false end
        for i, child in ipairs(parent.children) do
            if child == target then
                local scenes_to_check = {}
                local function scan_node(node)
                    if node.scenes then for _, s in ipairs(node.scenes) do scenes_to_check[s] = true end end
                    if node.children then for _, sub in ipairs(node.children) do scan_node(sub) end end
                end
                scan_node(child)

                table.remove(parent.children, i)
                
                local remaining_scenes = Utils.GetAllScenes(G.virtual_tree)
                
                for sname, _ in pairs(scenes_to_check) do
                    if not remaining_scenes[sname] then
                        -- [V2.0] 统一场景删除路径：优先使用子文件夹方式，Async 处理器现在已支持根据路径自动处理
                        local subfolder_rs = lib_path .. "/_Scenes/" .. sname .. "/" .. sname .. ".rsdata"
                        local flat_rs = lib_path .. "/_Scenes/" .. sname .. ".rsdata"
                        
                        -- 默认传深路径，异步处理器会根据逻辑判断物理存在性
                        local final_rs = subfolder_rs
                        if not Utils.FileExistsFast(subfolder_rs) and Utils.FileExistsFast(flat_rs) then
                            final_rs = flat_rs
                        end
                        
                        table.insert(G.delete_queue, { rs_path = final_rs, name = sname })
                        if G.favorite_scenes then G.favorite_scenes[sname] = nil end
                    end
                end
                
                if EngDB and EngDB.SaveFavorites then EngDB.SaveFavorites() end
                return true
            end
            if find_and_remove(child, target) then return true end
        end
        return false
    end
    
    if find_and_remove(G.virtual_tree, cat_node) then
        if EngDB then EngDB.SaveDatabase() end
        Match.ApplyFilter()
        return true
    end
    return false
end

function Match.MoveSceneToCategory(scene_name, target_node)
    if not scene_name or not target_node or target_node == "__ALL__" or target_node == "__FAVORITES__" then return end
    
    local function RemoveFromTree(node)
        if node.scenes then
            for i, s in ipairs(node.scenes) do
                if s == scene_name then 
                    table.remove(node.scenes, i)
                    return true 
                end
            end
        end
        if node.children then
            for _, child in ipairs(node.children) do
                if RemoveFromTree(child) then return true end
            end
        end
        return false
    end
    
    RemoveFromTree(G.virtual_tree)
    
    if not target_node.scenes then target_node.scenes = {} end
    local exists = false
    for _, s in ipairs(target_node.scenes) do
        if s == scene_name then exists = true; break end
    end
    if not exists then table.insert(target_node.scenes, scene_name) end
    
    if EngDB then EngDB.SaveDatabase() end
    Match.ApplyFilter()
end

function Match.RenameScene(old_name, new_name, node)
    if not old_name or not new_name or old_name == new_name then return end
    new_name = new_name:gsub('"', ''):gsub("'", ""):gsub("[<>:\\/|?*]", "_")
    
    local old_folder = lib_path .. "/_Scenes/" .. old_name
    local old_file = lib_path .. "/_Scenes/" .. old_name .. ".rsdata"
    local renamed_ok = false
    
    if Utils.DirExists(old_folder) then
        -- [V2.2] 现代文件夹结构重命名
        local new_folder = lib_path .. "/_Scenes/" .. new_name
        if os.rename(old_folder, new_folder) then
            -- 尝试同步重命名内部的 .rsdata
            local old_inner = new_folder .. "/" .. old_name .. ".rsdata"
            local new_inner = new_folder .. "/" .. new_name .. ".rsdata"
            if Utils.FileExistsFast(old_inner) then os.rename(old_inner, new_inner) end
            renamed_ok = true
        end
    elseif Utils.FileExistsFast(old_file) then
        -- [V2.0] 传统单文件结构重命名
        local new_file = lib_path .. "/_Scenes/" .. new_name .. ".rsdata"
        if os.rename(old_file, new_file) then renamed_ok = true end
    end
    
    if renamed_ok then
        if node and node.scenes then
            for i, s in ipairs(node.scenes) do
                if s == old_name then node.scenes[i] = new_name; break end
            end
        end
        if G.favorite_scenes and G.favorite_scenes[old_name] then
            G.favorite_scenes[new_name] = true
            G.favorite_scenes[old_name] = nil
        end
        if EngDB then EngDB.SaveDatabase() end
        Match.ApplyFilter()
    end
end

return Match

  end)(); package.loaded['Engine_Match'] = _m; return _m
end)()
    Scene        =  (function()
  local _m = (function()
--- @version 1.0
--- @description YS 拾境 - 场景操作引擎 (Scene Insertion & Saving)
--- @author YS / Antigravity

local Scene = {}
-- reaper.ShowConsoleMsg("[BOOT] Engine_IO_Scene loaded (20260404-v2)\n") 
local lib_path = ""
local G = nil
local Utils = nil
local Logger = nil
local source_cache = {}

function Scene.Init(lp, g_ref, utils_ref, logger_ref)
    lib_path = lp
    G = g_ref
    Utils = utils_ref
    Logger = logger_ref
end

function Scene.InsertScene(name, target_pos, target_track)
    if not name or name == "" then return end
    local rs_path = lib_path .. "/_Scenes/" .. name .. "/" .. name .. ".rsdata"
    if not Utils.FileExists(rs_path) then
        rs_path = lib_path .. "/_Scenes/" .. name .. ".rsdata"
    end
    
    local f = io.open(rs_path, "r")
    if not f then return end
    local content = f:read("*all"); f:close()
    local func = load(content)
    if not func then return end
    local ok, data = pcall(func)
    if not (ok and data and data.items) then return end
    
    reaper.Undo_BeginBlock()
    reaper.PreventUIRefresh(1)
    
    -- Using migrated Utils function
    Utils.AddToHistory(G, name)
    
    local cursor_pos = target_pos or reaper.GetCursorPosition()
    local base_tr_idx = -1
    
    if target_track and reaper.ValidatePtr(target_track, "MediaTrack*") then 
        base_tr_idx = Utils.GetVisibleTrackIndex(target_track)
    else
        local sel_tr = reaper.GetSelectedTrack(0, 0)
        if sel_tr then base_tr_idx = Utils.GetVisibleTrackIndex(sel_tr)
        else
            local last_tr = reaper.GetTrack(0, reaper.CountTracks(0)-1)
            base_tr_idx = last_tr and (Utils.GetVisibleTrackIndex(last_tr) + 1) or 0
        end
    end
    if base_tr_idx < 0 then base_tr_idx = 0 end

    local max_rel = 0
    for _, itd in ipairs(data.items) do 
        if itd.rel_track > max_rel then max_rel = itd.rel_track end 
    end
    
    if G.insert_mode == 1 then
        local tr_at_pos = Utils.GetTrackFromVisibleIndex(base_tr_idx)
        local abs_idx = tr_at_pos and math.floor(reaper.GetMediaTrackInfo_Value(tr_at_pos, "IP_TRACKNUMBER") - 1) or reaper.CountTracks(0)
        for i = 0, max_rel do reaper.InsertTrackAtIndex(abs_idx, true) end
    else
        while Utils.GetTrackFromVisibleIndex(base_tr_idx + max_rel) == nil do
            reaper.InsertTrackAtIndex(reaper.CountTracks(0), true)
        end
    end
    
    for idx, itd in ipairs(data.items) do
        local target_idx = base_tr_idx + itd.rel_track
        local tr = Utils.GetTrackFromVisibleIndex(target_idx)
        if tr and reaper.ValidatePtr(tr, "MediaTrack*") then
            local ni = reaper.AddMediaItemToTrack(tr)
            if not ni then goto skip_item end
            
            reaper.SetMediaItemInfo_Value(ni, "D_POSITION", cursor_pos + itd.rel_pos)
            reaper.SetMediaItemInfo_Value(ni, "D_LENGTH", itd.len)
            
            if itd.chunk and itd.chunk ~= "" then
                 local chunk = itd.chunk
                 chunk = chunk:gsub('\n%s*FILE "[^"]+"', '\nFILE ""')
                 chunk = chunk:gsub('\n%s*FILE [^%s"<>]+', '\nFILE ""')
                 reaper.SetItemStateChunk(ni, chunk, false)
            end
            
            reaper.SetMediaItemInfo_Value(ni, "D_POSITION", cursor_pos + itd.rel_pos)
            reaper.SetMediaItemInfo_Value(ni, "D_LENGTH", itd.len)
            
            if itd.source and itd.source ~= "" then
                -- [V2.0] 动态路径映射：优先在场景子文件夹查找，降级到共享 _Scenes
                local abs = lib_path .. "/_Scenes/" .. name .. "/" .. itd.source
                if not Utils.FileExists(abs) then
                    abs = lib_path .. "/_Scenes/" .. itd.source
                end
                
                local src = source_cache[abs]
                if not src then
                    src = reaper.PCM_Source_CreateFromFile(abs)
                    if src then source_cache[abs] = src end
                end
                if src and reaper.ValidatePtr(src, "PCM_source*") then 
                    local tk = reaper.GetActiveTake(ni)
                    if not tk then tk = reaper.AddTakeToMediaItem(ni) end
                    reaper.SetMediaItemTake_Source(tk, src) 
                else
                    -- 指针失效或文件不存在，重试逻辑
                    source_cache[abs] = nil 
                    local retry_count = 0
                    local function RetryInjection()
                        if not reaper.ValidatePtr(ni, "MediaItem*") then return end
                        local s = source_cache[abs] or reaper.PCM_Source_CreateFromFile(abs)
                        if s and reaper.ValidatePtr(s, "PCM_source*") then
                            source_cache[abs] = s
                            local t = reaper.GetActiveTake(ni)
                            if not t then t = reaper.AddTakeToMediaItem(ni) end
                            reaper.SetMediaItemTake_Source(t, s)
                            reaper.UpdateItemInProject(ni)
                        elseif retry_count < 10 then
                            retry_count = retry_count + 1
                            reaper.defer(RetryInjection)
                        else
                            if G then G._HUD_text_next = "媒体导入失败: 文件被占用或缺失" end
                        end
                    end
                    reaper.defer(RetryInjection)
                end 
            end
        end
        ::skip_item::
    end
    
    reaper.PreventUIRefresh(-1)
    reaper.Undo_EndBlock("插入搭建: "..name, -1)
    reaper.UpdateArrange()
    if Logger then Logger.info("IO.Scene", "scene_injected", {name = name}) end
end

function Scene.SaveScene(name)
    -- [DEFENSE] Logger 诊断入口，任何崩溃都会被捕获并输出到日志
    if Logger then Logger.info("IO.Scene", "save_scene_attempt", {name = name}) end

    local ok, err = pcall(function()
        if not G.tabs or not G.active_tab_idx then
            if Logger then Logger.error("IO.Scene", "save_aborted", "G.tabs or active_tab_idx is nil") end
            return
        end

        local current_tab = G.tabs[G.active_tab_idx]
        if not current_tab then
            if Logger then Logger.error("IO.Scene", "save_aborted", "current_tab is nil") end
            return
        end

        local target_cat = (current_tab.selected_cat_node and type(current_tab.selected_cat_node) == "table") and current_tab.selected_cat_node or nil
        if (not target_cat) or (target_cat == G.virtual_tree) then
            Utils.Debug("Save Scene Aborted: No Category Selected")
            if Logger then Logger.info("IO.Scene", "save_aborted", {reason = "no valid category selected"}) end
            return
        end
        local cat_path = Utils.GetNodePath(G.virtual_tree, target_cat)
        Utils.Debug("Save Scene Target: " .. tostring(target_cat.name) .. " | Path: " .. (cat_path and table.concat(cat_path, "/") or "NIL"))
        
        name = Utils.SafeName(name)
        local scene_dir = lib_path .. "/_Scenes/" .. name
        Utils.EnsureDir(scene_dir)
        
        local count = reaper.CountSelectedMediaItems(0)
        if count == 0 then 
            if G then G._HUD_text_next = "保存被拦截：未在工程中选中任何音频对象！" end
            if Logger then Logger.info("IO.Scene", "save_aborted", {reason = "no items selected"}) end
            return 
        end
        
        if Logger then Logger.info("IO.Scene", "save_collecting", {name = name, items = count}) end
        
        reaper.PreventUIRefresh(1)
        local min_pos = 10^10
        local tracks_set, orig_sel_items, source_counts = {}, {}, {}
        for i=0, count-1 do
            local item = reaper.GetSelectedMediaItem(0, i)
            table.insert(orig_sel_items, item)
            local pos = reaper.GetMediaItemInfo_Value(item, "D_POSITION")
            if pos < min_pos then min_pos = pos end
            tracks_set[reaper.GetMediaItem_Track(item)] = true
            local take = reaper.GetActiveTake(item)
            if take then
                local src = reaper.GetMediaItemTake_Source(take)
                local fn = reaper.GetMediaSourceFileName(src, "")
                if fn ~= "" then source_counts[fn] = (source_counts[fn] or 0) + 1 end
            end
        end
        
        local min_tr_idx = 10^10
        for tr in pairs(tracks_set) do
            local idx = Utils.GetVisibleTrackIndex(tr)
            if idx < min_tr_idx then min_tr_idx = idx end
        end
        
        local track_map = {}
        for tr in pairs(tracks_set) do 
            track_map[tr] = Utils.GetVisibleTrackIndex(tr) - min_tr_idx 
        end
        
        local extract_metadata = { 
            name = name, target_dir = scene_dir, 
            cat = target_cat, cat_path = cat_path, data = { items = {} }, batch_tasks = {} 
        }
        
        local source_file_map = {}
        local unique_file_count = 0
        
        local Async = package.loaded["Engine_IO_Async"]

        for _, item in ipairs(orig_sel_items) do
            if reaper.ValidatePtr(item, "MediaItem*") then
                local take = reaper.GetActiveTake(item)
                local rel_track = track_map[reaper.GetMediaItem_Track(item)]
                local rel_pos = reaper.GetMediaItemInfo_Value(item, "D_POSITION") - min_pos
                local len = reaper.GetMediaItemInfo_Value(item, "D_LENGTH")
                local _, chunk = reaper.GetItemStateChunk(item, "", false)
                chunk = chunk:gsub("IGUID %b{}\r?\n", ""):gsub("GUID %b{}\r?\n", "")
                
                if G.skip_fx and chunk:find("<TAKEFX") then
                    local lines, in_fx = {}, false
                    for line in chunk:gmatch("(.-)\r?\n") do
                        if line:match("^<TAKEFX") then in_fx = true end
                        if not in_fx then table.insert(lines, line) end
                        if in_fx and line == ">" then in_fx = false end
                    end
                    chunk = table.concat(lines, "\n") .. "\n"
                end
                
                local source_path, process_basic_copy = "", true
                if take then
                    local src = reaper.GetMediaItemTake_Source(take)
                    local fn = reaper.GetMediaSourceFileName(src, "")
                    if fn ~= "" then
                        if G.smart_crop and source_counts[fn] == 1 and Async then
                            local src_len = reaper.GetMediaSourceLength(src)
                            local start_offs = reaper.GetMediaItemTakeInfo_Value(take, "D_STARTOFFS")
                            local playrate = reaper.GetMediaItemTakeInfo_Value(take, "D_PLAYRATE")
                            if src_len > 0 and (start_offs > 0.05 or (len * playrate) < src_len - 0.05) then
                                process_basic_copy = false
                                unique_file_count = unique_file_count + 1
                                local g_chunk, s_rel_fn, g_fn = Async.PerformSmartCrop(item, scene_dir, name, unique_file_count)
                                if g_chunk ~= "" then
                                    chunk = g_chunk; source_path = s_rel_fn
                                    local target_f = scene_dir .. "/" .. s_rel_fn
                                    if not os.rename(g_fn, target_f) then
                                        table.insert(extract_metadata.batch_tasks, { type = "copy", src = g_fn, dest = target_f })
                                    end
                                else process_basic_copy = true end
                            end
                        end
                        if process_basic_copy then
                            if source_file_map[fn] then source_path = source_file_map[fn]
                            else
                                unique_file_count = unique_file_count + 1
                                local orig_name = fn:match("([^/\\]+)$") or (name .. "_" .. unique_file_count)
                                local rel_fn = orig_name
                                source_path = rel_fn; source_file_map[fn] = rel_fn
                                local target_f = scene_dir .. "/" .. rel_fn
                                local skip_copy = false
                                if reaper.JS_File_Stat then
                                    local _, sz = reaper.JS_File_Stat(fn)
                                    local _, t_sz = reaper.JS_File_Stat(target_f)
                                    if sz == t_sz then skip_copy = true end
                                end
                                if not skip_copy then table.insert(extract_metadata.batch_tasks, { type = "copy", src = fn, dest = target_f }) end
                            end
                        end
                    end
                end
                table.insert(extract_metadata.data.items, { rel_track = rel_track, rel_pos = rel_pos, len = len, source = source_path, chunk = chunk })
            end
        end
        
        local rsdata_content = "return " .. Utils.SerializeFormatted(extract_metadata.data)
        local rsdata_path = extract_metadata.target_dir .. "/" .. extract_metadata.name .. ".rsdata"
        table.insert(extract_metadata.batch_tasks, { 
            type = "metadata", 
            path = rsdata_path, 
            content = rsdata_content, 
            name = extract_metadata.name, 
            cat = extract_metadata.cat,
            cat_path = extract_metadata.cat_path -- [RECOVERY] 工业级路径追踪
        })
        
        -- [DEFENSE] 确保全局状态队列存在
        if not G.async_copy then G.async_copy = { active = false, tasks = {} } end
        if not G.save_stats then G.save_stats = { current = 0, total = 0, finish_time = 0 } end

        -- Inject tasks into Async queue
        for _, t in ipairs(extract_metadata.batch_tasks) do table.insert(G.async_copy.tasks, t) end
        G.save_stats.total = #G.async_copy.tasks; G.save_stats.current = 0
        G.async_copy.active = true; G.is_saving = true
        reaper.PreventUIRefresh(-1)
        
        if Logger then Logger.info("IO.Scene", "save_queued", {name = name, tasks = #extract_metadata.batch_tasks}) end
    end)

    if not ok then
        reaper.PreventUIRefresh(-1) -- 确保 UI 刷新计数始终平衡
        if Logger then Logger.error("IO.Scene", "save_scene_crashed", tostring(err)) end
        if G then G._HUD_text_next = "⚠ 保存失败，请查看日志: " .. tostring(err):sub(1, 60) end
    end
end

return Scene

  end)(); package.loaded['Engine_IO_Scene'] = _m; return _m
end)()
    Piano        =  (function()
  local _m = (function()
--- @version 1.1
--- @description YS 拾境 - 钢琴模式会话与预设引擎 (Piano Session & Presets)
--- @author YS / Antigravity

local Piano = {}
local lib_path = ""
local G = nil
local Utils = nil

local Logger = nil

function Piano.Init(lp, g_ref, utils_ref, logger_ref)
    lib_path = lp
    G = g_ref
    Utils = utils_ref
    Logger = logger_ref
end

--- [Phase 4] Piano 临时会话持久化 (v1.7)
function Piano.SavePianoSession()
    if lib_path == "" or not G.piano_tabs then return end
    local session_dir = lib_path .. "/_Piano_Temp/"
    reaper.RecursiveCreateDirectory(session_dir, 0)
    
    local snapshot = {
        active_tab = G.piano_active_tab or 1,
        preset_name = G._piano_preset_name,
        tabs = {}
    }
    for ti, tab in ipairs(G.piano_tabs) do
        local tab_data = { name = tab.name, slots = {}, params = tab.params }
        for si, slot in ipairs(tab.slots or {}) do
            local slot_data = {
                mode = slot.mode, alias = slot.alias, key = slot.key,
                poly = slot.poly, step_enabled = slot.step_enabled,
                uv = slot.uv, img_path = slot.img_path, items = {}
            }
            for _, item in ipairs(slot.items or {}) do
                if type(item) == "table" then
                    table.insert(slot_data.items, {
                        type = item.type, path = item.path,
                        offset = item.offset, length = item.length,
                        fade_in = item.fade_in, fade_out = item.fade_out,
                        chunk = item.chunk
                    })
                elseif type(item) == "string" then
                    table.insert(slot_data.items, { type = "sample", path = item })
                end
            end
            tab_data.slots[si] = slot_data
        end
        table.insert(snapshot.tabs, tab_data)
    end

    local content = "return " .. Utils.Serialize(snapshot)
    local f = io.open(session_dir .. "session.ysp", "wb")
    if f then 
        f:write(content); f:flush(); f:close() 
        if Logger then Logger.info("Piano.IO", "session_saved", {tabs = #snapshot.tabs}) end
    else
        if Logger then Logger.error("Piano.IO", "session_save_failed", "Cannot write to " .. session_dir) end
    end
end

function Piano.LoadPianoSession()
    if lib_path == "" then return false end
    local session_path = lib_path .. "/_Piano_Temp/session.ysp"
    local f = io.open(session_path, "rb")
    if not f then return false end
    local content = f:read("*a"); f:close()
    if not content or content == "" then return false end

    local loader, load_err = load(content)
    if not loader then 
        if Logger then Logger.error("Piano.IO", "session_load_parse_error", load_err) end
        return false 
    end
    local ok, data = pcall(loader)
    if not ok or type(data) ~= "table" or not data.tabs then 
        if Logger then Logger.error("Piano.IO", "session_load_failed", "Invalid data format") end
        return false 
    end

    G.piano_tabs = data.tabs
    G.piano_active_tab = data.active_tab or 1
    G._piano_preset_name = data.preset_name
    
    for _, tab in ipairs(G.piano_tabs) do
        if not tab.slots then tab.slots = {} end
        for si = 1, 12 do
            if not tab.slots[si] then
                tab.slots[si] = { mode = "random", items = {}, alias = "", key = "", poly = false, step_enabled = false }
            end
            tab.slots[si].items = tab.slots[si].items or {}
        end
    end
    return true
end

function Piano.ScanPianoPresets(force)
    if lib_path == "" then return {} end
    local now = reaper.time_precise()
    if not force and G.piano_preset_list and G.piano_preset_cache_path == lib_path 
       and (G.piano_preset_cache_time and (now - G.piano_preset_cache_time < 5)) then 
        return G.piano_preset_list 
    end

    local preset_root = lib_path .. "/_Piano_Presets/"
    reaper.RecursiveCreateDirectory(preset_root, 0)
    local list = {}
    local i = 0
    while true do
        local sub = reaper.EnumerateSubdirectories(preset_root, i)
        if not sub then break end
        if Utils.FileExists(preset_root .. sub .. "/preset.ysp") then
            table.insert(list, sub)
        end
        i = i + 1
    end
    G.piano_preset_list = list
    G.piano_preset_cache_path = lib_path
    G.piano_preset_cache_time = now
    G._piano_presets_loaded = true
    return list
end

function Piano.SavePianoPreset(name)
    if not name or name == "" or lib_path == "" then return false end
    local preset_dir = lib_path .. "/_Piano_Presets/" .. name .. "/"
    local audio_dir = preset_dir .. "Audio/"
    local icon_dir = preset_dir .. "Icons/"
    
    reaper.RecursiveCreateDirectory(audio_dir, 0)
    reaper.RecursiveCreateDirectory(icon_dir, 0)

    local snapshot = {}
    for i, tab in ipairs(G.piano_tabs) do
        local tab_clone = { name = tab.name, slots = {}, params = tab.params }
        for s_idx, slot in ipairs(tab.slots) do
            local slot_clone = { 
                alias = slot.alias, mode = slot.mode, 
                step_enabled = slot.step_enabled, uv = slot.uv, items = {} 
            }
            for _, item in ipairs(slot.items) do
                if item.path and item.path ~= "" then
                    local filename = item.path:match("([^/\\]+)$")
                    local target = audio_dir .. filename
                    local version = 2
                    local base_fn = filename:gsub("(%.%w+)$", "")
                    local ext = filename:match("(%.%w+)$") or ""
                    while Utils.FileExists(target) and target ~= item.path do
                        filename = base_fn .. "_v" .. version .. ext
                        target = audio_dir .. filename
                        version = version + 1
                    end
                    local f_in = io.open(item.path, "rb")
                    local f_out = io.open(target, "wb")
                    if f_in and f_out then
                        f_out:write(f_in:read("*a"))
                        f_in:close(); f_out:close()
                    end
                    table.insert(slot_clone.items, {
                        type = item.type, path = "Audio/" .. filename,
                        offset = item.offset, length = item.length,
                        fade_in = item.fade_in, fade_out = item.fade_out,
                        chunk = item.chunk
                    })
                end
            end
            if slot.img_path and slot.img_path ~= "" then
                local img_name = slot.img_path:match("([^/\\]+)$")
                local target_img = icon_dir .. img_name
                local f_in = io.open(slot.img_path, "rb")
                local f_out = io.open(target_img, "wb")
                if f_in and f_out then
                    f_out:write(f_in:read("*a"))
                    f_in:close(); f_out:close()
                end
                slot_clone.img_path = "Icons/" .. img_name
            end
            table.insert(tab_clone.slots, slot_clone)
        end
        table.insert(snapshot, tab_clone)
    end

    local ysp_path = preset_dir .. "preset.ysp"
    local f = io.open(ysp_path, "wb")
    if f then
        f:write("return " .. Utils.Serialize(snapshot))
        f:close()
        G._piano_preset_name = name
        Piano.ScanPianoPresets(true)
        if Logger then Logger.info("Piano.IO", "preset_saved", {name = name}) end
        return true
    end
    if Logger then Logger.error("Piano.IO", "preset_save_failed", {name = name}) end
    return false
end

function Piano.LoadPianoPreset(name)
    if not name or name == "" or lib_path == "" then return false end
    local preset_dir = lib_path .. "/_Piano_Presets/" .. name .. "/"
    local ysp_path = preset_dir .. "preset.ysp"
    if not Utils.FileExists(ysp_path) then return false end

    local f = io.open(ysp_path, "rb")
    local content = f:read("*a"); f:close()
    local loader, err = load(content)
    if not loader then
        if Logger then Logger.error("Piano.IO", "preset_load_parse_error", {name = name, detail = err}) end
        return false
    end
    local ok, data = pcall(loader)
    if not ok or type(data) ~= "table" then 
        if Logger then Logger.error("Piano.IO", "preset_load_failed", {name = name}) end
        return false 
    end

    for _, tab in ipairs(data) do
        if type(tab) ~= "table" then goto next_tab end
        if not tab.slots or type(tab.slots) ~= "table" then tab.slots = {} end
        for si = 1, 12 do
            if not tab.slots[si] or type(tab.slots[si]) ~= "table" then
                tab.slots[si] = { mode = "random", items = {}, alias = "", key = "", poly = false, step_enabled = false }
            end
            local slot = tab.slots[si]
            if not slot.items or type(slot.items) ~= "table" then slot.items = {} end
            for _, item in ipairs(slot.items) do
                if type(item) == "table" and item.path and not (item.path:match("^%a:") or item.path:match("^/")) then
                    item.path = preset_dir .. item.path
                end
            end
            if slot.img_path and type(slot.img_path) == "string" and not (slot.img_path:match("^%a:") or slot.img_path:match("^/")) then
                slot.img_path = preset_dir .. slot.img_path
            end
        end
        ::next_tab::
    end

    G.piano_tabs = data
    for i, tab in ipairs(G.piano_tabs) do
        if not tab.params then
            tab.params = {
                vol_range = 3.0, vol_on = false,
                pitch_shift = 0.2, pitch_on = false,
                step_ms = 700, step_on = false,
                step_rand = 0.2, rand_on = false
            }
        end
    end
    G._piano_preset_name = name
    Piano.ScanPianoPresets()
    return true
end

function Piano.DeletePianoPreset(name, soft_remove_fn)
    if not name or name == "" or lib_path == "" then return false end
    local preset_dir = lib_path .. "/_Piano_Presets/" .. name .. "/"
    
    local function delete_all_files(dir)
        if not Utils.FileExists(dir) then return end
        -- [BUG-001 Fix] 移除 while true，改用有限枚举，防止文件锁定导致的死循环
        for i = 0, 1000 do
            local file = reaper.EnumerateFiles(dir, 0)
            if not file then break end
            local full_path = dir .. file
            local ok, err = os.remove(full_path)
            if not ok then
                -- 如果文件无法删除（被占用），记录并跳过，不再重试，防止主线程挂起
                if Logger then Logger.debug("Piano.Delete", "skip_locked_file", {file = file, err = err}) end
                break -- 遇到无法处理的文件，提前跳出，交给后续的目录层级处理
            end
        end
    end

    if G._piano_preset_name == name and G.piano_tabs then
        local gc_dirs = {}
        for _, tab in ipairs(G.piano_tabs) do
            for _, slot in ipairs(tab.slots or {}) do
                if slot.img_path and slot.img_path:match("_Piano_Assets[/\\]Imported[/\\]([^/\\]+)") then
                    gc_dirs[slot.img_path:match("_Piano_Assets[/\\]Imported[/\\]([^/\\]+)") ] = true
                end
                for _, itm in ipairs(slot.items or {}) do
                    local p = type(itm) == "string" and itm or (type(itm) == "table" and itm.path or "")
                    if p:match("_Piano_Assets[/\\]Imported[/\\]([^/\\]+)") then
                        gc_dirs[p:match("_Piano_Assets[/\\]Imported[/\\]([^/\\]+)") ] = true
                    end
                end
            end
        end
        for dir_name, _ in pairs(gc_dirs) do
            local target_gc = lib_path .. "/_Piano_Assets/Imported/" .. dir_name .. "/"
            delete_all_files(target_gc)
            if soft_remove_fn then soft_remove_fn(target_gc) end
        end
    end

    os.remove(preset_dir .. "preset.ysp")
    delete_all_files(preset_dir .. "Audio/")
    delete_all_files(preset_dir .. "Icons/")
    
    if soft_remove_fn then
        soft_remove_fn(preset_dir .. "Audio/")
        soft_remove_fn(preset_dir .. "Icons/")
        soft_remove_fn(preset_dir)
    end
    
    if G._piano_preset_name == name then G._piano_preset_name = nil end
    Piano.ScanPianoPresets(true)
    return true
end

--- [Phase 5] 钢琴模式插入与试听引擎
function Piano._GetOrCreatePianoTrack()
    local track_name = "🎹 钢琴"
    local count = reaper.CountTracks(0)
    for i = 0, count - 1 do
        local tr = reaper.GetTrack(0, i)
        local _, name = reaper.GetTrackName(tr)
        if name == track_name then return tr end
    end
    reaper.InsertTrackAtIndex(count, true)
    local tr = reaper.GetTrack(0, count)
    reaper.GetSetMediaTrackInfo_String(tr, "P_NAME", track_name, true)
    return tr
end

function Piano.InsertSample(item_data, pos, target_track)
    local path, chunk
    if type(item_data) == "table" then
        path = item_data.path
        chunk = item_data.chunk
    else path = item_data end
    
    if not path or path == "" then return end
    pos = pos or reaper.GetCursorPosition()
    local tr = target_track or Piano._GetOrCreatePianoTrack()
    if not tr then return end
    
    reaper.SetOnlyTrackSelected(tr)
    local new_item
    if chunk and chunk ~= "" then
        new_item = reaper.AddMediaItemToTrack(tr)
        reaper.SetItemStateChunk(new_item, chunk, false)
        reaper.SetMediaItemInfo_Value(new_item, "D_POSITION", pos)
    else
        reaper.SetEditCurPos(pos, false, false)
        reaper.InsertMedia(path, 0)
        new_item = reaper.GetSelectedMediaItem(0, 0)
    end
    
    if new_item then
        local act_t = G.piano_tabs and G.piano_tabs[G.piano_active_tab or 1]
        local params = act_t and act_t.params or G.piano_params or {}
        if params.vol_on then
            local vol_bound = params.vol_range or 12.0
            -- [V4.0] 使用高斯分布，sigma 取范围的 1/3，确保绝大多数值都在范围内
            local vol_db = Utils.GaussianRandom(vol_bound / 3.0)
            reaper.SetMediaItemInfo_Value(new_item, "D_VOL", 10^(vol_db/20))
        end
        if params.pitch_on then
            local st_bound = params.pitch_shift or 24.0
            -- [V4.0] 同理，高斯抖动比均匀抖动更自然 (sigma 为半音范围的 1/3，再转为分)
            local cents = Utils.GaussianRandom(st_bound / 3.0) * 100.0
            local take = reaper.GetActiveTake(new_item)
            if take then reaper.SetMediaItemTakeInfo_Value(take, "D_PITCH", 2^(cents/1200)) end
        end
        reaper.SetMediaItemSelected(new_item, true)
    end
end

function Piano.PreviewSample(path)
    if not path or path == "" then return end
    if G._piano_preview then
        pcall(reaper.CF_Preview_Stop, G._piano_preview)
        G._piano_preview = nil
    end
    if reaper.CF_CreatePreview then
        local src = reaper.PCM_Source_CreateFromFile(path)
        if src then
            local preview = reaper.CF_CreatePreview(src)
            if preview then
                reaper.CF_Preview_SetValue(preview, "D_VOLUME", 1.0)
                reaper.CF_Preview_Play(preview)
                G._piano_preview = preview
            end
        end
    end
end

return Piano

  end)(); package.loaded['Engine_IO_Piano'] = _m; return _m
end)()
    Async        =  (function()
  local _m = (function()
--- @version 1.6
--- @description YS 拾境 - 异步 IO 任务分发中心 (Async IO Dispatcher)
--- @author YS / Antigravity
--- [CORE ENGINE: ASYNC PROCESSOR]

local Async = {}

-- [[ 内部状态 ]]
local lib_path = ""
local Logger = nil
local Utils = nil
local G = {
    save_queue = {},
    delete_queue = {},
    copy_queue = {},      -- [RECOVERY] 发现丢失，已补回
    is_busy = false
}
local Registry = nil

--- 初始化异步引擎
function Async.Init(lp, g_ref, utils_ref, logger_ref)
    lib_path = lp; G = g_ref; Utils = utils_ref; Logger = logger_ref
    
    -- [DEFENSE] 确保全局状态表包含所有必需的任务队列，防止 nil 崩溃
    if G then
        G.save_queue = G.save_queue or {}
        G.delete_queue = G.delete_queue or {}
        G.async_copy = G.async_copy or { active = false, tasks = {} } -- [HARMONIZE] 统一使用 async_copy
        G.is_busy = G.is_busy or false
    end

    -- 将全局状态表注入 Utils，使其 UpdateDeletionTick 可正常追踪时间戳
    if Utils and Utils.Init then Utils.Init(g_ref) end
end

-- ===================== [Task Registration] =====================

--- 入队保存任务 (非阻塞)
function Async.QueueSave(dest, content)
    table.insert(G.save_queue, { dest = dest, content = content })
end

--- 入队删除任务 (非阻塞)
function Async.QueueDelete(rs_path)
    table.insert(G.delete_queue, { rs_path = rs_path })
end

--- 入队拷贝任务 (非阻塞)
function Async.QueueCopy(src, dest)
    if not G.async_copy then G.async_copy = { active = true, tasks = {} } end
    table.insert(G.async_copy.tasks, { type = "copy", src = src, dest = dest })
    G.async_copy.active = true
end

-- ===================== [Task Processing] =====================

--- 处理保存队列 (每帧 1 个)
function Async.ProcessSaveQueue()
    if #G.save_queue == 0 then return end
    
    local ac = table.remove(G.save_queue, 1)
    if not ac or not ac.dest then return end
    
    -- 物理落盘
    local f = io.open(ac.dest, "wb")
    if f then
        f:write(ac.content)
        f:close()
        if Logger then Logger.info("Engine_Async", "File saved: " .. ac.dest) end
    end
end

--- 处理删除队列 (每帧 1 个目录 -> 转入分帧清理)
function Async.ProcessDeleteQueue()
    if #G.delete_queue == 0 then return end
    
    local item = table.remove(G.delete_queue, 1)
    if not item or not item.rs_path then return end
    
    -- [V2.0] 增强删除逻辑：不完全依赖 .rsdata 的物理存在来触发文件夹清理
    local rs_file = item.rs_path
    local parent_dir = rs_file:match("(.*)[/\\]")
    local is_in_scene_subfolder = parent_dir and parent_dir:match("_Scenes[/\\][^/\\]+$")
    
    if is_in_scene_subfolder and Utils.DirExists(parent_dir) then
        -- [PRO STRUCTURE] 只要文件夹在，就尝试清理整个文件夹
        if Logger then Logger.info("Async.Delete", "folder_cleanup", {path = parent_dir}) end
        Utils.SafeRemoveDir(parent_dir, lib_path)
        -- 顺便清理可能存在的残余平铺文件
        local legacy_rs = parent_dir .. ".rsdata"
        if Utils.FileExistsFast(legacy_rs) then os.remove(legacy_rs) end
    elseif Utils.FileExistsFast(rs_file) then
        -- [LEGACY / FALLBACK] 旧版平铺结构
        local scene_dir = rs_file:gsub("%.rsdata$", "")
        if Utils.DirExists(scene_dir) then
            Utils.SafeRemoveDir(scene_dir, lib_path)
        end
        os.remove(rs_file)
        if Logger then Logger.info("Async.Delete", "file_cleanup", {path = rs_file}) end
    end
end

--- 处理异步存储队列 (每帧 1 个任务)
--- 消费 G.async_copy.tasks，支持 "copy" 和 "metadata" 两种任务类型
function Async.ProcessAsyncCopyQueue()
    -- [CRITICAL FIX] 消费的是 G.async_copy.tasks，而非 G.copy_queue
    if not G.async_copy or not G.async_copy.active then return end
    if not G.async_copy.tasks or #G.async_copy.tasks == 0 then
        -- 所有任务已完成
        G.async_copy.active = false
        G.is_saving = false
        G.save_stats.finish_time = reaper.time_precise()
        if G then G._HUD_text_next = "✓ 存储完成" end
        return
    end

    local task = table.remove(G.async_copy.tasks, 1)
    if not task then return end

    -- 更新进度 (Safety Guard)
    if not G.save_stats then G.save_stats = { current = 0, total = 1 } end
    G.save_stats.current = (G.save_stats.current or 0) + 1

    if task.type == "copy" and task.src and task.dest then
        -- [任务A] 文件拷贝 (音频源文件)
        local ok_io, io_err = pcall(function()
            local dir = task.dest:match("(.*[\\/])")
            if dir then reaper.RecursiveCreateDirectory(dir, 0) end
            local inf = io.open(task.src, "rb")
            if inf then
                local content = inf:read("*all")
                inf:close()
                local outf = io.open(task.dest, "wb")
                if outf then
                    outf:write(content)
                    outf:close()
                else error("Failed to open dest for writing: " .. task.dest) end
            else error("Failed to open source for reading: " .. task.src) end
        end)
        
        if not ok_io then
            if Logger then Logger.error("Async.Copy", "io_error", {src = task.src, dest = task.dest, error = tostring(io_err)}) end
            if G then G._HUD_text_next = "⚠ 文件拷贝失败: " .. tostring(io_err):sub(-30) end
        end

    elseif task.type == "metadata" and task.path and task.content then
        -- [任务B] 元数据写入 (WAV 指纹 / 轨道 Chunk / 时间轴信息)
        local ok_meta, meta_err = pcall(function()
            local dir = task.path:match("(.*[\\/])")
            if dir then reaper.RecursiveCreateDirectory(dir, 0) end
            local f = io.open(task.path, "wb")
            if f then
                f:write(task.content)
                f:close()
                if Logger then Logger.info("Async.Meta", "write_ok", {path = task.path}) end
            else error("Failed to open metadata file for writing: " .. task.path) end
        end)

        if not ok_meta then
            if Logger then Logger.error("Async.Meta", "io_error", {path = task.path, error = tostring(meta_err)}) end
            return -- 如果元数据写入失败，不进行后续注册
        end

        -- [NEW] 注册场景物理文件信息
        if not Registry then Registry = package.loaded["Modules/Engine_Registry"] end
        if Registry and task.name then
            local file_list = {}
            if G.async_copy and G.async_copy.tasks then
                -- Note: Since we are in the metadata task, we can't easily see the current batch's files 
                -- because they might have been removed from the queue already.
                -- However, Engine_IO_Scene has 'extract_metadata.data.items' which contains sources.
                -- We can pass the file list in the task metadata.
            end
            -- Since task.content is the rsdata, we can parse it or just trust that the folder exists.
            -- Actually, let's just register the folder presence for now.
            local scene_folder = lib_path .. "/_Scenes/" .. task.name
            Registry.Register(task.name, {}, task.name)
        end

        -- [CRITICAL FIX] 将场景注册到虚拟树
        -- 使用路径化标识 (cat_path) 替代内存指针 (cat)，防止异步过程中的树重载导致注册失效
        local target_node = nil
        if task.cat_path and Utils then
            Utils.Debug("Async Registration Started for: " .. tostring(task.name))
            if Utils.LookupNodeByPath then 
                target_node = Utils.LookupNodeByPath(G.virtual_tree, task.cat_path)
            end
        end
        
        -- 兜底措施: 如果路径失效，尝试使用指针或根节点
        if not target_node then 
            Utils.Debug("Path Lookup Failed, Falling back to Pointer/Root")
            target_node = (task.cat and type(task.cat) == "table") and task.cat or G.virtual_tree 
        end

        if target_node and task.name then
            target_node.scenes = target_node.scenes or {}
            
            -- 防止重复注入 (Re-check)
            local already = false
            for _, s in ipairs(target_node.scenes) do
                if s == task.name then already = true; break end
            end
            if not already then
                table.insert(target_node.scenes, task.name)
                Utils.Debug("Scene Registered Successfully to: " .. tostring(target_node.name))
                if Logger then Logger.info("Async.Meta", "scene_registered", {cat = target_node.name, scene = task.name, mode = (task.cat_path and "path" or "pointer")}) end
            end
        end

        -- 持久化数据库 + 刷新当前搜索结果
        -- [V1.2.2] 修正模块查找键值，处理 package.loaded 中的不同命名习惯
        -- 优先查找当前项目路径，兜底查找全局路径
        local EngDB = package.loaded["Modules/Engine_DB"] or package.loaded["Engine_DB"]
        local EngMatch = package.loaded["Modules/Engine_Match"] or package.loaded["Engine_Match"]

        if EngDB and EngDB.SaveDatabase then 
            EngDB.SaveDatabase() 
            Utils.Debug("Database Saved to hierarchy.db")
        elseif Logger then
            Utils.Debug("WARNING: Engine_DB Handle Missing!")
            Logger.warn("Async.Meta", "Engine_DB NOT FOUND in package.loaded")
        end
        
        -- [V1.2.2] 存储完成后触发匹配引擎刷新，并联动物理自愈作为最终防线
        if EngMatch and EngMatch.ApplyFilter then 
            EngMatch.ApplyFilter() 
        elseif Logger then
            Logger.warn("Async.Meta", "Engine_Match NOT FOUND in package.loaded")
        end

        -- 如果是当前批次的最后一个任务，执行物理自愈作为双保险
        if #G.async_copy.tasks == 0 and EngDB and EngDB.RescanPhysicalScenes then
            EngDB.RescanPhysicalScenes()
            if Logger then Logger.info("Async.Meta", "final_rescan_safety_net_triggered") end
        end
    end
end

--- 垃圾回收扫描 [RECOVERY]
function Async.ProcessOrphanSweep()
    -- 占位符：防止调用错误，未来可实现 _Trash 的过期自动清理
end

--- 定时更新 (由 Main 循环调用)
function Async.Update()
    Async.ProcessSaveQueue()
    Async.ProcessDeleteQueue()
    Async.ProcessAsyncCopyQueue()
end

-- ===================== [Smart Crop Engine] =====================

--- 智能裁剪引擎 — Source-Only Render (Non-destructive)
--- 使用 AudioAccessor 流式读取 Take 实际使用区间的原始波形数据并写入 WAV。
--- FX链、淡入淡出、包络均完整保留在 Chunk 中，不会被烘焙。
---
--- @param item MediaItem   待处理的媒体项目
--- @param target_dir string 输出目录
--- @param name string       场景名称 (用于生成文件名)
--- @param index number      当前文件索引 (防止重名)
--- @return string g_chunk   修改后的项目 Chunk
--- @return string s_rel_fn  目标目录内的相对路径
--- @return string g_fn      输出文件的绝对路径
function Async.PerformSmartCrop(item, target_dir, name, index)
    -- ========== 安全防御 ==========
    if not (item and reaper.ValidatePtr(item, "MediaItem*")) then return "", "", "" end
    local take = reaper.GetActiveTake(item)
    if not take then return "", "", "" end

    local src    = reaper.GetMediaItemTake_Source(take)
    local orig_fn = reaper.GetMediaSourceFileName(src, "")
    if orig_fn == "" then return "", "", "" end

    -- ========== 获取源文件属性 ==========
    local samplerate = reaper.GetMediaSourceSampleRate(src)
    local nch        = reaper.GetMediaSourceNumChannels(src)
    if samplerate <= 0 then samplerate = 44100 end
    if nch <= 0 then nch = 1 end

    -- ========== 计算待裁剪时长 ==========
    -- crop_dur = 在项目时间轴上实际可见的长度
    local crop_dur  = reaper.GetMediaItemInfo_Value(item, "D_LENGTH")
    
    -- ========== 准备输出 ==========
    local rel_fn = string.format("%s_crop_%d.wav", name, index)
    local g_fn   = (target_dir:gsub("\\", "/"):gsub("/+$", "")) .. "/" .. rel_fn
    if Utils and Utils.EnsureDir then Utils.EnsureDir(target_dir) end

    local f = io.open(g_fn, "wb")
    if not f then 
        Utils.Debug("SmartCrop Error: Failed to open file for writing: " .. tostring(g_fn))
        return "", "", "" 
    end

    -- ========== 创建 AudioAccessor ==========
    local acc = reaper.CreateTakeAudioAccessor(take)
    if not acc then 
        f:close()
        Utils.Debug("SmartCrop Error: Failed to create AudioAccessor")
        return "", "", "" 
    end

    Utils.Debug(string.format("SmartCrop Start: %s | SR: %d | Ch: %d | Dur: %.3fs", rel_fn, samplerate, nch, crop_dur))

    -- ========== 写入 WAV Header (IEEE 32-bit Float) ==========
    local total_smp = math.floor(crop_dur * samplerate + 0.5)
    local data_sz   = total_smp * nch * 4

    f:write("RIFF")
    f:write(string.pack("<I4", 36 + data_sz))
    f:write("WAVE")
    f:write("fmt ")
    f:write(string.pack("<I4", 16))          -- Subchunk1Size
    f:write(string.pack("<I2", 3))           -- AudioFormat (3 = IEEE Float)
    f:write(string.pack("<I2", nch))
    f:write(string.pack("<I4", samplerate))
    f:write(string.pack("<I4", samplerate * nch * 4)) -- ByteRate
    f:write(string.pack("<I2", nch * 4))     -- BlockAlign
    f:write(string.pack("<I2", 32))          -- BitsPerSample
    f:write("data")
    f:write(string.pack("<I4", data_sz))

    -- ========== 流式读取 + 写入 ==========
    local BLOCK   = 2048
    local buf     = reaper.new_array(BLOCK * nch)
    local written = 0

    while written < total_smp do
        local n   = math.min(BLOCK, total_smp - written)
        local t_s = written / samplerate
        buf.clear(0)
        local ret = reaper.GetAudioAccessorSamples(acc, samplerate, nch, t_s, n, buf)
        
        if ret <= 0 then 
            -- 如果返回 0，说明数据还没准备好，在这种同步循环中我们需要稍作等待或重试
            -- 但在脚本流程中，我们先记录这个异常情况
            if ret < 0 then 
                Utils.Debug("SmartCrop Warning: AudioAccessor Invalid at " .. tostring(written))
                break 
            end
        end
        
        for i = 1, n * nch do
            f:write(string.pack("<f", math.max(-1.0, math.min(1.0, buf[i] or 0))))
        end
        written = written + n
    end

    Utils.Debug(string.format("SmartCrop Finished: %d samples written", written))

    f:close()
    reaper.DestroyAudioAccessor(acc)

    -- ========== 修改 Chunk 引用 (FX链，淡居均保留) ==========
    local _, g_chunk = reaper.GetItemStateChunk(item, "", false)
    -- 移除 GUID 噪音 (与 Engine_IO_Scene.lua 处理一致)
    g_chunk = g_chunk:gsub("IGUID %b{}\r?\n", ""):gsub("GUID %b{}\r?\n", "")
    -- 重指源文件路径
    local esc_fn = g_fn:gsub("\\", "/"):gsub('"', '\\"')
    g_chunk = g_chunk:gsub('FILE "([^"]*)"', 'FILE "' .. esc_fn .. '"')
    -- 将 D_STARTOFFS 重置为 0 (裁剪后的文件从头开始)
    g_chunk = g_chunk:gsub("D_STARTOFFS%s+[%d%.%-eE%+]+", "D_STARTOFFS 0")

    return g_chunk, rel_fn, g_fn
end



--- 兼容性包装：软删除目录
function Async.SoftRemoveDir(dir_path)
    if not dir_path or dir_path == "" then return end
    if Utils and Utils.SafeRemoveDir then
        Utils.SafeRemoveDir(dir_path, lib_path)
    end
end

return Async

  end)(); package.loaded['Engine_IO_Async'] = _m; return _m
end)()
    Exchange     =  (function()
  local _m = (function()
--- @version 1.1
--- @description YS 拾境 - 工业级资产交换引擎 (Asset Exchange Engine)
--- @author YS / Antigravity
--- [ASYNCHRONOUS PACK/UNPACK ENGINE]

local Exchange = {}
local G = nil
local Eng = nil
local lib_path = ""
local Utils = nil
local r = reaper

local is_mac = r.GetOS():match("mac") or r.GetOS():match("OSX") or r.GetOS():match("macOS")

function Exchange.Init(g, eng, lp, utils_ref)
    G = g
    Eng = eng
    lib_path = lp
    Utils = utils_ref
end

--- [NEW] 清理所有残留的导出临时目录
function Exchange.Cleanup()
    local res_path = r.GetResourcePath():gsub("\\", "/")
    local i = 0
    while true do
        local dir = r.EnumerateSubdirectories(res_path, i)
        if not dir then break end
        if dir:match("^YS_MainExport_Temp_") or dir:match("^YS_PianoExport_Temp_") or dir:match("^YS_PianoPresetsExport_Temp_") then
            Utils.SafeRemoveDir(res_path .. "/" .. dir)
            -- 因为删除了目录，索引不需要增加，重新检查当前索引
        else
            i = i + 1
        end
    end
end

-- ===================== Common Helpers =====================
-- [Refactored] Now using Utils equivalents for EnsureDir, SafeRemoveDir

local function MappingProgress(real)
    if real < 0.2 then
        return real * 3.0 -- 0.2 对应 0.6
    else
        return 0.6 + (real - 0.2) * 0.4875 -- 0.8 段映射到 0.39 段，最终 0.9875 (约 0.99)
    end
end

local function Internal_StepFiles(sess, status_prefix)
    if sess.phase ~= "COPY" then return false end
    sess.f_idx = sess.f_idx + 1
    local f = sess.pending_files[sess.f_idx]
    
    if f then
        local disp_f = f.rel or f.src:match("[^/]+$") or "file"
        sess.status = status_prefix .. ": " .. Utils.TruncateString(disp_f, 40) .. " (" .. sess.f_idx .. "/" .. sess.total_files .. ")"
        
        -- [V1.2.5] 增强路径安全：确保目标文件的父目录绝对存在
        local dst_dir = f.dst:match("(.+)[/\\\\][^/\\\\]+$")
        if dst_dir then Utils.EnsureDir(dst_dir) end
        
        -- reaper.ShowConsoleMsg("[Debug] 正在拷贝: " .. tostring(f.src) .. "\n -> 目标: " .. tostring(f.dst) .. "\n")
        
        --- 统一 UTF-8 转换 (针对 Windows 文件系统名)兼容性
        local success = false
        
        -- 方案 A: 使用 JS_API (官方推荐的高性能方案，完美支持中文)
        if reaper.JS_File_Copy then
            success = reaper.JS_File_Copy(f.src, f.dst)
        end
        
        -- 方案 B: Lua 二进制流回退 (跨平台)
        if not success then
            local in_f = io.open(f.src, "rb")
            if in_f then
                local data = in_f:read("*all"); in_f:close()
                local out_f = io.open(f.dst, "wb")
                if out_f then
                    out_f:write(data); out_f:close()
                    success = true
                end
            end
        end

        if success and f.item_meta then
            if not f.item_meta.audio_files then f.item_meta.audio_files = {} end
            table.insert(f.item_meta.audio_files, { rel_path = f.rel, size = 0 }) -- Size here is optional for manifest
        end
        if not success then
            -- reaper.ShowConsoleMsg("[Debug] ERROR: 拷贝失败! " .. tostring(f.src) .. "\n")
        end
        
        return false
    else
        sess.phase = "FINAL"
        return false
    end
end

-- ===================== Pack (Main UI Export) =====================

local function FlattenTargets(targets)
    local out = {}
    local seen = {}
    
    local function ParseNode(node, current_path)
        if not node then return end
        -- 1. 抓取当前节点的所有场景
        if node.scenes then
            for _, s in pairs(node.scenes) do
                local sname = type(s) == "table" and s.name or s
                local key = sname .. "||" .. (current_path or "")
                if not seen[key] then
                    seen[key] = true
                    table.insert(out, { name = sname, path = current_path or "" })
                end
            end
        end
        -- 2. 递归抓取子目录
        if node.children then
            for _, child in ipairs(node.children) do
                local child_name = child.name or "Unknown"
                local next_p = (current_path == "") and child_name or (current_path .. "/" .. child_name)
                ParseNode(child, next_p)
            end
        end
    end

    for _, t in ipairs(targets) do
        if t == "Root" or (type(t) == "table" and (t.name == "Root" or not t.name)) then
            ParseNode(G.virtual_tree, "")
        elseif t == "Favorites" then
            for sname, _ in pairs(G.favorite_scenes or {}) do
                local path = Utils.ScanTree(G.virtual_tree, sname, "path") or ""
                table.insert(out, { name = sname, path = path })
            end
        else
            -- [修复点] 如果目标是名字（字符串）或单节点表，先在树中定位该节点
            local target_name = type(t) == "table" and t.name or t
            local node = Utils.ScanTree(G.virtual_tree, target_name, "node")
            if node then
                local path = Utils.ScanTree(G.virtual_tree, target_name, "path") or ""
                ParseNode(node, path)
            else
                -- 降级方案：如果树里找不到节点（可能是场景名），直接作为单场景处理
                table.insert(out, { name = target_name, path = "" })
            end
        end
    end
    return out
end

-- ===================== Main UI Export Sessions (Asynchronous) =====================
local main_pack_sess = nil

function Exchange.CreateMainPackSession(targets, export_file_path)
    if main_pack_sess and not main_pack_sess.done then 
        reaper.MB("当前已有打包任务正在运行，请等待完成后再试。", "操作由于冲突被拦截", 0)
        return nil 
    end
    if not targets or type(targets) ~= "table" then return nil end
    local scenes = FlattenTargets(targets)
    if #scenes == 0 then return nil end

    local tmp_dir_name = "YS_MainExport_Temp_" .. tostring(os.time())
    local tmp_dir = r.GetResourcePath() .. "/" .. tmp_dir_name
    Utils.EnsureDir(tmp_dir)

    main_pack_sess = {
        scenes = scenes,
        total_scenes = #scenes,
        scene_idx = 0,
        pending_files = {}, -- { {src, dst, rel, sname, audio_meta} }
        manifest = { version = 142, export_date = os.date("%Y-%m-%d %H:%M:%S"), items = {} },
        tmp_dir = tmp_dir,
        final_path = export_file_path,
        status = "准备中...",
        done = false,
        phase = "SCAN" -- SCAN, COPY, FINAL
    }
    return main_pack_sess
end

function Exchange.StepMainPackSession()
    if not main_pack_sess or main_pack_sess.done then return true end

    if main_pack_sess.phase == "SCAN" then
        main_pack_sess.scene_idx = main_pack_sess.scene_idx + 1
        local sinfo = main_pack_sess.scenes[main_pack_sess.scene_idx]
        local sname = sinfo and sinfo.name
        local spath = sinfo and sinfo.path
        local scenes_dir = lib_path .. "/_Scenes"
        
        if sname then
            main_pack_sess.status = "检索: " .. sname .. " (" .. main_pack_sess.scene_idx .. "/" .. main_pack_sess.total_scenes .. ")"
            local is_folder_structure = false
            local rsdata_path = scenes_dir .. "/" .. sname .. "/" .. sname .. ".rsdata"
            if not Utils.FileExists(rsdata_path) then
                rsdata_path = scenes_dir .. "/" .. sname .. ".rsdata"
            else
                is_folder_structure = true
            end
            
            -- reaper.ShowConsoleMsg("[Debug] ===========================\n[Debug] 扫描场景: " .. tostring(sname) .. "\n[Debug] 尝试打开: " .. tostring(rsdata_path) .. "\n")
            local f = io.open(rsdata_path, "r")
            if f then
                local content = f:read("*all"); f:close()
                local func = load(content)
                if func then
                    local ok, scene_data = pcall(func)
                    if ok and type(scene_data) == "table" then
                        local item_meta = { name = sname, parent_path = spath or "", audio_files = {}, rsdata_content = content }
                        table.insert(main_pack_sess.manifest.items, item_meta)
                        
                        -- [NEW FIX] 根据结构类型决定导出路径
                        local rs_rel = is_folder_structure and ("_Scenes/" .. sname .. "/" .. sname .. ".rsdata") or ("_Scenes/" .. sname .. ".rsdata")
                        table.insert(main_pack_sess.pending_files, {
                            src = rsdata_path,
                            dst = main_pack_sess.tmp_dir .. "/" .. rs_rel,
                            rel = rs_rel
                        })

                        for _, item in ipairs(scene_data.items or {}) do
                            if item.source and item.source ~= "" then
                                local src_abs = ""
                                local src_rel = ""
                                
                                if is_folder_structure and Utils.FileExists(scenes_dir .. "/" .. sname .. "/" .. item.source) then
                                    src_abs = scenes_dir .. "/" .. sname .. "/" .. item.source
                                    src_rel = "_Scenes/" .. sname .. "/" .. item.source
                                else
                                    src_abs = lib_path .. "/" .. item.source
                                    src_rel = item.source
                                    -- 如果 item.source 不是完整的 _Scenes 路径，降级兼容
                                    if not Utils.FileExists(src_abs) and Utils.FileExists(scenes_dir .. "/" .. item.source) then
                                        src_abs = scenes_dir .. "/" .. item.source
                                        src_rel = "_Scenes/" .. item.source
                                    end
                                end

                                table.insert(main_pack_sess.pending_files, {
                                    src = src_abs,
                                    dst = main_pack_sess.tmp_dir .. "/" .. src_rel,
                                    rel = src_rel,
                                    item_meta = item_meta
                                })
                            end
                        end
                    end
                end
            end
            if not f then
                -- reaper.ShowConsoleMsg("[Debug] ERROR: 无法打开文件: " .. tostring(rsdata_path) .. "\n")
            end
            return false
        else
            -- reaper.ShowConsoleMsg("[Debug] SCAN 完成，总计入队待拷贝文件: " .. tostring(#main_pack_sess.pending_files) .. "\n[Debug] ===========================\n")
            main_pack_sess.phase = "COPY"
            main_pack_sess.total_files = #main_pack_sess.pending_files
            main_pack_sess.f_idx = 0 -- Changed from file_idx to f_idx
            if main_pack_sess.total_files == 0 then main_pack_sess.phase = "FINAL" end
            return false
        end

    elseif main_pack_sess.phase == "COPY" then
        return Internal_StepFiles(main_pack_sess, "打包资源")
    
    elseif main_pack_sess.phase == "FINAL" then
        -- Finalize Zip/Folder
        if not main_pack_sess.meta_done then
            main_pack_sess.status = "正在合并清单并导出..."
            local m_path = main_pack_sess.tmp_dir .. "/manifest.ysa"
            local mf = io.open(m_path, "wb")
            if mf then mf:write("return " .. Utils.Serialize(main_pack_sess.manifest)); mf:close() end
            main_pack_sess.meta_done = true
            return false
        end
        main_pack_sess.status = "正在将资源包移至目标路径..."

        local final_path = main_pack_sess.final_path
        if not final_path:match("%.ysa$") then final_path = final_path .. ".ysa" end
        local final_dir = final_path:gsub("%.ysa$", "")
        
        Utils.SafeRemoveDir(final_dir)
        local move_ok = os.rename(main_pack_sess.tmp_dir, final_dir)
        if not move_ok then
            -- Fallback: Pure Lua Copy-then-Delete if cross-drive (Case 43)
            -- 彻底弃用 os.execute("xcopy") 以防止 UI 假死
            Utils.EnsureDir(final_dir)
            local function recursive_copy(s, d)
                r.RecursiveCreateDirectory(d, 0)
                local idx = 0
                while true do
                    local f = r.EnumerateFiles(s, idx)
                    if not f then break end
                    local sf, df = s.."/"..f, d.."/"..f
                    local inf = io.open(sf, "rb")
                    if inf then
                        local dat = inf:read("*all"); inf:close()
                        local outf = io.open(df, "wb")
                        if outf then outf:write(dat); outf:close() end
                    end
                    idx = idx + 1
                end
                local sidx = 0
                while true do
                    local sub = r.EnumerateSubdirectories(s, sidx)
                    if not sub then break end
                    recursive_copy(s.."/"..sub, d.."/"..sub)
                    sidx = sidx + 1
                end
            end
            recursive_copy(main_pack_sess.tmp_dir, final_dir)
            Utils.SafeRemoveDir(main_pack_sess.tmp_dir)
        end
        main_pack_sess.done = true
        return true
    end
end

function Exchange.GetMainPackStatus()
    if not main_pack_sess then return 1.0, "就绪" end
    if main_pack_sess.done then return 1.0, "完成" end
    
    local real = 0
    if main_pack_sess.phase == "SCAN" then
        real = (main_pack_sess.scene_idx / main_pack_sess.total_scenes) * 0.2
    elseif main_pack_sess.phase == "COPY" then
        real = 0.2 + (main_pack_sess.f_idx / main_pack_sess.total_files) * 0.79
    elseif main_pack_sess.phase == "FINAL" then
        real = 0.99
    end
    return MappingProgress(real), main_pack_sess.status
end

-- Legacy Sync Pack (Wired to use session internally to minimize duplication)
function Exchange.Pack(targets, export_zip_path)
    local sess = Exchange.CreateMainPackSession(targets, export_zip_path)
    if not sess then return end
    while not Exchange.StepMainPackSession() do end
    r.MB("资源已成功打包导出！", "分享成功", 0)
end

-- ===================== Unpack (Import) =====================

local function GetLocalFile(name)
    local rsdata_path = lib_path .. "/_Scenes/" .. name .. ".rsdata"
    local f = io.open(rsdata_path, "rb")
    if f then local sz = f:seek("end"); f:close(); return { name = name, size = sz } end
    return nil
end

local function ArbitrateConflict(imported_file, is_piano)
    local exists = false
    if is_piano then
        local f = io.open(lib_path .. "/_Piano_Presets/" .. imported_file.name .. "/preset.ysp", "r")
        if f then f:close(); exists = true end
    else
        exists = GetLocalFile(imported_file.name) ~= nil
    end
    if not exists then return "COPY_DIRECT", imported_file.name end
    
    -- [V2.2.7] 优先级修正：手动单次决议 (import_resolution) 必须高于批量决议 (last_import_resolution)
    if G.import_resolution then
        local res = G.import_resolution
        G.import_resolution = nil -- 执行后立即清理
        return res, imported_file.name
    end

    if G.last_import_resolution then
        return G.last_import_resolution, imported_file.name
    end

    -- 触发 UI 弹窗并挂起引擎
    G.import_conflict_item = imported_file.name
    G.trigger_exchange_conflict = true
    return "AWAITING_ARBITRATION", nil
end

local function FindOrCreateNode(root, path, new_cats_map)
    if not path or path == "" then return root end
    local final_path = path
    local current = root
    for part in final_path:gmatch("[^/]+") do
        if not current.children then current.children = {} end
        local found = false
        for _, c in ipairs(current.children) do
            if c.name == part then current = c; found = true; break end
        end
        if not found then
            if new_cats_map then new_cats_map[part] = true end
            local new_node = { name = part, scenes = {}, children = {}, expanded = true }
            table.insert(current.children, new_node); current = new_node
        end
    end
    return current
end

-- ===================== Unpack Sessions (Asynchronous) =====================
local unpack_sess = nil

function Exchange.CreateUnpackSession(import_path)
    -- [V2.2.7] 会话锁解开：如果 modal 已关闭但 session 还在，视为孤儿 session 强制释放
    if unpack_sess and not unpack_sess.done then 
        if not G.active_modal_id or (G.active_modal_id ~= "导入进度" and G.active_modal_id ~= "导入冲突") then
            unpack_sess = nil -- 强制重置
        else
            reaper.MB("当前已有导入任务正在运行，请等待完成后再试。", "操作由于冲突被拦截", 0)
            return nil 
        end
    end
    local work_dir = import_path:gsub("\\", "/")
    if work_dir:match("manifest%.ysa$") then
        work_dir = work_dir:match("(.+)/[^/]+$") or work_dir
    end

    local m_path = work_dir .. "/manifest.ysa"
    local mf = io.open(m_path, "r")
    if not mf then return nil end
    local content = mf:read("*all"); mf:close()

    local decoder, err = load(content)
    if not decoder then return nil end

    local ok, manifest = pcall(decoder)
    if not ok or type(manifest) ~= "table" then return nil end

    -- [v1.0] Type dispatch
    if manifest.type == "PIANO_PRESETS_BUNDLE" then
        unpack_sess = {
            is_piano = true,
            work_dir = work_dir,
            manifest = manifest,
            presets = manifest.presets or {},
            total_presets = #(manifest.presets or {}),
            p_idx = 0,
            pending_files = {},
            status = "准备中...",
            done = false,
            success_count = 0,
            skipped_count = 0,
            error_count = 0,
            phase = "SCAN" -- SCAN, COPY, DONE
        }
    else
        unpack_sess = {
            is_piano = false,
            work_dir = work_dir,
            manifest = manifest,
            items = manifest.items or {},
            total_items = #(manifest.items or {}),
            item_idx = 0,
            pending_files = {},
            status = "准备中...",
            done = false,
            success_count = 0,
            skipped_count = 0,
            error_count = 0,
            new_categories = {},
            phase = "SCAN"
        }
    end
    G.import_apply_to_all = false
    G.last_import_resolution = nil
    G.import_resolution = nil
    
    return unpack_sess
end

function Exchange.StepUnpackSession()
    if not unpack_sess or unpack_sess.done then return true end

    if unpack_sess.phase == "SCAN" then
        if unpack_sess.is_piano then
            unpack_sess.p_idx = unpack_sess.p_idx + 1
            local p_name = unpack_sess.presets[unpack_sess.p_idx]
            if p_name then
                -- [Bug 1 Fix] Resolve Naming Conflict using ArbitrateConflict
                local action, new_name = ArbitrateConflict({name = p_name}, true)
                if action == "AWAITING_ARBITRATION" then
                    unpack_sess.p_idx = unpack_sess.p_idx - 1 -- Rollback index
                    return false
                end
                
                if action == "RENAME" then
                    local base = p_name; local count = 1
                    new_name = base .. " (" .. count .. ")"
                    while io.open(lib_path .. "/_Piano_Presets/" .. new_name .. "/preset.ysp", "r") do 
                        count = count + 1; new_name = base .. " (" .. count .. ")" 
                    end
                    action = "COPY_DIRECT"
                end
                
                if action == "SKIP" then
                    unpack_sess.skipped_count = (unpack_sess.skipped_count or 0) + 1
                    return false
                end
                
                unpack_sess.success_count = (unpack_sess.success_count or 0) + 1
                G.import_last_action = "导入预设: " .. new_name
                
                unpack_sess.status = "扫描预设: " .. new_name .. " (" .. unpack_sess.p_idx .. "/" .. unpack_sess.total_presets .. ")"
                local src_dir = unpack_sess.work_dir .. "/" .. p_name
                -- Add scene.ysp
                table.insert(unpack_sess.pending_files, { src = src_dir .. "/preset.ysp", dst_dir = lib_path .. "/_Piano_Presets/" .. new_name, p_name = new_name })
                -- Scan subdirs for audio/icons
                local function add_dir(rel)
                    local i = 0
                    while true do
                        local fn = r.EnumerateFiles(src_dir .. rel, i)
                        if not fn then break end
                        table.insert(unpack_sess.pending_files, { src = src_dir .. rel .. "/" .. fn, dst_dir = lib_path .. "/_Piano_Presets/" .. new_name .. rel, p_name = new_name })
                        i = i + 1
                    end
                end
                add_dir("/Audio"); add_dir("/Icons")
                return false
            else
                unpack_sess.phase = "COPY"
                unpack_sess.total_files = #unpack_sess.pending_files
                unpack_sess.f_idx = 0
                return false
            end
        else
            -- Main UI Scan (Already has all info in manifest)
            unpack_sess.phase = "COPY"
            return false
        end

    elseif unpack_sess.phase == "COPY" then
        if unpack_sess.is_piano then
            unpack_sess.f_idx = unpack_sess.f_idx + 1
            local f = unpack_sess.pending_files[unpack_sess.f_idx]
            if f then
                unpack_sess.status = "解包文件: " .. (f.src:match("[^/]+$") or "file")
                Utils.EnsureDir(f.dst_dir)
                local in_f = io.open(f.src, "rb")
                if in_f then
                    local data = in_f:read("*all"); in_f:close()
                    local out_f = io.open(f.dst_dir .. "/" .. f.src:match("[^/]+$"), "wb")
                    if out_f then out_f:write(data); out_f:close() end
                end
                return false
            else
                unpack_sess.done = true
                if Eng.ScanPianoPresets then Eng.ScanPianoPresets() end
                return true
            end
        else
            -- Main UI Copy (Same as before but we can keep it scene-based for now as rsdata is small)
            unpack_sess.item_idx = unpack_sess.item_idx + 1
            local item = unpack_sess.items[unpack_sess.item_idx]
            if item then
                unpack_sess.status = "同步资源: " .. item.name .. " (" .. unpack_sess.item_idx .. "/" .. unpack_sess.total_items .. ")"
                local action, new_name = ArbitrateConflict(item)
                
                if action == "AWAITING_ARBITRATION" then
                    unpack_sess.item_idx = unpack_sess.item_idx - 1 -- Rollback index to retry this item
                    return false -- Suspend session
                end

                if action == "RENAME" then
                    local base = item.name; local count = 1
                    new_name = base .. " (" .. count .. ")"
                    while GetLocalFile(new_name) do count = count + 1; new_name = base .. " (" .. count .. ")" end
                    action = "COPY_DIRECT" -- Treat as direct copy with new name
                end

                if action ~= "SKIP" then
                    unpack_sess.success_count = unpack_sess.success_count + 1
                    G.import_last_action = "导入: " .. new_name
                    local scenes_dir = lib_path .. "/_Scenes"
                    
                    -- Handle MERGE logic (If supported by rsdata, currently just overwrites or copies)
                    -- For now, OVERWRITE and MERGE are simplified to COPY_DIRECT
                    local out_rs = io.open(scenes_dir .. "/" .. new_name .. ".rsdata", "wb")
                    if out_rs then out_rs:write(item.rsdata_content); out_rs:close() end
                    for _, audio in ipairs(item.audio_files or {}) do
                        local src_path = unpack_sess.work_dir .. "/" .. audio.rel_path
                        local dest_path = lib_path .. "/" .. audio.rel_path
                        local rel_dir = audio.rel_path:match("(.+)/[^/]+$")
                        if rel_dir then Utils.EnsureDir(lib_path .. "/" .. rel_dir) end
                        local in_file = io.open(src_path, "rb")
                        if in_file then
                            local audio_data = in_file:read("*all"); in_file:close()
                            local out_file = io.open(dest_path, "wb")
                            if out_file then out_file:write(audio_data); out_file:close() end
                        end
                    end
                    local target_node = FindOrCreateNode(G.virtual_tree, item.parent_path, unpack_sess.new_categories)
                    if not target_node.scenes then target_node.scenes = {} end
                    
                    -- Don't add to tree if it's already there (for OVERWRITE/MERGE)
                    local exists_in_node = false
                    for _, s in ipairs(target_node.scenes) do if s == new_name then exists_in_node = true; break end end
                    if not exists_in_node then table.insert(target_node.scenes, new_name) end
                else
                    unpack_sess.skipped_count = unpack_sess.skipped_count + 1
                    G.import_last_action = "跳过: " .. item.name
                end
                return false
            else
                Eng.SaveDatabase()
                unpack_sess.done = true
                return true
            end
        end
    end
end

function Exchange.GetUnpackStats()
    if not unpack_sess then return 0, 0, 0 end
    return unpack_sess.success_count or 0, unpack_sess.skipped_count or 0, unpack_sess.error_count or 0
end

function Exchange.GetUnpackStatus()
    if not unpack_sess then return 1.0, "就绪" end
    if unpack_sess.done then return 1.0, "完成" end
    local pct = 0
    if unpack_sess.is_piano then
        if unpack_sess.phase == "SCAN" then pct = (unpack_sess.p_idx / unpack_sess.total_presets) * 0.1
        else pct = 0.1 + (unpack_sess.f_idx / unpack_sess.total_files) * 0.9 end
    else
        pct = (unpack_sess.item_idx / unpack_sess.total_items)
    end
    return pct, unpack_sess.status
end

-- Legacy Sync Unpack
function Exchange.Unpack(import_path)
    local sess = Exchange.CreateUnpackSession(import_path)
    if not sess then return end
    while not Exchange.StepUnpackSession() do end
    r.MB("成功导入完成！", "导入完成", 0)
end

-- ===================== Piano Tab Export (PackPianoTab) =====================

function Exchange.PackPianoTab(tab_idx, export_folder_path)
    if not G.piano_tabs or not G.piano_tabs[tab_idx] then
        r.MB("Target tab not found.", "Export Failed", 0)
        return
    end

    local tab = G.piano_tabs[tab_idx]
    local tab_name = tab.name or ("Piano_Tab_" .. tab_idx)

    local tmp_dir_name = "YS_PianoExport_" .. tostring(os.time())
    local tmp_dir = r.GetResourcePath() .. "/" .. tmp_dir_name
    Utils.EnsureDir(tmp_dir)
    Utils.EnsureDir(tmp_dir .. "/audio")

    local slot_data = {}
    local audio_manifest = {}

    for si = 1, 12 do
        local slot = tab.slots and tab.slots[si] or {}
        local sd = {
            mode  = slot.mode or "random",
            alias = slot.alias or "",
            key   = slot.key or "",
            poly  = slot.poly or false,
            items = {},
            img_path = nil,
        }

        for ii, item_raw in ipairs(slot.items or {}) do
            local item_path = type(item_raw) == "string" and item_raw or (type(item_raw) == "table" and (item_raw.path or item_raw.source or "") or "")
            if item_path ~= "" then
                local full_path = item_path
                if not full_path:match("^[A-Z]:") and not full_path:match("^/") then
                    full_path = lib_path .. "/" .. item_path
                end
                local in_f = io.open(full_path, "rb")
                if in_f then
                    local data = in_f:read("*all"); in_f:close()
                    local filename = item_path:match("([^/\\]+)$") or ("audio_" .. si .. "_" .. ii)
                    local rel = "audio/s" .. si .. "_" .. filename
                    local out_f = io.open(tmp_dir .. "/" .. rel, "wb")
                    if out_f then
                        out_f:write(data); out_f:close()
                        table.insert(sd.items, rel)
                        table.insert(audio_manifest, { slot = si, idx = ii, rel_path = rel, size = #data, original = item_path })
                    end
                else
                    table.insert(sd.items, item_path)
                end
            end
        end

        if slot.img_path and slot.img_path ~= "" then
            local icon_full = slot.img_path
            if not icon_full:match("^[A-Z]:") and not icon_full:match("^/") then
                icon_full = lib_path .. "/" .. slot.img_path
            end
            local ic_f = io.open(icon_full, "rb")
            if ic_f then
                local ic_data = ic_f:read("*all"); ic_f:close()
                local ic_name = slot.img_path:match("([^/\\]+)$") or ("img_" .. si .. ".png")
                local ic_rel = "audio/img_s" .. si .. "_" .. ic_name
                local ic_out = io.open(tmp_dir .. "/" .. ic_rel, "wb")
                if ic_out then ic_out:write(ic_data); ic_out:close(); sd.img_path = ic_rel end
            end
        end

        slot_data[si] = sd
    end

    local params = tab.params or G.piano_params or {}
    local params_copy = {
        vol_range   = params.vol_range   or 3.0,
        vol_on      = params.vol_on ~= false,
        pitch_shift = params.pitch_shift or 0.2,
        pitch_on    = params.pitch_on ~= false,
        step_ms     = params.step_ms or 200,
        step_on     = params.step_on ~= false,
        step_rand   = params.step_rand or 0.0,
        rand_on     = params.rand_on ~= false,
    }

    local manifest = {
        type        = "PIANO_TAB",
        version     = 1,
        tab_name    = tab_name,
        export_date = os.date("%Y-%m-%d %H:%M:%S"),
        slots       = slot_data,
        params      = params_copy,
        audio_files = audio_manifest,
    }

    local m_path = tmp_dir .. "/manifest.ysa"
    local mf = io.open(m_path, "wb")
    if mf then mf:write("return " .. Utils.Serialize(manifest)); mf:close() end

    local final_dir = export_folder_path:gsub("%.ysa$", ""):gsub("%.zip$", "")
    SafeRemoveDir(final_dir)
    local move_ok = os.rename(tmp_dir, final_dir)
    if not move_ok then
        EnsureDir(final_dir); EnsureDir(final_dir .. "/audio")
        local in_m = io.open(m_path, "rb")
        if in_m then
            local md = in_m:read("*all"); in_m:close()
            local out_m = io.open(final_dir .. "/manifest.ysa", "wb")
            if out_m then out_m:write(md); out_m:close() end
        end
        for _, af in ipairs(audio_manifest) do
            local s = tmp_dir .. "/" .. af.rel_path
            local d = final_dir .. "/" .. af.rel_path
            local in_f = io.open(s, "rb")
            if in_f then
                local ad = in_f:read("*all"); in_f:close()
                local out_f = io.open(d, "wb")
                if out_f then out_f:write(ad); out_f:close() end
            end
        end
        Utils.SafeRemoveDir(tmp_dir)
    end

    r.MB("閽㈢惔閰嶇疆椤?[" .. tab_name .. "] 宸茬粡鎴愬姛鎵撳寘瀵煎嚭锛乗n鎵€鍦ㄧ洰褰曪細" .. final_dir:match("[^/\\]+$"), "鍒嗕韩鎴愬姛", 0)
end

-- ===================== Asynchronous Export Engine =====================
local pack_session = nil

function Exchange.CreatePackSession(preset_names, export_file_path)
    if not preset_names or #preset_names == 0 then return nil end
    
    local tmp_dir_name = "YS_PianoPresetsExport_" .. tostring(os.time())
    local tmp_dir = r.GetResourcePath() .. "/" .. tmp_dir_name
    Utils.EnsureDir(tmp_dir)
    Utils.EnsureDir(tmp_dir .. "/_assets")
    
    pack_session = {
        presets = preset_names,
        total_presets = #preset_names,
        p_idx = 0,
        pending_files = {}, -- { {src, dst, rel} }
        manifest = {
            type = "PIANO_PRESETS_BUNDLE",
            version = 1,
            export_date = os.date("%Y-%m-%d %H:%M:%S"),
            presets = preset_names,
            assets_manifest = {}
        },
        tmp_dir = tmp_dir,
        final_path = export_file_path,
        status = "鍑嗗涓?..",
        done = false,
        phase = "SCAN" -- SCAN, COPY, FINAL
    }
    return pack_session
end

function Exchange.StepPackSession()
    if not pack_session or pack_session.done then return true end

    if pack_session.phase == "SCAN" then
        pack_session.p_idx = pack_session.p_idx + 1
        local p_name = pack_session.presets[pack_session.p_idx]
        if p_name then
            pack_session.status = "扫描预设: " .. p_name .. " (" .. pack_session.p_idx .. "/" .. pack_session.total_presets .. ")"
            local src_dir = lib_path .. "/_Piano_Presets/" .. p_name
            local dst_dir = pack_session.tmp_dir .. "/" .. p_name
            Utils.EnsureDir(dst_dir)
            
            -- Add preset.ysp
            table.insert(pack_session.pending_files, { src = src_dir .. "/preset.ysp", dst = dst_dir .. "/preset.ysp", rel = p_name .. "/preset.ysp" })
            
            -- Scan subfolders
            local function scan_dir(sub)
                local full_src = src_dir .. sub
                local full_dst = dst_dir .. sub
                local i = 0
                while true do
                    local fn = r.EnumerateFiles(full_src, i)
                    if not fn then break end
                    Utils.EnsureDir(full_dst)
                    table.insert(pack_session.pending_files, { 
                        src = full_src .. "/" .. fn, 
                        dst = full_dst .. "/" .. fn,
                        rel = p_name .. sub .. "/" .. fn
                    })
                    i = i + 1
                end
            end
            scan_dir("/Audio"); scan_dir("/Icons")
            
            -- Scan linked assets (V17.0+)
            local ysp_f = io.open(src_dir .. "/preset.ysp", "r")
            if ysp_f then
                local p_data = ysp_f:read("*all"); ysp_f:close()
                for asset_path in p_data:gmatch("Imported/([^\"\\/]+/[^\"\\/]+)") do
                    local asset_dir = asset_path:match("^([^/]+)")
                    if asset_dir then
                        local as_src = lib_path .. "/_Piano_Assets/Imported/" .. asset_dir
                        local as_dst = pack_session.tmp_dir .. "/_assets/" .. asset_dir
                        local j = 0
                        while true do
                            local afn = r.EnumerateFiles(as_src, j)
                            if not afn then break end
                            Utils.EnsureDir(as_dst)
                            table.insert(pack_session.pending_files, {
                                src = as_src .. "/" .. afn,
                                dst = as_dst .. "/" .. afn,
                                rel = "_assets/" .. asset_dir .. "/" .. afn
                            })
                            j = j + 1
                        end
                    end
                end
            end
            return false
        else
            pack_session.phase = "COPY"
            pack_session.total_files = #pack_session.pending_files
            pack_session.f_idx = 0
            if pack_session.total_files == 0 then pack_session.phase = "FINAL" end
        end
    elseif pack_session.phase == "COPY" then
        return Internal_StepFiles(pack_session, "打包文件中")

    elseif pack_session.phase == "FINAL" then
        -- Finalize
        if not pack_session.meta_done then
            pack_session.status = "正在渲染资源清单..."
            local mf = io.open(pack_session.tmp_dir .. "/manifest.ysa", "wb")
            if mf then mf:write("return " .. Utils.Serialize(pack_session.manifest)); mf:close() end
            pack_session.meta_done = true
            return false
        end
        
        pack_session.status = "正在将资源包移至目标路径..."
        local final_path = pack_session.final_path
        if not final_path:match("%.ysa$") then final_path = final_path .. ".ysa" end
        local final_dir = final_path:gsub("%.ysa$", "")
        
        Utils.SafeRemoveDir(final_dir)
        local move_ok = os.rename(pack_session.tmp_dir, final_dir)
        if not move_ok then
            -- Fallback: Copy-then-Delete if cross-drive
            Utils.EnsureDir(final_dir)
            local cmd = is_mac and ('cp -R "'..pack_session.tmp_dir..'/" "'..final_dir..'"') 
                               or ('xcopy "'..pack_session.tmp_dir:gsub("/", "\\")..'\\" "'..final_dir:gsub("/", "\\")..'\\" /E /I /Y')
            os.execute(cmd)
            Utils.SafeRemoveDir(pack_session.tmp_dir)
        end
        pack_session.done = true
        return true
    end
end

function Exchange.GetPackStatus()
    if not pack_session then return 1.0, "就绪" end
    if pack_session.done then return 1.0, "完成" end
    local real = 0
    if pack_session.phase == "SCAN" then
        real = (pack_session.p_idx / pack_session.total_presets) * 0.1
    elseif pack_session.phase == "COPY" then
        real = 0.1 + (pack_session.f_idx / pack_session.total_files) * 0.89
    else
        real = 0.99
    end
    return MappingProgress(real), pack_session.status
end


-- ===================== Piano Presets Import =====================
function Exchange.UnpackPianoPresetsBundle(work_dir, manifest)
    if not manifest or manifest.type ~= "PIANO_PRESETS_BUNDLE" then return end
    
    -- unpack imported assets
    local i = 0
    while true do
        local dir_name = reaper.EnumerateSubdirectories(work_dir .. "/_assets", i)
        if not dir_name then break end
        Utils.CopyDirFiles(work_dir .. "/_assets/" .. dir_name, lib_path .. "/_Piano_Assets/Imported/" .. dir_name)
        i = i + 1
    end
    
    local presets_imported = 0
    for _, p_name in ipairs(manifest.presets or {}) do
        local src_dir = work_dir .. "/" .. p_name
        local dst_dir = lib_path .. "/_Piano_Presets/" .. p_name
        
        -- Check if exists:
        local ysp_check = io.open(dst_dir .. "/preset.ysp", "r")
        local final_name = p_name
        if ysp_check then
            ysp_check:close()
            local res = r.MB("系统预设 [" .. p_name .. "] 已经存在。\n\n【是】 覆盖原预设\n【否】 建立新副本\n【取消】 跳过此项", "同名冲突检测", 3)
            if res == 2 then goto continue end
            if res == 7 then
                local c = 1
                local new_name = p_name .. " (" .. c .. ")"
                while io.open(lib_path .. "/_Piano_Presets/" .. new_name .. "/preset.ysp", "r") do
                    c = c + 1
                    new_name = p_name .. " (" .. c .. ")"
                end
                final_name = new_name
                dst_dir = lib_path .. "/_Piano_Presets/" .. final_name
            end
        end
        
        Utils.EnsureDir(dst_dir)
        Utils.CopyDirFiles(src_dir, dst_dir)
        Utils.CopyDirFiles(src_dir .. "/Audio", dst_dir .. "/Audio")
        Utils.CopyDirFiles(src_dir .. "/Icons", dst_dir .. "/Icons")
        
        presets_imported = presets_imported + 1
        ::continue::
    end
    
    if presets_imported > 0 then
        if Eng.ScanPianoPresets then Eng.ScanPianoPresets() end
        r.MB("成功导入 " .. presets_imported .. " 个预设方案！\n您可以在下拉菜单中直接选择加载。", "批量导入完成", 0)
    end
end

return Exchange

  end)(); package.loaded['Archive_Exchange'] = _m; return _m
end)()
    GUI          =  (function()
  local _m = (function()
--[[
 * ReaScript Name: YS_GUI
 * Description: YS Platform 工业级全局 UI 框架 (Global UI Framework)
 * Author: YS
 * Version: 1.2
 * About: 此模块负责全平台视觉一致性 (Header, Tactile Buttons, Window Logic)。
--]]

local GUI = (function()
    local r = reaper
    local Theme = require("YS_Theme")
    local M = {
        VERSION = "1.2",
        DEFAULT_HOVER_COLOR = 0x57A5FFFF,
        rounding = (Theme and Theme.rounding) or 12.0 -- 全局圆角同步
    }
    
    -- [V115.25] 工业级资源池 (Resource Pooling)
    -- 缓存 ListClipper 等重量级对象，杜绝 excessive creation of short-lived resources 警告
    local _clippers = {}
    function M.GetClipper(ctx, key)
        if not _clippers[key] or not r.ImGui_ValidatePtr(_clippers[key], "ImGui_ListClipper*") then
            _clippers[key] = r.ImGui_CreateListClipper(ctx)
        end
        return _clippers[key]
    end

    -- [V115.26] API 兼容性补丁 (Compatibility Shim)
    -- 处理 ReaImGui 不同版本间 Clipper 命名差异 (GetDisplayRange vs GetDisplayStart/End)
    function M.GetClipperRange(clipper)
        if r.ImGui_ListClipper_GetDisplayRange then
            return r.ImGui_ListClipper_GetDisplayRange(clipper)
        elseif r.ImGui_ListClipper_GetDisplayStart and r.ImGui_ListClipper_GetDisplayEnd then
            return r.ImGui_ListClipper_GetDisplayStart(clipper), r.ImGui_ListClipper_GetDisplayEnd(clipper)
        end
        return 0, 0 -- 挂机兜底
    end
    local Icons = require("YS_Icons")
    local FontManager = require("YS_FontManager")

    -- [V115.22] 核心重构：自绘窗口代理底座 (Unified Proxy Background)
    -- 处理阴影、分层底色（标题栏/主体）以及边框
    function M.DrawWindowProxyBg(ctx, US, C, header_h_pixel, is_collapsed)
        local dl    = reaper.ImGui_GetWindowDrawList(ctx)
        local win_x, win_y = reaper.ImGui_GetWindowPos(ctx)
        local win_w, win_h = reaper.ImGui_GetWindowSize(ctx)
        local h_h = (header_h_pixel or 32) * US
        local rd  = (Theme.rounding or 12) * US
        
        -- 1. 绘制底层软阴影 (仅在展开时绘制，防止折叠态出现“黑线”感)
        if not is_collapsed then
            reaper.ImGui_DrawList_AddRectFilled(dl, win_x, win_y+2*US, win_x+win_w, win_y+win_h+2*US, 0x00000055, rd)
        end
        
        -- 2. 绘制标题栏背景 (Header)
        -- 折叠时使用全圆角，展开时仅上圆角
        local r_top = is_collapsed and reaper.ImGui_DrawFlags_RoundCornersAll() or (reaper.ImGui_DrawFlags_RoundCornersTopLeft() | reaper.ImGui_DrawFlags_RoundCornersTopRight())
        reaper.ImGui_DrawList_AddRectFilled(dl, win_x, win_y, win_x + win_w, win_y + h_h, C.title_bg or 0x1A1C1EFF, rd, r_top)
        
        if not is_collapsed then
            -- 3. 绘制主体背景 (Body)
            local r_bot = reaper.ImGui_DrawFlags_RoundCornersBottom()
            reaper.ImGui_DrawList_AddRectFilled(dl, win_x, win_y + h_h, win_x + win_w, win_y + win_h, C.base_bg or 0x2D2D2DFF, rd, r_bot)
            
            -- 4. 绘制外框描边 (Stroke)
            reaper.ImGui_DrawList_AddRect(dl, win_x, win_y, win_x+win_w, win_y+win_h, C.frame_black or 0, rd, nil, 1.0)
        end
    end

    --- 工业级帮助标记 (Hover Tooltip)
    function M.SafeTooltip(ctx, text, state)
    if not text or text == "" or not state then return end
    
    -- [V1.18] Unified Hide Logic: Piano mode uses engine-specific flag
    local hide = false
    if state.is_piano_mode or (type(state.piano_engine) == "table" and state.piano_engine.active) then
        hide = state.piano_engine and state.piano_engine.hide_tooltips
    else
        hide = state.hide_tooltip_main
    end
    if hide then return end
    
    reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_Text(), 0xFFFFFFFF)
    reaper.ImGui_SetTooltip(ctx, text)
    reaper.ImGui_PopStyleColor(ctx)
end

    function M.HelpMarker(ctx, desc, state)
        reaper.ImGui_TextDisabled(ctx, "(?)")
        if reaper.ImGui_IsItemHovered(ctx) then
            M.SafeTooltip(ctx, desc, state)
        end
    end

    --- 分组标题块 (Section Header)
    function M.DrawSectionHeader(ctx, label, w)
        if not ctx then return end
        local ww = w or r.ImGui_GetContentRegionAvail(ctx)
        local hh = r.ImGui_GetFontSize(ctx) + 10
        local cur_x, cur_y = r.ImGui_GetCursorPos(ctx)
        
        local draw_list = r.ImGui_GetWindowDrawList(ctx)
        local px, py = r.ImGui_GetCursorScreenPos(ctx)
        local Theme = require("YS_Theme")
        local c1 = (Theme.COLORS.accent & 0xFFFFFF00) | 0x22
        local c2 = (Theme.COLORS.accent_2 & 0xFFFFFF00) | 0x11
        
        r.ImGui_DrawList_AddRectFilledMultiColor(draw_list, px, py, px + ww, py + hh, c1, c2, c2, c1)
        
        local offset_y = (hh - r.ImGui_GetFontSize(ctx)) * 0.5 + r.ImGui_GetFontSize(ctx) * FontManager.GetVerticalOffset()
        r.ImGui_SetCursorPos(ctx, cur_x + 8, cur_y + offset_y)
        r.ImGui_Text(ctx, label)
        r.ImGui_SetCursorPos(ctx, cur_x, cur_y + hh + 4)
    end




    --- 工业级智能标题栏
    function M.DrawHeaderV2(ctx, title, config)
        config = config or {}
        local r = reaper
        local scale = config.scale or 1
        local header_h = config.header_h or 32 * scale
        
        local win_w = config.width or r.ImGui_GetWindowWidth(ctx)
        
        local cur_x, cur_y = r.ImGui_GetWindowPos(ctx)
        local dl       = r.ImGui_GetWindowDrawList(ctx)
        local padding_x = 10 * scale
        local action   = nil
        local state    = config.G_State or {}
        local rounding = Theme.rounding * scale
        local is_collapsed = config.G_State and config.G_State.is_collapsed and not config.is_modal
        -- [V4.2.0 Boundary Rectitude]
        --  移除可能重复的 AddRectFilled，背景已由 DrawWindowProxyBg 全程托管
        --  仅保留必要的文字与图标绘制逻辑


        -- 2. Logo & 文字绑定 (组件化自动布局)
        local padding_x = rounding -- 基础边距等于圆角半径
        
        --  弹窗模式强制不显示 Logo，主界面显示 Logo
        if not config.is_modal then
            local logo_key = config.logo_key or "Logo"
            local logo_tex = config.logo_tex or Icons.GetTexture(ctx, logo_key)
            local logo_sz  = 24 * scale
            
            if logo_tex then
                local lx = cur_x + padding_x
                local ly = cur_y + (header_h - logo_sz) * 0.5
                r.ImGui_DrawList_AddImage(dl, logo_tex, lx, ly, lx + logo_sz, ly + logo_sz, 0,0,1,1, Theme.COLORS.text)
                padding_x = padding_x + logo_sz + 10 * scale
            end
        end
        
        r.ImGui_SetCursorPos(ctx, padding_x, (header_h - r.ImGui_GetFontSize(ctx)) * 0.5)
        r.ImGui_Text(ctx, title)

        -- 3. Omni-Intelligence 手柄逻辑 (全域逻辑驱动拖拽/折叠)
        local mx, my = r.ImGui_GetMousePos(ctx)
        local rel_x, rel_y = mx - cur_x, my - cur_y
        local in_title = rel_x >= 0 and rel_x < win_w and rel_y >= 0 and rel_y < header_h

        if r.ImGui_IsMouseClicked(ctx, 0) and in_title then
            state._hd_down = true
            state._hd_dragged = false
            state._hd_start_mx, state._hd_start_my = mx, my
            state._hd_last_mx, state._hd_last_my = mx, my
        end

        if state._hd_down then
            if r.ImGui_IsMouseDown(ctx, 0) then
                local dx, dy = mx - state._hd_start_mx, my - state._hd_start_my
                if math.abs(dx) > 2 or math.abs(dy) > 2 then
                    local wx, wy = r.ImGui_GetWindowPos(ctx)
                    r.ImGui_SetWindowPos(ctx, wx + (mx - state._hd_last_mx), wy + (my - state._hd_last_my))
                    state._hd_dragged = true
                end
                state._hd_last_mx, state._hd_last_my = mx, my
            else
                -- 自动处理折叠逻辑 (弹窗模式下屏蔽)
                if not state._hd_dragged and rel_x < 90 * scale and not config.is_modal then 
                    action = "collapse" 
                    if config.G_State then
                        state.is_collapsed = not state.is_collapsed
                        if state.PRODUCT_ID then
                            reaper.SetExtState(state.PRODUCT_ID, "Collapsed", state.is_collapsed and "1" or "0", true)
                        end
                    end
                end
                state._hd_down = false
            end
        elseif not r.ImGui_IsMouseDown(ctx, 0) then
            state._hd_dragged = false
        end

        if in_title and rel_x < 90 * scale and r.ImGui_IsMouseDoubleClicked(ctx, 0) and not config.is_modal then
            action = "collapse"
            if config.G_State then state.is_collapsed = not state.is_collapsed end
        end

        -- 4. 右侧图标组 (全自动绑定关闭按钮)
        local function DrawBtn(name, tooltip, act_key)
            local b_sz = header_h * 0.55
            local margin = 6 * scale -- [Case 42] 贴近边缘
            local spacing = 4 * scale
            state._hd_btn_count = (state._hd_btn_count or 0) + 1
            local bx = win_w - margin - b_sz - (state._hd_btn_count - 1) * (b_sz + spacing)
            
            -- [V1.3 Fix] 强制在本地坐标内设置 Cursor，确保 InvisibleButton 不会超出逻辑宽度
            local target_bx = math.min(bx, win_w - b_sz - 4 * scale)
            r.ImGui_SetCursorPos(ctx, target_bx, (header_h - b_sz) * 0.5)
            
            r.ImGui_PushID(ctx, (title or "Header").."_hd_area")
            local clicked, hov = Icons.DrawIconButton(ctx, "hd_"..name, name, cur_x + target_bx, cur_y + (header_h-b_sz)*0.5, b_sz, config[act_key], 0xCCCCCCFF)
            r.ImGui_PopID(ctx)
            
            if hov then 
                M.SafeTooltip(ctx, tooltip, state)
            end
            return clicked and not state._hd_dragged
        end

        state._hd_btn_count = 0
        -- 核心执行组：关闭 & 保存 (弹窗模式下默认隐藏非必要图标)
        local show_close = config.show_close
        if show_close == nil then show_close = true end -- 默认显示关闭
        
        local show_save = config.show_save
        if show_save == nil then show_save = not config.is_modal end -- 弹窗默认隐藏保存
        
        local show_settings = config.show_settings
        if show_settings == nil then show_settings = not config.is_modal end -- 弹窗默认隐藏设置

        if show_close then 
            local tt = config.is_modal and "" or "关闭"
            if DrawBtn("Close", tt) then 
                action = "close" 
                if config.G_State and not config.is_modal then state.force_exit = true end
            end 
        end
        
        if show_save then 
            if DrawBtn("Save", "保存搭建", "is_saving") then 
                action = "save" 
            end 
        end

        if show_settings then
            if DrawBtn("Gear", "设置", "is_setting") then 
                action = "settings" 
            end
        end

        return action
    end

    --- 工业级稳定拖拽引擎
    function M.HandleStableDrag(ctx, state, key, x1, y1, x2, y2)
        local is_hovered = r.ImGui_IsMouseHoveringRect(ctx, x1, y1, x2, y2)
        local is_clicked = r.ImGui_IsMouseClicked(ctx, 0)
        local is_down = r.ImGui_IsMouseDown(ctx, 0)
        
        local drag_key = "is_dragging_" .. key
        local start_x_key = "drag_start_wx_" .. key
        local start_y_key = "drag_start_wy_" .. key
        
        if is_clicked and is_hovered then
            if not r.ImGui_IsAnyItemActive(ctx) then
                state[drag_key] = true
                state[start_x_key], state[start_y_key] = r.ImGui_GetWindowPos(ctx)
            end
        end
        
        if state[drag_key] then
            if is_down then
                local dx, dy = r.ImGui_GetMouseDragDelta(ctx)
                local target_x = math.floor(state[start_x_key] + dx + 0.5)
                local target_y = math.floor(state[start_y_key] + dy + 0.5)
                return true, target_x, target_y
            else
                state[drag_key] = false
                state[start_x_key], state[start_y_key] = nil, nil
            end
        end
        return false
    end

    --- 工业级渐变滑块 (1:1 还原图二高级感)
    --- @param ctx any ImGui Context
    --- @param id string Unique ID
    --- @param val number Current Value
    --- @param min number Min Value
    --- @param max number Max Value
    --- @param w number Width
    --- @param label string? Optional side label
    --- @return boolean changed, number new_val
    function M.DrawGradientSlider(ctx, id, val, min, max, w, label)
        local Theme = require("YS_Theme")
        local cur_x, cur_y = r.ImGui_GetCursorPos(ctx)
        local screen_x, screen_y = r.ImGui_GetCursorScreenPos(ctx)
        local draw_list = r.ImGui_GetWindowDrawList(ctx)
        
        local ww = (w < 0) and r.ImGui_GetContentRegionAvail(ctx) or w
        local hh = 20
        
        r.ImGui_InvisibleButton(ctx, id, ww, hh)
        local is_active = r.ImGui_IsItemActive(ctx)
        
        local new_val = val
        if is_active then
            local mouse_x = r.ImGui_GetMousePos(ctx)
            local pct = (mouse_x - screen_x) / ww
            pct = math.max(0, math.min(1, pct))
            new_val = min + (max - min) * pct
        end
        
        r.ImGui_DrawList_AddRectFilled(draw_list, screen_x, screen_y + hh/2 - 1, screen_x + ww, screen_y + hh/2 + 1, 0xFFFFFF1A, 1)
        
        local fill_w = ((new_val - min) / (max - min)) * ww
        local accent = Theme.COLORS.accent or 0x0066FFFF
        if fill_w > 0 then
            r.ImGui_DrawList_AddRectFilled(draw_list, screen_x, screen_y + hh/2 - 1, screen_x + fill_w, screen_y + hh/2 + 1, accent, 1)
        end
        
        local grab_x = screen_x + fill_w
        r.ImGui_DrawList_AddCircleFilled(draw_list, grab_x, screen_y + hh/2, 6, is_active and 0xFFFFFFFF or accent, 16)
        r.ImGui_DrawList_AddCircle(draw_list, grab_x, screen_y + hh/2, 6.5, 0x00000033, 16, 1.0)

        r.ImGui_SetCursorPos(ctx, cur_x, cur_y + hh)
        return new_val ~= val, new_val
    end

    --- 工业级标准渲染：按钮 (支持智能缩放与反馈)
    function M.DrawButtonStandard(ctx, id, label, w, h, rounding)
        local draw_list = r.ImGui_GetWindowDrawList(ctx)
        local Theme = require("YS_Theme")
        local xx, yy = r.ImGui_GetCursorScreenPos(ctx)
        local font_size = r.ImGui_GetFontSize(ctx)
        local ww = (w and w > 0) and w or (r.ImGui_GetContentRegionAvail(ctx))
        local hh = h or (font_size * 2.2)
        local rr = rounding or 6

        r.ImGui_InvisibleButton(ctx, id, ww, hh)
        local hovered = r.ImGui_IsItemHovered(ctx)
        local active  = r.ImGui_IsItemActive(ctx)
        local clicked = r.ImGui_IsItemClicked(ctx, 0)

        local bg_col = active and Theme.COLORS.accent_active or (hovered and Theme.COLORS.accent_hover or Theme.COLORS.accent)
        r.ImGui_DrawList_AddRectFilled(draw_list, xx, yy, xx+ww, yy+hh, bg_col, rr)
        r.ImGui_DrawList_AddRect(draw_list, xx, yy, xx+ww, yy+hh, 0xFFFFFF1A, rr, nil, 1.0)

        local ts_w, ts_h = r.ImGui_CalcTextSize(ctx, label)
        local US = G.ui_scale or 1
        r.ImGui_DrawList_AddText(draw_list, xx + (ww - ts_w)/2, yy + (hh - ts_h)/2, Theme.COLORS.text_on_accent or 0xFFFFFFFF, label)
        return clicked
    end

    --- 工业级标准渲染：窗口卡片边框
    function M.DrawCard(ctx, label, w, h, rounding)
        local draw_list = r.ImGui_GetWindowDrawList(ctx)
        local Theme = require("YS_Theme")
        local cur_x, cur_y = r.ImGui_GetCursorScreenPos(ctx)
        local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
        local ww = ((w and w > 0) and w or avail_w) - 1
        local hh = ((h and h > 0) and h or avail_h) - 1
        local rr = rounding or 6

        r.ImGui_DrawList_AddRectFilled(draw_list, cur_x, cur_y, cur_x + ww, cur_y + hh, Theme.COLORS.bg_child or 0x1A1A1AFF, rr)
        r.ImGui_DrawList_AddRect(draw_list, cur_x, cur_y, cur_x + ww, cur_y + hh, 0xFFFFFF1F, rr, 0, 1.0)
        r.ImGui_DrawList_AddLine(draw_list, cur_x + rr, cur_y + 1, cur_x + ww - rr, cur_y + 1, 0xFFFFFF2A)
    end

    --- 智能按钮主入口
    function M.DrawButton(ctx, id, label, w, h, rounding)
        local Theme = require("YS_Theme")
        if Theme.COLORS.accent_2 and Theme.COLORS.accent_2 ~= Theme.COLORS.accent then
            return M.DrawGradientButton(ctx, id, label, w or -1, h or 36, Theme.COLORS.accent, Theme.COLORS.accent_2, rounding or 6.0)
        else
            return M.DrawButtonStandard(ctx, id, label, w, h, rounding)
        end
    end

    ---  工业级 3D 触感按钮 (Standardized Tactile Button)
    --- @param ctx any ImGui Context
    --- @param id string Unique ID
    --- @param label string Button text
    --- @param w number Width
    --- @param h number Height
    --- @param scale number UI Scale
    --- @param active boolean Whether it's the primary/active action
    --- @return boolean clicked
    function M.DrawTactileButton(ctx, id, label, w, h, scale, active)
        local Theme = require("YS_Theme")
        local C     = Theme.COLORS
        local cur_x, cur_y   = r.ImGui_GetCursorPos(ctx)
        local screen_x, screen_y = r.ImGui_GetCursorScreenPos(ctx)
        local dl = r.ImGui_GetWindowDrawList(ctx)
        local US = scale or 1.0
        local ww = w or 110 * US
        local hh = h or 32 * US

        r.ImGui_InvisibleButton(ctx, id, ww, hh)
        local hovered = r.ImGui_IsItemHovered(ctx)
        local down    = r.ImGui_IsItemActive(ctx)
        local clicked = r.ImGui_IsItemClicked(ctx, 0)
        local rr = 6 * US

        -- 1. 物理阴影 (Global Tactile DNA)
        local shadow_alpha = down and 0x22 or (hovered and 0x55 or 0x33)
        local shadow_off   = down and 0.5*US or 1.5*US
        r.ImGui_DrawList_AddRectFilled(dl, screen_x, screen_y + shadow_off, screen_x + ww, screen_y + hh + shadow_off, 0x00000000 | shadow_alpha, rr)

        -- 2. 基底颜色
        local base_col = active and (C.accent or 0x00B4D8FF) or 0x292C30FF -- #292C30 (Industrial Matte)
        if hovered then
            base_col = active and (C.accent_hover or 0x33CCFFFF) or 0x3A3E44FF -- Slightly lighter on hover
        end
        if down then
            base_col = active and (C.accent_active or 0x0099B3FF) or 0x1A1C1EFF -- Down to Title color
        end
        r.ImGui_DrawList_AddRectFilled(dl, screen_x, screen_y, screen_x + ww, screen_y + hh, base_col, rr)

        -- 3. 顶部微光 (Pixel-perfect Rounded Gradient Sheen)
        if not down then
            local peak_alpha = active and 24 or (hovered and 16 or 8)
            local steps = math.floor(hh * 0.35)
            local R = rr - 1
            for i = 0, steps - 1 do
                local y_off = i
                local alpha = math.floor(peak_alpha * (1 - i / steps))
                local pad_x = 0
                if y_off < R then
                    local dy = R - y_off
                    pad_x = R - math.sqrt(math.max(0, R * R - dy * dy))
                end
                r.ImGui_DrawList_AddRectFilled(dl, screen_x + 1 + pad_x, screen_y + 1 + y_off, screen_x + ww - 1 - pad_x, screen_y + 1 + y_off + 1.0, 0xFFFFFF00 | alpha)
            end
        end

        -- 4. 边缘高光与深度 (Refractive DNA - Drawn AFTER gradient to prevent anti-aliasing bleed)
        local line_col = active and 0xFFFFFF44 or 0xFFFFFF22
        r.ImGui_DrawList_AddRect(dl, screen_x, screen_y, screen_x + ww, screen_y + hh, line_col, rr, nil, 1.0 * US)
        
        if not down then
            r.ImGui_DrawList_AddLine(dl, screen_x + rr, screen_y + 1, screen_x + ww - rr, screen_y + 1, 0xFFFFFF33, 1.0)
        end

        -- 4. 文字
        local ts_w, ts_h = r.ImGui_CalcTextSize(ctx, label)
        local text_off = down and 1*US or 0
        r.ImGui_DrawList_AddText(dl, screen_x + (ww - ts_w)/2, screen_y + (hh - ts_h)/2 + text_off, 0xFFFFFFFF, label)

        r.ImGui_SetCursorPos(ctx, cur_x + ww, cur_y)
        return clicked
    end

    --- 智能滑块包装
    function M.DrawSlider(ctx, id, val, min, max, w, label)
        local Theme = require("YS_Theme")
        local ww = w or -1
        if Theme.COLORS.accent_2 and Theme.COLORS.accent_2 ~= Theme.COLORS.accent then
            return M.DrawGradientSlider(ctx, id, val, min, max, ww, label)
        else
            r.ImGui_SetNextItemWidth(ctx, ww)
            local fmt = label and "" or "%.2f"
            local rv, nv = r.ImGui_SliderDouble(ctx, id, val, min, max, fmt)
            if label then
                 r.ImGui_SameLine(ctx)
                 r.ImGui_Text(ctx, label)
            end
            return rv, nv
        end
    end

    --- 工业级渐变按钮
    function M.DrawGradientButton(ctx, id, label, w, h, col1, col2, rounding)
        local cur_x, cur_y = r.ImGui_GetCursorPos(ctx)
        local screen_x, screen_y = r.ImGui_GetCursorScreenPos(ctx)
        local draw_list = r.ImGui_GetWindowDrawList(ctx)
        local rnd = rounding or 0
        local ww = (w < 0) and r.ImGui_GetContentRegionAvail(ctx) or w
        local hh = h
        
        r.ImGui_InvisibleButton(ctx, id, ww, hh)
        local is_hover = r.ImGui_IsItemHovered(ctx)
        local is_active = r.ImGui_IsItemActive(ctx)
        
        local c1, c2 = col1, col2
        if is_hover then
            c1 = (col1 & 0xFFFFFF00) | math.min(0xFF, (col1 & 0xFF) + 0x22)
            c2 = (col2 & 0xFFFFFF00) | math.min(0xFF, (col2 & 0xFF) + 0x22)
        end
        if rnd > 0 then
            r.ImGui_DrawList_AddRectFilled(draw_list, screen_x, screen_y, screen_x + ww, screen_y + hh, c1, rnd)
            r.ImGui_DrawList_AddLine(draw_list, screen_x + rnd, screen_y + 1, screen_x + ww - rnd, screen_y + 1, 0xFFFFFF33)
        else
            r.ImGui_DrawList_AddRectFilledMultiColor(draw_list, screen_x, screen_y, screen_x + ww, screen_y + hh, c1, c2, c2, c1)
        end
        
        r.ImGui_DrawList_AddRect(draw_list, screen_x, screen_y, screen_x + ww, screen_y + hh, 0xFFFFFF22, rnd, nil, 1.0)
        
        local font_size = r.ImGui_GetFontSize(ctx)
        local text_w = r.ImGui_CalcTextSize(ctx, label)
        local offset = is_active and 2 or 0
        r.ImGui_SetCursorPos(ctx, cur_x + (ww - text_w) / 2, cur_y + (hh - font_size) / 2 + offset/2)
        r.ImGui_DrawList_AddText(draw_list, screen_x + (ww - text_w) / 2, screen_y + (hh - font_size) / 2 + offset/2, 0xFFFFFFFF, label)
        
        return r.ImGui_IsItemClicked(ctx, 0)
    end


    ---  标签页（活跃态内凹）
    function M.DrawTactileTab(ctx, id, label, active, w, h, scale, is_last)
        local Theme = require("YS_Theme")
        local C     = Theme.COLORS
        local cur_x, cur_y   = r.ImGui_GetCursorPos(ctx)
        local screen_x, screen_y = r.ImGui_GetCursorScreenPos(ctx)
        local dl = r.ImGui_GetWindowDrawList(ctx)
        local US = scale or 1.0
        local ww = w or 80 * US
        local hh = h or 26 * US

        r.ImGui_InvisibleButton(ctx, id, ww, hh)
        local hovered = r.ImGui_IsItemHovered(ctx)
        local clicked = r.ImGui_IsItemClicked(ctx, 0)
        local rr = 6 * US -- Consistent rounding

        -- 1. 全域物理阴影扩展
        local shadow_alpha = active and 0x55 or (hovered and 0x33 or 0x22)
        r.ImGui_DrawList_AddRect(dl, screen_x, screen_y + 1.2*US, screen_x + ww, screen_y + hh + 1.8*US, 0x00000000 | shadow_alpha, rr, nil, 1.2*US)
        r.ImGui_DrawList_AddRectFilled(dl, screen_x, screen_y + 0.8*US, screen_x + ww, screen_y + hh + 1.2*US, 0x00000000 | (shadow_alpha - 0x11), rr)

        -- 2. 状态基底渲染
        -- [Unified Vibrant Blue] 与全域选中色保持一致
        local active_bg = (C.accent & 0xFFFFFF00) | 0x7A -- 增强饱和度与侧边栏对齐
        local hover_bg  = 0xFFFFFF44
        local norm_bg   = 0xFFFFFF15 -- [V110.1] 降低非选中态亮度，防止与蓝色底座视觉竞争
        local base_col  = active and active_bg or (hovered and hover_bg or norm_bg)
        r.ImGui_DrawList_AddRectFilled(dl, screen_x, screen_y, screen_x + ww, screen_y + hh, base_col, rr)

        -- 3. 完美边缘折射渐变 (Pixel-perfect Rounded Gradient)
        local peak_alpha = active and 36 or (hovered and 18 or 10)
        local steps = math.floor(hh * 0.3)
        local R = rr - 1
        for i = 0, steps - 1 do
            local y_off = i
            local alpha = math.floor(peak_alpha * (1 - i / steps))
            local pad_x = 0
            if y_off < R then
                local dy = R - y_off
                pad_x = R - math.sqrt(math.max(0, R * R - dy * dy))
            end
            r.ImGui_DrawList_AddRectFilled(dl, screen_x + 1 + pad_x, screen_y + 1 + y_off, screen_x + ww - 1 - pad_x, screen_y + 1 + y_off + 1.0, 0xFFFFFF00 | alpha)
        end
        
        -- 侧向折射边缘 (Refractive Outline)
        -- 选中态采用 0xFFFFFF44 (25% 强力白边) 以在蓝色底座中“破壳而出”
        local line_alpha = active and 0x44 or (hovered and 0x10 or 0x08)
        r.ImGui_DrawList_AddRect(dl, screen_x, screen_y, screen_x + ww, screen_y + hh, 0xFFFFFF00 | line_alpha, rr, nil, 1.2 * US)
        
        -- 极细底部压深 (Bottom Occlusion)
        if active or hovered then
            r.ImGui_DrawList_AddLine(dl, screen_x + rr, screen_y + hh - 1, screen_x + ww - rr, screen_y + hh - 1, 0x00000022, 1.0)
        end

        -- 4. 文字反馈 (Typography Dynamics)
        local ts_w, ts_h = r.ImGui_CalcTextSize(ctx, label)
        -- 始终保留微弱文字阴影，增强 3D 悬浮感
        r.ImGui_DrawList_AddText(dl, screen_x + (ww - ts_w)/2 + 1, screen_y + (hh - ts_h)/2 + 1, 0x00000033, label)
        
        local text_col = active and 0xFFFFFFFF or 0xAAAAAAFF
        r.ImGui_DrawList_AddText(dl, screen_x + (ww - ts_w)/2, screen_y + (hh - ts_h)/2, text_col, label)

        r.ImGui_SetCursorPos(ctx, cur_x + ww, cur_y)
        return clicked
    end

    --- 工业级侧边栏标题 (Minimalist Version)
    function M.DrawSidebarLabel(ctx, label, scale)
        local Theme = require("YS_Theme")
        local US = scale or 1.0
        local cur_x, cur_y = r.ImGui_GetCursorPos(ctx)
        
        r.ImGui_SetCursorPos(ctx, cur_x + 6 * US, cur_y)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Text(), Theme.COLORS.text_dim)
        r.ImGui_Text(ctx, label:upper())
        r.ImGui_PopStyleColor(ctx)
    end

    --- DrawTabTray：背景由 Archive_UI_Main 统一管理，此函数保留但不绘制任何内容
    function M.DrawTabTray(ctx, x, y, w, h, scale)
        -- V17.2: 背景已由 Archive_UI_Main 直接画 RAISED_BG，这里不重复绘制
    end

    --- 窗口全局背景拖拽实现
    function M.HandleWindowDragging(ctx, G_State, key)
        local h_flags = r.ImGui_HoveredFlags_RootWindow() | r.ImGui_HoveredFlags_ChildWindows()
        local is_hovered = r.ImGui_IsWindowHovered(ctx, h_flags)
        local is_dragging = G_State["is_dragging_" .. (key or "body")]
        
        if is_hovered or is_dragging then
            local wx, wy = r.ImGui_GetWindowPos(ctx)
            local ww = r.ImGui_GetWindowWidth(ctx)
            local wh = r.ImGui_GetWindowHeight(ctx)
            local active, tx, ty = M.HandleStableDrag(ctx, G_State, key or "body", wx, wy + 40, wx + ww, wy + wh)
            if active then return {x = tx, y = ty} end
        end
        return nil
    end

    ---@param ctx any ImGui Context
    ---@param state table Global state table
    ---@param config table UI configuration
    ---@return string|nil action Returns the action triggered
    function M.DrawUnifiedCommandStrip(ctx, state, config)
        local Theme = require("YS_Theme")
        local action = nil
        local win_w = reaper.ImGui_GetWindowWidth(ctx)
        local UI_SCALE = config.scale or 1
        local dl = reaper.ImGui_GetWindowDrawList(ctx) -- [Fix] Correctly capture draw list
        
        -- Layout Specs (Industrial Precision v2.8 - 40px / 52px Balance - V78.8)
        local icon_size = 40 * UI_SCALE
        local spacing = 8 * UI_SCALE -- [V78.8] 统一紧凑间距
        local padding_x = 4 * UI_SCALE
        
        local Icons = require("YS_Icons")
        reaper.ImGui_SetCursorPosX(ctx, padding_x)
        local curr_x, base_y = reaper.ImGui_GetCursorScreenPos(ctx)
        
        -- Helper: Draw icon and handle state (v12.5 Normalized Pad - Mac Style)
        local function DrawStripIcon(id, name, tooltip, active, col_norm, col_hov, norm, strike_through)
            local pad_sz = icon_size
            -- 1. 热区与渲染统一委托 (Single Hitbox Principle)
            -- [V115.2] 完全交给 Icons.DrawIconButton 处理透明屏蔽后的交互
            local scale_factor = norm or 0.95 
            local icon_inner_sz = pad_sz * scale_factor
            local i_off = (pad_sz - icon_inner_sz) * 0.5
            local norm_c = active and Theme.COLORS.accent or (col_norm or 0x8A8E99FF)
            local hov_c = Theme.COLORS.accent
            
            local clicked, hov = Icons.DrawIconButton(ctx, id.."_sym", name, curr_x + i_off, base_y + i_off, icon_inner_sz, active, norm_c, hov_c, nil, false)
            
            -- 可选斜杠：用于“跳过 FX”等关闭逻辑的视觉反馈 (左上到右下)
            if strike_through then
                local line_c = 0xEEEEEEEE -- [V102.5] 换成白色对角线
                local thickness = 2 * UI_SCALE
                local margin = 9 * UI_SCALE -- [V102.6] 显著收缩斜线，不顶到底座边缘
                reaper.ImGui_DrawList_AddLine(dl, curr_x + margin, base_y + margin, curr_x + pad_sz - margin, base_y + pad_sz - margin, line_c, thickness)
            end

            if hov then 
                M.SafeTooltip(ctx, tooltip, state)
            end
            local res = clicked
            
            --  终极对齐修复：直接使用绝对坐标推算
            curr_x = curr_x + pad_sz + spacing
            return res
        end

        -- 1. LEFT GROUP: SETTINGS & LOCK (Global Toggle)
        if DrawStripIcon("Settings", "settings", "打开设置", state.is_setting, 0xCCCCCCFF, nil, 0.95) then
            action = "settings"
        end

        local lock_icon = state.is_global and "Lock_Close" or "Lock_Open"
        --  改名全局搜索并解除 Active 常亮绑定 (仅作为模式切换)
        if DrawStripIcon("Global", lock_icon, "全局搜索\n开启：在全部分类中搜索\n关闭：仅在当前选中分类搜索", false, nil, nil, 0.95) then
            state.is_global = not state.is_global
            action = "toggle_global"
        end

        -- 2. SEARCH INPUT (Flagship v12.0 Inset)
        -- 物理世界基准锁定：抛弃受环境干扰的 Viewport，直接采用父级主窗口的高精度尺寸
        local win_abs_x, win_abs_y = reaper.ImGui_GetWindowPos(ctx)
        
        -- 核心逻辑：主窗口绝对 X坐标 + 主窗口绝对宽度
        local physical_right_edge = (config.win_x or win_abs_x) + (config.width or reaper.ImGui_GetWindowWidth(ctx))
        local total_right_w = (7 * icon_size) + (6 * spacing) 
        local right_start_abs_x = physical_right_edge - total_right_w - 4 * UI_SCALE
        
        -- 纯数学排版：摒弃容易被换行污染的 GetCursorScreenPos，严格使用手动计算的流式坐标
        local curr_abs_x = curr_x
        local curr_abs_y = base_y
        local search_w = right_start_abs_x - spacing - curr_abs_x
        if search_w < 50 * UI_SCALE then search_w = 50 * UI_SCALE end
        
        reaper.ImGui_SetNextItemWidth(ctx, search_w)
        reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_FrameRounding(), 6 * UI_SCALE)
        reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_FramePadding(), 10 * UI_SCALE, 6 * UI_SCALE)
        
        --  工业视界：加深底色以增强三维凹陷对比 (Stereoscopic Inset)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_FrameBg(), 0x181A1CFF)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_FrameBgHovered(), 0x1E2123FF)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_FrameBgActive(), 0x141516FF)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_Text(), 0xECF0F1FF)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_TextDisabled(), 0x94A3B8FF)
        reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_TextSelectedBg(), Theme.COLORS.select_bg)
        
        reaper.ImGui_SetNextItemWidth(ctx, search_w)
        --  精确锚定输入框起点
        reaper.ImGui_SetCursorScreenPos(ctx, curr_abs_x, curr_abs_y + 6 * UI_SCALE) 
        FontManager.PushStaticFont(ctx)
        changed, new_val = reaper.ImGui_InputTextWithHint(ctx, "##Search", "搜索关键词...", state.search_text or "")
        FontManager.PopStaticFont(ctx)
        
        local min_x, min_y = reaper.ImGui_GetItemRectMin(ctx)
        local max_x, max_y = reaper.ImGui_GetItemRectMax(ctx)
        local dl = reaper.ImGui_GetWindowDrawList(ctx)

        --  工业级立体视觉: CNC 铝合金面板切割与高光反射 (Hardware Inset)
        local r = 6 * UI_SCALE
        
        if not reaper.ImGui_IsItemActive(ctx) then
            -- 1. 底边环境光反射 (Bottom Ambient Highlight)：向下偏移 1px，模拟环境光打在面板切口下沿
            reaper.ImGui_DrawList_AddRect(dl, min_x, min_y + 1*UI_SCALE, max_x, max_y + 1*UI_SCALE, 0xFFFFFF15, r)
            
            -- 2. 面板切口主阴影 (Crisp Dark Edge)：覆盖在高光之上，暴露出底部 1px 的反光
            reaper.ImGui_DrawList_AddRect(dl, min_x, min_y, max_x, max_y, 0x00000080, r, nil, 1.0)
            
            -- 3. 顶部深度内阴影 (Top Inner Drop Shadow)：模拟上方光源被切口挡住，增强下沉感
            local shdw_y = min_y + 1.5*UI_SCALE
            reaper.ImGui_DrawList_AddLine(dl, min_x + r*0.5, shdw_y, max_x - r*0.5, shdw_y, 0x00000066, 2.0*UI_SCALE)
        else
            -- 活跃状态：原有的 Accent 高亮框，外加一点立体下沉和发光
            reaper.ImGui_DrawList_AddRect(dl, min_x, min_y + 1*UI_SCALE, max_x, max_y + 1*UI_SCALE, 0x00000044, r) -- Accent 自身的投影
            reaper.ImGui_DrawList_AddRect(dl, min_x, min_y, max_x, max_y, Theme.COLORS.accent, r, nil, 1.5 * UI_SCALE)
        end

        if changed then
            state.search_text = new_val
            action = "search_changed"
        end
        reaper.ImGui_PopStyleColor(ctx, 6)
        reaper.ImGui_PopStyleVar(ctx, 2)
        
        --  右侧图标组：纯数学起始点同步，不再受到任何 Layout 干扰
        curr_x = right_start_abs_x

        -- 3. RIGHT GROUP: TOOLS & ACTIONS (v11.5 Reactive Logic)
        -- History (Now Neutral by default, Highlights on Hover)
        if DrawStripIcon("History", "history", "使用记录：查看并在当前会话中快速锁定已插入或拖拽过的资源", (state.view_mode == "history"), 0xAAAAAAFF, Theme.COLORS.accent or 0x00B4D8FF, 0.95) then 
            action = "show_history" 
        end

        -- Smart/New Toggle
        local insert_icon = state.insert_mode == 1 and "new" or "smart_toy"
        local insert_tip = state.insert_mode == 1 
            and "当前模式：新建插入\n强制为插入的内容创建新轨道。方便独立处理每一层音效，保持工程条理清晰" 
            or "当前模式：智能插入\n在当前选中轨道插入。如果轨道已有内容，则自动向后顺延排列，不增加新轨道"
        --  新建插入/智能插入仅为模式切换，无需常驻蓝光亮起功能
        if DrawStripIcon("InsertToggle", insert_icon, insert_tip, false, nil, nil, 0.95) then 
            state.insert_mode = (state.insert_mode == 1) and 0 or 1
            action = state.insert_mode == 1 and "new_insert" or "smart_insert"
        end

        local piano_icon = state.is_piano_mode and "piano_off" or "piano"
        if DrawStripIcon("Piano", piano_icon, "钢琴模式开关", state.is_piano_mode, nil, nil, 0.95) then 
            action = "toggle_piano" 
        end

        -- AutoClose
        if DrawStripIcon("AutoClose", "AutoClose", "自动关闭：成功插入素材后自动关闭窗口", state.auto_close, nil, nil, 0.95) then
            state.auto_close = not state.auto_close
            action = "toggle_autoclose"
        end

        -- SmartCrop (Formerly Scissor)
        if DrawStripIcon("SmartCrop", "Scissor", "智能裁切：物理截取可见片段，自动剔除未使用区域（所见即所得）。", state.smart_crop, nil, nil, 0.95) then
            state.smart_crop = not state.smart_crop
            action = "toggle_scissor"
        end

        -- Skip FX 
        if DrawStripIcon("SkipFX", "function", "跳过FX：仅保存原始干声采样。自动忽略并剥离 Item 上的所有插件效果", state.skip_fx, nil, nil, 0.95, state.skip_fx) then
            state.skip_fx = not state.skip_fx
            action = "toggle_fxsave"
        end
        -- save (Save Build)
        if DrawStripIcon("Save", "save", "保存搭建：将轨道上选中的音频点存入资源库，支持查重并覆盖同名记录", state.is_saving, nil, nil, 0.95) then 
            action = "save" 
        end

        -- share (Category/Selection Share) - Restored V13.8
        if DrawStripIcon("Share", "external-link", "分享当前选择或分类的配置资源包", false, nil, nil, 0.95) then 
            action = "share" 
        end

        return action
    end

    --- [Case 22] 统一弹窗逻辑引擎：解决布局失衡，强制按钮居中
    --- @param ctx any ImGui Context
    --- @param title string 标题
    --- @param config table { width, scale, G_State, buttons, content_func, id }
    --- [EXPORT V1.2] 声明式布局助手 (Layout Assistant)
    function M.LayoutHelper(ctx, scale, content_w)
        local r = reaper
        local _scale = scale or 1.0
        local _cw = content_w or r.ImGui_GetContentRegionAvail(ctx)
        
        return {
            CenterText = function(text, color)
                local tw = r.ImGui_CalcTextSize(ctx, text)
                r.ImGui_SetCursorPosX(ctx, (_cw - tw) * 0.5)
                if color then r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Text(), color) end
                r.ImGui_Text(ctx, text)
                if color then r.ImGui_PopStyleColor(ctx) end
            end,
            ProgressBar = function(pct, height, label)
                r.ImGui_ProgressBar(ctx, pct, _cw, (height or 28) * _scale, label or "")
            end,
            ChildBox = function(id, height, rounding, draw_func)
                r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ChildBg(), 0x121415FF)
                r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_ChildRounding(), (rounding or 4) * _scale)
                if r.ImGui_BeginChild(ctx, id, _cw, height * _scale, 1) then
                    draw_func()
                    r.ImGui_EndChild(ctx)
                end
                r.ImGui_PopStyleVar(ctx)
                r.ImGui_PopStyleColor(ctx)
            end,
            Spacing = function(h) r.ImGui_Dummy(ctx, 0, (h or 8) * _scale) end,
            Separator = function() r.ImGui_Separator(ctx) end,
            Text = function(text) r.ImGui_Text(ctx, text) end,
            TextColored = function(col, text) r.ImGui_TextColored(ctx, col, text) end,
            InputText = function(id, val, flags)
                r.ImGui_SetNextItemWidth(ctx, _cw)
                return r.ImGui_InputText(ctx, id, val, flags)
            end,
            Button = function(label, w, h, col)
                if col then r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), col) end
                local res = r.ImGui_Button(ctx, label, w, h)
                if col then r.ImGui_PopStyleColor(ctx) end
                return res
            end,
            Checkbox = function(label, val)
                return r.ImGui_Checkbox(ctx, label, val)
            end
        }
    end

    -- 冗余函数已合并至文件顶部 DrawWindowProxyBg (Line 20)

    function M.DrawModal(ctx, title, config)
        local r = reaper
        local scale = config.scale or 1.0

        local scale = config.scale or 1.0
        local win_w = config.width or (420 * scale)
        local popup_id = config.id or (title .. "##" .. (config.suffix or "Modal"))
        
        -- 1. 样式压栈 (物理圆角归零，防止 Docker 背景泄露)
        r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_WindowPadding(), 0, 0)
        r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_WindowBorderSize(), 0.0) 
        r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_WindowRounding(), 0.0)

        -- 2. 颜色控制：窗口背景设为透明，底座由 DrawList 100% 接管
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_WindowBg(), 0x00000000)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_PopupBg(), 0x00000000)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_TitleBgActive(), 0x1A1C1EFF)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Border(), 0x00000000)
        
        local flags = r.ImGui_WindowFlags_AlwaysAutoResize() | r.ImGui_WindowFlags_NoTitleBar() | r.ImGui_WindowFlags_NoBackground()
        
        -- [B4 Fix] Center on screen (force MainViewport because modals are often outside End())
        local vp = r.ImGui_GetMainViewport(ctx)
        local vp_x, vp_y = r.ImGui_Viewport_GetPos(vp)
        local vp_w, vp_h = r.ImGui_Viewport_GetSize(vp)
        local f_flags = flags | reaper.ImGui_WindowFlags_NoBackground() | reaper.ImGui_WindowFlags_NoTitleBar()
        local action_ret = nil
        
        -- [V115.21] 核心重构：移除 IsPopupOpen 依赖，实现纯 Lua 状态驱动 (Case 66)
        -- 外部通过 G.active_modal_id 判断是否调用此函数
        
        -- 1. 全屏吸附压暗底垫 (Invisible Dim Layer)
        r.ImGui_SetNextWindowPos(ctx, vp_x, vp_y)
        r.ImGui_SetNextWindowSize(ctx, vp_w, vp_h)
        r.ImGui_PushStyleColor(ctx, r.ImGui_Col_WindowBg(), 0x00000000)
        local dim_flags = r.ImGui_WindowFlags_NoTitleBar() | r.ImGui_WindowFlags_NoResize() | r.ImGui_WindowFlags_NoMove() | r.ImGui_WindowFlags_NoScrollbar()
        -- 尝试通过 NoInputs 防止抢夺焦点，但如果要保持点击关闭，不能用 NoInputs。
        local rescue_focus = false
        if r.ImGui_Begin(ctx, "ModalDim_"..popup_id, nil, dim_flags) then
            -- [V115.22 Fix] 仅在 modal 已经显示过至少一帧后才允许点击 dim 层关闭
            -- 防止首帧 hover 立即触发 close（零帧可见 Bug）
            if config._appeared and r.ImGui_IsWindowHovered(ctx) and r.ImGui_IsMouseClicked(ctx, 0) then
                action_ret = "close"
            end
            -- Auto-rescue focus: if Dim Layer gets focused, pass it to the Proxy to prevent freeze
            if r.ImGui_IsWindowFocused(ctx) then
                rescue_focus = true
            end
            r.ImGui_End(ctx)
        end
        r.ImGui_PopStyleColor(ctx)

        -- 2. 核心悬浮窗 (Floating Proxy)
        r.ImGui_SetNextWindowSizeConstraints(ctx, 300 * scale, -1, 520 * scale, -1)
        r.ImGui_SetNextWindowPos(ctx, math.floor(vp_x + vp_w * 0.5), math.floor(vp_y + vp_h * 0.5), r.ImGui_Cond_Appearing(), 0.5, 0.5)
        
        if rescue_focus then r.ImGui_SetNextWindowFocus(ctx) end
        if r.ImGui_Begin(ctx, popup_id, nil, f_flags) then
            if r.ImGui_IsWindowAppearing(ctx) then r.ImGui_SetWindowFocus(ctx) end
                local wx, wy = r.ImGui_GetWindowPos(ctx)
            local ww, wh = r.ImGui_GetWindowSize(ctx) -- Use full size for proxy
            local dl = r.ImGui_GetWindowDrawList(ctx)
            
            -- [Case 65] 统一圆角修正：限制为 8px (与工具栏对齐)
            local modal_rd = (Theme.rounding or 8.0) * scale
            local bg_col = Theme.COLORS.title_bg or 0x1A1C1EFF
            
            reaper.ImGui_DrawList_AddRectFilled(dl, wx, wy, wx + ww, wy + wh, bg_col, modal_rd)
            reaper.ImGui_DrawList_AddRect(dl, wx, wy, wx + ww, wy + wh, 0x000000FF, modal_rd, nil, 1.0) -- Border

            r.ImGui_Dummy(ctx, win_w, 0.001)
            
            local hdr = M.DrawHeaderV2(ctx, title, { width = win_w, scale = scale, show_close = true, is_modal = true })
            if hdr == "close" then 
                -- [V115.18 Fix] 解决 Begin 架构下的延迟问题：必须显式返回信号
                action_ret = "close" 
            end
            
            local padding = 24 * scale
            r.ImGui_SetCursorPosY(ctx, r.ImGui_GetCursorPosY(ctx) + 12 * scale)
            
            r.ImGui_BeginGroup(ctx)
            r.ImGui_Indent(ctx, padding)
            local actual_content_w = r.ImGui_GetWindowWidth(ctx) - padding * 2
            r.ImGui_PushItemWidth(ctx, actual_content_w) 
            
            if config.content_func then 
                config.content_func(ctx, scale, actual_content_w, M.LayoutHelper(ctx, scale, actual_content_w)) 
            end
            
            r.ImGui_PopItemWidth(ctx)
            r.ImGui_Unindent(ctx, padding)
            r.ImGui_EndGroup(ctx)
            
            r.ImGui_Dummy(ctx, 0, 10 * scale)
            
            local btns = config.buttons or {
                { label = " 确 认 ", color = 0x4488FFCC, act = "ok", w = 110 },
                { label = " 取 消 ", color = 0x333333FF, act = "cancel", w = 90 }
            }
            
            local spacing = 12 * scale
            local group_w = 0
            local style_pad_x, _ = r.ImGui_GetStyleVar(ctx, r.ImGui_StyleVar_FramePadding())
            local max_btn_w = 0
            for i, b in ipairs(btns) do
                if not b.w or b.w <= 0 then
                    local label_txt = b.label:match("^(.*)##") or b.label
                    local tw, _ = r.ImGui_CalcTextSize(ctx, label_txt)
                    b._actual_w = tw + style_pad_x * 2 + 16 * scale 
                else
                    b._actual_w = b.w * scale
                end
                max_btn_w = math.max(max_btn_w, b._actual_w)
            end
            
            max_btn_w = math.max(max_btn_w, 80 * scale) 
            for i, b in ipairs(btns) do
                b._actual_w = max_btn_w
                group_w = group_w + b._actual_w + (i < #btns and spacing or 0)
            end
            
            local real_win_w = r.ImGui_GetWindowWidth(ctx)
            local start_x = (real_win_w - group_w) * 0.5
            r.ImGui_SetCursorPosX(ctx, start_x)
            
            for i, b in ipairs(btns) do
                local base_col = b.color or 0x4488FFCC
                local hov_col = base_col
                if base_col == 0x4488FFCC then hov_col = 0x5599FFFF
                elseif base_col == 0x333333FF then hov_col = 0x444444FF
                elseif base_col == 0xFF4444CC then hov_col = 0xFF6666FF
                end
                
                r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), base_col)
                r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonHovered(), hov_col)
                r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ButtonActive(), hov_col | 0x22)
                
                if r.ImGui_Button(ctx, b.label, b._actual_w, 32 * scale) or 
                   (b.act == "ok" and r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_Enter())) or
                   (b.act == "cancel" and r.ImGui_IsKeyPressed(ctx, r.ImGui_Key_Escape())) then
                    action_ret = b.act
                end
                r.ImGui_PopStyleColor(ctx, 3)
                if i < #btns then r.ImGui_SameLine(ctx, 0, spacing) end
            end
            
            r.ImGui_Dummy(ctx, 0, 16 * scale)
            r.ImGui_End(ctx)
        end
        
        r.ImGui_PopStyleVar(ctx, 3)
        r.ImGui_PopStyleColor(ctx, 4)
        return action_ret

    end

    return M
end)()

return GUI

  end)(); package.loaded['YS_GUI'] = _m; return _m
end)()
    UI           =  (function()
  local _m = (function()
--- @version 1.1
--- @description YS 拾境 - 布局协调器 (Layout Orchestrator)
--- @author YS / Antigravity
--- @about 负责 SideBar 与 ResultGrid 的顶层布局平衡。
-- [V2.0] refactored: Core rendering moved to Main_Widgets.lua. 
-- This module now acts as a pure layout orchestrator.

local UI = {}
local PRODUCT_ID = "YS_Archive"
local EXTSTATE_SECTION = "YS_Archive"

local G      = nil
local Icons  = nil
local Theme  = nil
local Auth   = nil
local Eng    = nil
local FontManager = nil
local PI     = nil
local GUI    = nil
local State  = nil
local Helper = nil
local Exchange = nil
local MW     = nil

function UI.Init(g, icons, theme, auth, eng, fm, pi, gui, state, helper, exch, mw)
    G = g; Icons = icons; Theme = theme; Auth = auth; Eng = eng; FontManager = fm; PI = pi; GUI = gui; State = state; Helper = helper; Exchange = exch
    MW = mw
end

-- ===================== 主绘制函数 (Entry) =====================
--- @version 1.0.2
--- @description YS 拾境 - 工业级资产交换引擎 (Asset Exchange Engine)
--- @author YS / Antigravity
--- [ASYNCHRONOUS PACK/UNPACK ENGINE]
function UI.Draw(ctx, UI_SCALE)
    local C        = Theme.COLORS
    local US       = UI_SCALE
    local title_h  = 32 * US
    local toolbar_h= 52 * US
    local header_h = title_h + toolbar_h
    local sidebar_w= 188 * US

    local win_w, win_h
    if G.is_collapsed then
        win_w, win_h = 420*US, title_h
        reaper.ImGui_SetNextWindowSize(ctx, win_w, win_h, reaper.ImGui_Cond_Always())
    else
        win_w = math.max(750*US, G._last_saved_w)
        win_h = math.max(400*US, G._last_saved_h)
        if G._needs_resize_sync then
            reaper.ImGui_SetNextWindowSize(ctx, win_w, win_h, reaper.ImGui_Cond_Always())
            G._needs_resize_sync = false
        end
    end

    local wflags = reaper.ImGui_WindowFlags_NoTitleBar() 
                 | reaper.ImGui_WindowFlags_NoScrollbar()
    if G.is_collapsed then wflags = wflags | reaper.ImGui_WindowFlags_NoResize() end
    
    reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_WindowPadding(), 0, 0)
    reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_ChildBorderSize(), 0)
    reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_ScrollbarSize(), 0)
    reaper.ImGui_PushStyleVar(ctx, reaper.ImGui_StyleVar_WindowBorderSize(), 0)
    
    reaper.ImGui_PushStyleColor(ctx, reaper.ImGui_Col_WindowBg(), 0x00000000)
    local visible, open = reaper.ImGui_Begin(ctx, PRODUCT_ID .. "##YSARCH", nil, wflags)
    reaper.ImGui_PopStyleVar(ctx, 4) -- Pop WindowPadding, ChildBorderSize, ScrollbarSize, WindowBorderSize
    
    if visible then
        UI.DrawMain(ctx, US)
    end
    
    reaper.ImGui_End(ctx)
    reaper.ImGui_PopStyleColor(ctx, 1) -- Pop WindowBg
    return open
end

function UI.DrawMain(ctx, US)
    local C = Theme.COLORS
    
    -- [V4.1.2] 布局常量恢复 (Restored Layout Constants)
    local title_h   = 32 * US
    local toolbar_h = 44 * US
    local header_h  = (G.is_collapsed and title_h or (title_h + toolbar_h)) 
    local sidebar_w = 200 * US
    
    -- [V115.14] 抽取底层托底，屏蔽 Docker 污染
    -- [V115.20] 状态回归：恢复标准圆角底座代理
    GUI.DrawWindowProxyBg(ctx, US, C, header_h / US, G.is_collapsed)
    
    local win_w = reaper.ImGui_GetWindowWidth(ctx)
    local win_h = reaper.ImGui_GetWindowHeight(ctx)

    FontManager.PushSidebarFont(ctx)
    local dl    = reaper.ImGui_GetWindowDrawList(ctx)
    local win_x, win_y = reaper.ImGui_GetWindowPos(ctx)

    -- [Auth Gateway] 授权优先级最高，若弹窗打开则直接拦截所有背景绘制（包括 Header/Toolbar）
    local auth_passed, auth_action = Auth.DrawAuthUI(ctx)
    if not auth_passed then
        if auth_action == "exit" then G.force_exit = true end
        FontManager.PopSidebarFont(ctx)
        return
    end

    -- Delegate Header and Toolbar to Main_Widgets
    MW.DrawHeader(ctx, US, win_w, title_h)
    MW.DrawToolbar(ctx, US, win_w, title_h, toolbar_h, header_h)

    if not G.is_collapsed and not G._needs_resize_sync then
        local cur_w, cur_h = reaper.ImGui_GetWindowSize(ctx)
        if cur_w ~= G._last_saved_w or cur_h ~= G._last_saved_h then
            G._last_saved_w, G._last_saved_h = cur_w, cur_h
            reaper.SetExtState(PRODUCT_ID, "LastW", tostring(math.floor(cur_w)), true)
            reaper.SetExtState(PRODUCT_ID, "LastH", tostring(math.floor(cur_h)), true)
        end
    end

    if not G.is_collapsed then
        local body_y = win_y + header_h
        -- [V4.2.0] 边界物理对位：自绘背景必须手动实现圆角以对齐视觉预期
        local rd = Theme.rounding * US
        local r_bl = reaper.ImGui_DrawFlags_RoundCornersBottomLeft()
        local r_br = reaper.ImGui_DrawFlags_RoundCornersBottomRight()
        reaper.ImGui_DrawList_AddRectFilled(dl, win_x, body_y, win_x+sidebar_w, win_y+win_h, Theme.COLORS.sidebar_bg, rd, r_bl)
        reaper.ImGui_DrawList_AddRectFilled(dl, win_x+sidebar_w+3*US, body_y, win_x+win_w, win_y+win_h, Theme.COLORS.base_bg, rd, r_br)
        
        local sep_x = win_x + sidebar_w
        reaper.ImGui_DrawList_AddLine(dl, sep_x, body_y, sep_x, win_y+win_h, 0x00000066, 1.0)
        reaper.ImGui_DrawList_AddLine(dl, sep_x + 1, body_y, sep_x + 1, win_y+win_h, Theme.COLORS.sep_hi, 1.0)

        -- Delegate Layout bodies to Main_Widgets
        MW.DrawSidebar(ctx, US, sidebar_w, header_h)
        MW.DrawMainView(ctx, US, sidebar_w, win_w, header_h)
    end


    FontManager.PopSidebarFont(ctx)
end

return UI

  end)(); package.loaded['Archive_UI_Main'] = _m; return _m
end)()
    
    local m = script_path .. "Modules/"
    MW          = dofile(m .. "Main_Widgets.lua") -- @YS_INJECT
    PEng        = dofile(m .. "Piano_Engine.lua") -- @YS_INJECT
    PW          = dofile(m .. "Piano_Widgets.lua") -- @YS_INJECT
    PModals     = dofile(m .. "Piano_Modals.lua") -- @YS_INJECT
    PI_Module   = dofile(m .. "Archive_UI_Piano.lua") -- @YS_INJECT
    
    -- 3. 依赖注入与初始化
    if Eng and Eng.Init then
        Eng.Init(lib_path, G, Utils, nil, EngDB, EngIO, EngMatch)
        if EngIO and EngIO.Init then EngIO.Init(lib_path, G, Utils, nil, EngDB) end
        if Exchange and Exchange.Init then Exchange.Init(G, Eng, lib_path, Utils) end
        Eng.Exchange = Exchange
        if Async and Async.Init then Async.Init(lib_path, G, Utils, Logger) end
    end
    
    if MW and MW.Init then MW.Init(G, Icons, Theme, Auth, Eng, FontManager, GUI, State, Helper, Exchange, Utils) end
    if UI and UI.Init then UI.Init(G, Icons, Theme, Auth, Eng, FontManager, PI_Module, GUI, State, Helper, Exchange, MW) end
    if Helper and Helper.Init then Helper.Init(G, Icons, Theme, Auth, Eng, PEng, FontManager, GUI, function() return lib_path end, State, Utils, Logger) end
    if PEng and PEng.Init then PEng.Init(G, Eng, FontManager, Theme, Utils) end
    if PW and PW.Init then PW.Init(G, Theme, Eng, FontManager, GUI) end
    if PModals and PModals.Init then PModals.Init(G, Theme, Eng, PEng, FontManager, Helper, GUI) end
    if PI_Module and PI_Module.Init then PI_Module.Init(G, Icons, Theme, Eng, FontManager, GUI, PEng, PW, PModals, Helper) end

    -- 4. 数据实体载入
    if Eng then
        Eng.LoadFavorites()
        local ok_db = Eng.LoadDatabase()
        local ok_tabs = Eng.LoadTabs(State.CreateTab)
        if not (ok_db and ok_tabs) then
            G.tabs = { State.CreateTab("全部") }
            G.active_tab_idx = 1
        end
        Eng.LoadPianoState()
        Eng.LoadPianoSession()
        Eng.SaveSettings()
        
        -- [V2.0] 一次性数据迁移与初始化
        if EngDB.MigrateLegacyData then EngDB.MigrateLegacyData() end
        G._db_rescan_done = true
        
        Eng.ApplyFilter()
    end

    -- 5. 应用 UI 样式
    ApplyUIProps(ctx)
    
    -- [V2.0] Project-Centric Auth ID
    local function ReadSelfAuthId()
        local _, script_file = reaper.get_action_context()
        if not script_file or script_file == "" then return "1001" end -- Fallback
        local f = io.open(script_file, "r")
        if not f then return "1001" end
        local h = f:read(1024); f:close()
        return h:match("@ys_auth_id%s+([%w_%-]+)") or "1001"
    end
    
    local self_id = ReadSelfAuthId()
    Auth.Init(lib_path, self_id, "https://sogpxkopckrp.ap-southeast-1.clawcloudrun.com", "拾境", F)
    Auth.BootstrapChecks() 
    
    if lib_path and lib_path ~= "" then
        G.IsPathReady = true
    end
    
    G._engines_loaded = true
    G._data_load_done = true
    G._app_init_done = true
end

-- ===================== 主循环 =====================
local ctx = reaper.ImGui_CreateContext('YS_Archive', reaper.ImGui_ConfigFlags_DockingEnable())
local first_run = true
local error_reported = false

local function Loop()
    local ok, err = pcall(function()
        if not ctx or not reaper.ImGui_ValidatePtr(ctx, "ImGui_Context*") then return end
        
        if first_run then
            InitApp(ctx)
            first_run = false
            G._boot_time = reaper.time_precise()
            
            -- [V3.1] 立即标记数据加载完成 (从 hierarchy.db 读取后即可显示)
            G._data_load_done = true
            if Eng and Eng.ApplyFilter then Eng.ApplyFilter() end
            
            -- [Pass 2] 立即附加高质量字体 (同步模式下不再分阶段)
            if FontManager and FontManager.AttachHighQualityFonts then
                FontManager.AttachHighQualityFonts(ctx)
            end
            
            local boot_duration = (G._boot_time - G._boot_perf_start) * 1000
            if Logger then Logger.info("Boot", "Atomic sync boot finished", {ms = boot_duration}) end
        else
            local now = reaper.time_precise()
            local elapsed = now - G._boot_time

            -- [V3.0.3] 架构演进：不再自动后台扫盘，改为纯数据库驱动。
            -- 如需同步物理文件，请在设置菜单手动点击“重建索引”。

            -- Stage 3: Background Authenticate Refresh (Deferred to 8s)
            if not G._auth_refreshed and elapsed > 8.0 then
                Auth.BackgroundRefresh()
                G._auth_refreshed = true
            end
        end

        
        if G._request_font_reload then
            -- [V1.3 Fix] NO skip frame needed: path-only cache key means size changes reuse
            -- the same font handle (no new Atlas entry). For file changes, ApplyUIProps runs
            -- BEFORE ImGui_Begin, so NewFrame will include newly attached fonts in THIS frame.
            ApplyUIProps(ctx)
            G._request_font_reload = false
        end
        
        local push_ok, stats = Theme.Push(ctx)
        if push_ok then 
            local UI_SCALE = G.ui_scale
            G._HUD_text = G._HUD_text_next
            G._HUD_text_next = nil
            
            local is_authorized = Auth.IsAuthorized()
            local open = true
            
            if is_authorized then
                if UI then open = UI.Draw(ctx, UI_SCALE) end
                if PI_Module then PI_Module.Draw(ctx, UI_SCALE) end
            else
                -- 绘制独立的授权窗口，不通过 UI.Draw 开启主 Window 壳子
                Auth.DrawAuthUI(ctx)
            end
            
            if Helper and G._data_load_done then
                if Helper.DrawModals then Helper.DrawModals(ctx, UI_SCALE) end
                if Helper.HandleGlobalDragDrop then Helper.HandleGlobalDragDrop(ctx) end
            end
            
            -- Sync Progress HUD removed as requested
            -- DrawStatusHUD(ctx, UI_SCALE) 
            
            if Eng then
                Eng.ProcessAsyncCopyQueue()
                Eng.ProcessDeleteQueue()
                Eng.ProcessOrphanSweep()
            end
            
            Theme.Pop(ctx, stats)
            
            if G._request_reinit then
                G._request_reinit = false
                InitApp(ctx)
            end
            if open and not G.force_exit and not Auth.ShouldExit() then
                reaper.defer(Loop)
            else
                if (Auth.ShouldExit()) then
                    if Logger then Logger.warn("Auth", "Forced closure by Auth Gateway.") end
                end
                if Eng then
                    Eng.SavePianoSession()
                    Eng.SaveSettings()
                end
            end
        else
            -- 样式栈失效通常意味着 Context 出了问题
            reaper.defer(Loop)
        end
    end)
    
    if not ok then
        G._last_error = tostring(err)
        if not error_reported then
            if Logger then Logger.error("Main", "runtime_error", tostring(err)) end
            reaper.ShowConsoleMsg("拾境 (YS_Archive) 运行错误:\n" .. tostring(err) .. "\n")
            error_reported = true
        end
        -- [V1.3] 仅在 ctx 彻底失效时才停止循环；字体过渡等瞬时错误可自动恢复
        if ctx and reaper.ImGui_ValidatePtr(ctx, "ImGui_Context*") then
            error_reported = false
            reaper.defer(Loop)
        end
    end
end

reaper.atexit(function()
    G.history = {}
    if Logger then Logger.info("Main", "session_closed", "History cleared") end
end)

reaper.defer(Loop)
