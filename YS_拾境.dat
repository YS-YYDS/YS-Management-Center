  local _m = (function()
--- @module MachineID_Provider
--- Provides multiple methods to gather a stable Hardware ID for the system.
-- Using reaper directly to comply with Industrial Audit standards.
local G_HWID_CACHE = nil -- Process-level cache
local M = {}

-- [AESTHETIC-SECURITY] Standard Lua-native Base64 Implementation 
-- (Ensures 100% compatibility across all REAPER versions and prevents nil errors)
local function b64_enc(data)
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    return ((data:gsub('.', function(x) 
        local r, bb = '', x:byte(); for j = 8, 1, -1 do r = r .. (bb % 2^j - bb % 2^(j-1) > 0 and '1' or '0') end; return r
    end) .. '0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c = 0; for j = 1, 6 do c = c + (x:sub(j, j) == '1' and 2^(6-j) or 0) end; return b:sub(c + 1, c + 1)
    end) .. ({ '', '==', '=' })[#data % 3 + 1])
end

local function b64_dec(data)
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    return (data:gsub('[^'..b..'=]', ''):gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b:find(x) - 1)
        for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c = 0; for i = 1, 8 do c = c + (x:sub(i, i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local function Obfuscate(data)
    local key = "YS_HWID_PASS"
    local res = {}
    for i = 1, #data do
        res[i] = string.char(data:byte(i) ~ key:byte((i-1)%#key+1))
    end
    return b64_enc(table.concat(res))
end

local function Deobfuscate(data)
    if not data or data == "" then return nil end
    local raw = b64_dec(data)
    if not raw or raw == "" then return nil end
    local key = "YS_HWID_PASS"
    local res = {}
    for i = 1, #raw do
        res[i] = string.char(raw:byte(i) ~ key:byte((i-1)%#key+1))
    end
    return table.concat(res)
end
--- Benchmark a provider function
function M.Benchmark(func, ...)
    local start = reaper.time_precise()
    local id = func(...)
    local duration = (reaper.time_precise() - start) * 1000 -- ms
    return id or "Error/None", duration
end

--- Utility to clean Windows command output
function M.Clean(s)
    if not s then return "" end
    local cleaned = {}
    for i = 1, #s do
        local c = s:byte(i)
        if (c >= 32 and c <= 126) or c == 10 or c == 13 or c == 9 then
            table.insert(cleaned, string.char(c))
        end
    end
    local res = table.concat(cleaned)
    return res:match("^%s*(.-)%s*$")
end

--- Method B: WMIC UUID (Stable, Potential Lag)
function M.GetID_WMIC(timeout)
    local cmd = 'wmic csproduct get uuid'
    local res = reaper.ExecProcess(cmd, timeout or 500)
    if res and res ~= "" then
        res = M.Clean(res)
        local uuid = res:match("(%x+-%x+-%x+-%x+-%x+)")
        if uuid and #uuid > 20 then return "WMIC_" .. uuid end
    end
    return nil
end

--- Method C: Registry MachineGuid (Stable, Fast)
function M.GetID_REG(timeout)
    local cmd = 'reg query "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Cryptography" /v MachineGuid'
    local res = reaper.ExecProcess(cmd, timeout or 500)
    if res and res ~= "" then
        res = M.Clean(res)
        local guid = res:match("(%x+-%x+-%x+-%x+-%x+)")
        if guid and #guid > 20 then return "REG_" .. guid end
    end
    return nil
end

--- Method D: Disk Serial (Fast, Stable)
function M.GetID_Disk(timeout)
    local cmd = 'cmd.exe /c vol c:'
    local res = reaper.ExecProcess(cmd, timeout or 300)
    if res and res ~= "" then
        res = M.Clean(res)
        local serial = res:match("(%x%x%x%x%-%x%x%x%x)")
        if serial then return "DISK_" .. serial end
    end
    return nil
end

--- Path for the physical cache file
local function GetCachePath()
    local info = debug.getinfo(1, "S")
    local path = info.source:match("@?(.*[/\\])") or ""
    -- Use a hidden-like filename in the project root if possible, or same dir
    return path .. "hwid.clib"
end

--- Default "Stable" ID provider using prioritized methods.
function M.GetStableID()
    -- 1. [INSTANT] Process Memory Cache
    if G_HWID_CACHE then return G_HWID_CACHE end

    -- 2. [FAST] Reaper ExtState (Registry-backed in Windows)
    local cached_ext = reaper.GetExtState("YS_Auth_Common", "HWID_PERSIST")
    if cached_ext ~= "" then 
        G_HWID_CACHE = cached_ext
        return cached_ext 
    end

    -- 3. [FILE] Local Physical Cache (Deobfuscated)
    local cf = GetCachePath()
    local f = io.open(cf, "rb")
    if f then
        local raw = f:read("*a")
        f:close()
        local id = Deobfuscate(raw)
        if id and id ~= "" then
            G_HWID_CACHE = id
            reaper.SetExtState("YS_Auth_Common", "HWID_PERSIST", id, true)
            return id
        end
    end

    -- 4. [FALLBACK] If no cache, perform a FAST synchronous check (max 100ms)
    -- We prioritize REG and DISK as they are usually fast.
    local id = M.GetID_REG(100) 
    if not id then id = M.GetID_Disk(100) end
    
    -- 5. [ASYNC] If still no ID, return a hardware-bound but quickly generated ID
    -- and save it as a temporary stable ID.
    if not id then
        local comp = os.getenv("COMPUTERNAME") or "UNK"
        local user = os.getenv("USERNAME") or "USR"
        id = "TMP_" .. comp:sub(1,4) .. "_" .. user:sub(1,4) .. "_" .. reaper.genGuid(""):sub(2,9)
    end

    -- 6. Persistence
    G_HWID_CACHE = id
    reaper.SetExtState("YS_Auth_Common", "HWID_PERSIST", id, true)
    local f2 = io.open(cf, "wb")
    if f2 then
        f2:write(Obfuscate(id))
        f2:close()
    end
    
    return id
end

return M

