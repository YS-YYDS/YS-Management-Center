    G.ui_font_size = math.floor(G.ui_scale * 16 + 0.5)
    
    -- Initialize saved dimensions
    G._last_saved_w = tonumber(r.GetExtState(PRODUCT_ID, "LastW")) or 1000
    G._last_saved_h = tonumber(r.GetExtState(PRODUCT_ID, "LastH")) or 700
    G._needs_resize_sync = true

    -- Load Piano Bindings
    local pb = r.GetExtState(PRODUCT_ID, "PianoBindings")
    if pb ~= "" then
        if Utils and Utils.SafeTableLoad then
            local res = Utils.SafeTableLoad(pb)
            if res then G.piano_bindings = res end
        else
            -- 降级方案 (不推荐，但在 Utils 缺失时作为兼容)
            local loader, err = load("return " .. pb, "PianoData", "t", {})
            if loader then
                local ok, res = pcall(loader)
                if ok and type(res) == "table" then G.piano_bindings = res end
            end
        end
    end

