--- ZONE: MODAL SYSTEM ---

local modal_registry = {
    ["SaveScene"] = {
        title = "保存搭建", id = "保存搭建", w = 300, trigger = "trigger_rename_scene",
        draw = function(c, US, content_w, L)
            if r.ImGui_IsWindowAppearing(c) then r.ImGui_SetKeyboardFocusHere(c) end
            L.Text("请输入名称:")
            r.ImGui_PushStyleColor(c, r.ImGui_Col_FrameBg(), 0x121415FF)
            local ch, nv = L.InputText("##save_name", G.save_scene_buf or "")
            if ch then G.save_scene_buf = nv end
            r.ImGui_PopStyleColor(c)
        end,
        btns = { {L=" 确 认 ", C=0x4488FFCC, A="ok", W=110}, {L=" 取 消 ", C=0x333333FF, A="cancel", W=90} },
        on_any = function(res)
            if res == "ok" and G.save_scene_buf ~= "" then
                local confirm = true
                if Utils.ScanTree(G.virtual_tree, G.save_scene_buf) then
                    local res_mb = r.MB("搭建 '"..G.save_scene_buf.."' 已存在，是否将其覆盖？", "覆盖确认", 4)
                    if res_mb ~= 6 then confirm = false end
                end
                if confirm then Eng.SaveScene(G.save_scene_buf) end
            end
        end
    },
    ["SystemPrompt"] = {
        title = "系统提示", id = "系统提示", w = 300, trigger = "trigger_prompt",
        draw = function(c, US, content_w, L) L.Text(G.auth_error_msg or "未知提示") end,
        btns = { {L=" 好 的 ", C=0x4488FFCC, A="ok", W=120} }
    },
    ["AuthSuccess"] = {
        title = "拾境 | 授权成功", id = "授权成功", w = 360, trigger = "trigger_auth_success",
        draw = function(c, US, content_w, L)
            L.Text("★ 恭喜！您已成功激活全功能版。")
            L.Spacing(10)
            local expiry_str = "永久有效"
            if G.expiry_ts and G.expiry_ts > 0 then
                expiry_str = os.date("%Y-%m-%d %H:%M", G.expiry_ts)
            end
            L.TextColored(0xBBBBBBFF, "有效期至: " .. expiry_str)
            L.Spacing(10)
            L.Text("请尽情享受专业的数据搭建体验。")
        end,
        btns = { {L=" 开启拾境之旅 ", C=0x5B6EE1FF, A="ok", W=180} },
        on_any = function(res)
            if res == "ok" then
                -- 显式清理强制显示状态，确保进入主界面
                G.force_show_ui = false
            end
        end
    },
    ["ImportProgress"] = {
        title = "导入资源中", id = "导入进度", w = 400, trigger = "trigger_import_progress",
        draw = function(c, US, content_w, L)
            if Eng.Exchange then
                local pct, status = Eng.Exchange.GetUnpackStatus()
                L.Text(status)
                L.ProgressBar(pct, 20)
                
                -- [V2.2.3] 动态操作日志：为用户提供明确的“跳过/覆盖”反馈，消除疑虑
                if G.import_last_action then
                    L.Spacing(4)
                    L.TextColored(0xAAAAAAFF, "最近操作: " .. G.import_last_action)
                end

                if not G._import_notified and Eng.Exchange.StepUnpackSession() then
                    G._import_notified = true -- 一次性防重触发保护
                    local ok, skip, err = Eng.Exchange.GetUnpackStats()
                    local msg = string.format("资源包处理完成！\n\n- 新增/覆盖: %d\n- 已跳过: %d\n- 失败: %d", ok, skip, err)
                    r.MB(msg, "导入完成", 0)
                    G.active_modal_id = nil -- 立即销毁弹窗 ID，防止下帧重入
                    G.trigger_import_progress = false 
                    G.import_last_action = nil -- 清理日志
                    if G.is_piano_mode and Eng.ScanPianoPresets then Eng.ScanPianoPresets() end
                    Eng.ApplyFilter()
                    G._import_notified = nil -- 任务彻底结束后重置保护位
                end
            end
        end,
        btns = {} -- No buttons, auto-close on finish
    },
    ["ExchangeConflict"] = {
        title = "导入名称重复", id = "导入冲突", w = 360, trigger = "trigger_exchange_conflict",
        draw = function(c, US, content_w, L)
            L.Text("场景 '" .. (G.import_conflict_item or "未知") .. "' 在本地已存在。")
            L.Text("请选择处理方式:")
            L.Spacing(4)
            local rv, nv = L.Checkbox("应用到后续所有冲突", G.import_apply_to_all or false)
            if rv then G.import_apply_to_all = nv end
        end,
        btns = { 
            {L="  覆 盖  ", C=0xFF4444CC, A="OVERWRITE", W=100}, 
            {L=" 自 动 更 名 ", C=0x4488FFCC, A="RENAME", W=100},
            {L="  跳 过  ", C=0x333333FF, A="SKIP", W=100}
        },
        on_any = function(res)
            -- [V2.2.8] 健壮性：如果用户关闭弹窗而不做选择，默认为 SKIP，防止无限弹窗
            if res == "close" or res == "cancel" then res = "SKIP" end
            
            if res ~= "close" and res ~= "cancel" then
                if G.import_apply_to_all then G.last_import_resolution = res end
                G.import_resolution = res
                G.active_modal_id = "导入进度"
            end
        end
    },
    ["Rename"] = {
        title = function() 
            if G.is_creating_new then return "新建项" end
            if G.rename_target_type == "TAB" or G.rename_target_type == "PIANO_TAB" then return "重命名标签页" end
            return "重命名" 
        end,
        id = "重命名弹窗", w = 300, trigger = "trigger_rename_pop",
        draw = function(c, US, content_w, L)
            local lbl = (G.rename_target_type == "TAB") and "新标签名称:" or "名称:"
            L.Text(lbl)
            r.ImGui_PushStyleColor(c, r.ImGui_Col_FrameBg(), 0x121415FF)
            local ch, nv = L.InputText("##modal_rename_inp", G.rename_buf or "", r.ImGui_InputTextFlags_AutoSelectAll())
            if ch then G.rename_buf = nv end
            r.ImGui_PopStyleColor(c)
        end,
        btns = { {L=" 确 定 ", C=0x4488FFCC, A="ok", W=110}, {L=" 取 消 ", C=0x333333FF, A="cancel", W=90} },
        on_any = function(res)
            if res == "ok" and G.rename_buf ~= "" then
                -- [Bug 2 Fix] Prioritize creation: ensure 'is_creating_new' is handled before any rename logic
                if G.is_creating_new and G.create_target_list then
                    table.insert(G.create_target_list, { name = G.rename_buf, children = {}, scenes = {}, id = os.time()..math.random(100) })
                    Eng.SaveDatabase()
                elseif G.rename_target_type == "TAB" and G.action_target_tab then
                    G.action_target_tab.name = G.rename_buf; Eng.SaveTabs(State.CreateTab)
                elseif G.rename_target_type == "PIANO_TAB" and G._piano_rename_tab and G.piano_tabs[G._piano_rename_tab] then
                    G.piano_tabs[G._piano_rename_tab].name = G.rename_buf; Eng.SaveSettings()
                elseif G.rename_target_type == "PIANO_SLOT" and G._piano_rename_slot_idx then
                    local tab = G.piano_tabs[G.piano_active_tab]
                    if tab and tab.slots[G._piano_rename_slot_idx] then
                        tab.slots[G._piano_rename_slot_idx].alias = (G.rename_buf == "") and " " or G.rename_buf
                        Eng.SaveSettings()
                    end
                elseif G.rename_target_type == "SCENE" and G.action_target_scene then
                    Eng.RenameScene(G.action_target_scene, G.rename_buf, G.action_target_node)
                elseif G.action_target_node then
                    G.action_target_node.name = G.rename_buf; Eng.SaveDatabase()
                end
            end
            G.is_creating_new = false; G.rename_target_type = nil; G._piano_rename_tab = nil; G._piano_rename_slot_idx = nil
            G.action_target_scene = nil; G.action_target_node = nil -- Reset targets for safety
        end
    },
    ["SavePianoPreset"] = {
        title = "保存预设方案", id = "保存预设方案", w = 300, trigger = "_piano_trigger_save_preset",
        draw = function(c, US, content_w, L)
            L.Text("输入方案名称:")
            local ch, nv = L.InputText("##preset_save_inp", G._piano_save_preset_buf or "", r.ImGui_InputTextFlags_AutoSelectAll())
            if ch then G._piano_save_preset_buf = nv end
        end,
        btns = { {L=" 确 定 ", C=0x4488FFCC, A="ok", W=100}, {L=" 取 消 ", C=0x333333FF, A="cancel", W=100} },
        on_any = function(res)
            if res == "ok" and G._piano_save_preset_buf ~= "" then
                local exists = false
                if G.piano_preset_list then
                    for _, p in ipairs(G.piano_preset_list) do
                        if p == G._piano_save_preset_buf then exists = true; break end
                    end
                end
                
                local confirm = true
                if exists then
                    local choice = r.MB("预设方案 '"..G._piano_save_preset_buf.."' 已存在，是否覆盖？", "方案已存在", 4)
                    if choice ~= 6 then confirm = false end
                end
                
                if confirm then 
                    Eng.SavePianoPreset(G._piano_save_preset_buf)
                else
                    G.active_modal_id = "保存预设方案"
                    G._piano_trigger_save_preset = false -- Ensure trigger doesn't re-trigger
                end
            end
        end
    },
    ["ClearPianoTab"] = {
        title = "风险操作确认", id = "风险操作确认", w = 280, trigger = "_piano_trigger_clear_all",
        draw = function(c, US, content_w, L)
            r.ImGui_PushStyleColor(c, r.ImGui_Col_Text(), 0xFF5555FF)
            L.Text("⚠️")
            r.ImGui_PopStyleColor(c)
            r.ImGui_SameLine(c, 0, 2 * US)
            L.Text("警告：这将彻底清空该分页下的")
            L.Text("所有图片以及音频素材。")
        end,
        btns = { {L=" 确定清空 ", C=0xFF4444CC, A="ok", W=110}, {L=" 取 消 ", C=0x333333FF, A="cancel", W=90} },
        on_any = function(res)
            if res == "ok" then
                local tab = G.piano_tabs[G.piano_active_tab]
                if tab then
                    for i, slot in ipairs(tab.slots) do
                        if #slot.items > 0 then
                            PEng.RecordDeletion(i, slot)
                        end
                    end
                    PEng.ResetTabToDefault(tab)
                    Eng.SaveSettings()
                end
            end
        end
    },
    ["PianoHistory"] = {
        title = "最近删除记录", id = "PianoHistory", w = 380, trigger = "trigger_piano_history_pop",
        draw = function(c, US, content_w, L)
            if not G.piano_deleted_history or #G.piano_deleted_history == 0 then
                L.CenterText("暂无删除记录")
                return
            end
            L.Text("点击条目立即还原到对应位置:")
            L.Spacing(4)
            L.ChildBox("hist_list", 280, 4, function()
                local dl = r.ImGui_GetWindowDrawList(c)
                for i, entry in ipairs(G.piano_deleted_history) do
                    r.ImGui_PushID(c, i)
                    
                    local row_h = 36 * US
                    local cx, cy = r.ImGui_GetCursorScreenPos(c)
                    local win_w = r.ImGui_GetContentRegionAvail(c)
                    
                    -- Interaction logic
                    local hov = r.ImGui_IsMouseHoveringRect(c, cx, cy, cx + win_w, cy + row_h)
                    local active = r.ImGui_IsMouseDown(c, 0) and hov
                    
                    -- Background frame
                    local col = active and 0x4488FF66 or (hov and 0x4488FF33 or 0x25282AFF)
                    r.ImGui_DrawList_AddRectFilled(dl, cx, cy, cx + win_w, cy + row_h, col, 4*US)
                    r.ImGui_DrawList_AddRect(dl, cx, cy, cx + win_w, cy + row_h, 0xFFFFFF11, 4*US)
                    
                    -- 1. Slot Badge
                    r.ImGui_SetCursorScreenPos(c, cx + 8*US, cy + (row_h - 18*US)*0.5)
                    r.ImGui_DrawList_AddRectFilled(dl, cx + 8*US, cy + (row_h - 18*US)*0.5, cx + 58*US, cy + (row_h + 18*US)*0.5, 0x4488FF22, 2*US)
                    L.TextColored(0x4488FFFF, string.format(" 插槽 %d", entry.slot_idx))
                    
                    -- 2. Time
                    r.ImGui_SameLine(c, 62 * US)
                    L.TextColored(0x888888FF, entry.time)
                    
                    -- 3. Name (Bold/Bright)
                    r.ImGui_SameLine(c, 120 * US)
                    -- Ensure uniqueness for ID purposes even if label same
                    local display_label = (entry.label == "" and "无名音频") or entry.label
                    L.Text(display_label)
                    
                    -- Invisible overlapping area for clicking
                    r.ImGui_SetCursorScreenPos(c, cx, cy)
                    if r.ImGui_InvisibleButton(c, "##item_btn_"..i, win_w, row_h) then
                        PEng.RestoreDeletion(i)
                    end
                    if r.ImGui_IsItemHovered(c) then
                        r.ImGui_SetTooltip(c, "点击立即恢复: " .. entry.label)
                    end
                    
                    r.ImGui_PopID(c)
                    L.Spacing(2)
                end
            end)
        end,
        btns = { {L=" 清空历史 ##PianoHistClear", C=0x555555FF, A="clear", W=100}, {L=" 关 闭 ##PianoHistClose", C=0x333333FF, A="cancel", W=100} },
        on_any = function(res)
            if res == "clear" then
                G.piano_deleted_history = {}
                G.active_modal_id = "PianoHistory"
            end
        end
    },
    ["PianoExport"] = {
