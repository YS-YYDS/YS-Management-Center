--- @version 1.1
--- @description YS 拾境 - 引擎调度中心 (Engine Dispatcher)
--- @author YS / Antigravity
--- [ENGINE LAYER ORCHESTRATOR]
--
-- [GENE: V2.0]
-- 此模块现已降级为调度器。所有重量级逻辑交由：
-- - Engine_DB.lua (虚拟树/搜索/分类/环境匹配)
-- - Engine_IO.lua (文件读写/轨道插入/异步队列处理)

local Eng = {}
local PRODUCT_ID = "YS_Archive"

local lib_path = ""
local G = nil
local Utils = nil
local Dbg = nil

-- 子模块依赖
local EngDB = nil
local EngIO = nil
local EngMatch = nil
local Logger = nil -- [INDUCTED] 可观测性基座

-- 初始化调度器
function Eng.Init(lp, g_ref, utils_ref, dbg_fn, db_module, io_module, match_module)
    lib_path = lp
    G = g_ref
    Utils = utils_ref
    Eng.Utils = utils_ref
    Dbg = dbg_fn
    
    EngDB = db_module
    EngIO = io_module
    EngMatch = match_module
    
    -- 动态感知 Logger
    if package.loaded["Archive_Logger"] then Logger = package.loaded["Archive_Logger"] end
    
    if EngDB then EngDB.Init(lp, g_ref, utils_ref, dbg_fn, Eng) end
    if EngIO then EngIO.Init(lp, g_ref, utils_ref, dbg_fn, EngDB) end
    if EngMatch then EngMatch.Init(lp, g_ref, EngDB, utils_ref) end
    
    if Logger then Logger.info("Engine", "initialized", {product_id = PRODUCT_ID}) end
end

-- ===================== 状态存取 =====================
function Eng.GetLibraryPath()
    return lib_path
end

function Eng.SaveSettings()
    local settings = {
        core = {
            insert_mode = G.insert_mode or 1,
            auto_close = G.auto_close,
            smart_crop = G.smart_crop,
            skip_fx = G.skip_fx
        },
        piano = {
            expanded_w = G._piano_expanded_w,
            expanded_h = G._piano_expanded_h,
            active_tab = G.piano_active_tab or 1,
            history    = G.piano_deleted_history -- [V2.2.16] 持久化删除历史
        }
    }
    
    -- 获取当前 Piano Tab 的参数
    local act_t = G.piano_tabs and G.piano_tabs[G.piano_active_tab or 1]
    settings.piano.params = act_t and act_t.params or G.piano_params or {}
    
    Utils.SaveTable("SettingsV3", settings)

    if G.piano_bindings then
        local pb_str = Utils.SerializeTable(G.piano_bindings)
        reaper.SetExtState("YS_Archive", "PianoBindings", pb_str, true)
    end
end

function Eng.LoadPianoState()
    local settings = Utils.LoadTable("SettingsV3")
    if settings then
        -- Core Settings
        if settings.core then
            G.insert_mode = settings.core.insert_mode or 1
            G.auto_close = settings.core.auto_close
            G.smart_crop = settings.core.smart_crop
            G.skip_fx = settings.core.skip_fx
        end
        -- Piano Settings
        if settings.piano then
            G._piano_expanded_w = settings.piano.expanded_w
            G._piano_expanded_h = settings.piano.expanded_h
            G.piano_params = settings.piano.params
            G.piano_active_tab = settings.piano.active_tab
            G.piano_deleted_history = settings.piano.history or {} -- [V2.2.16] 恢复删除历史
        end
    else
        -- 向后兼容旧版 V2
        local old_val = reaper.GetExtState(PRODUCT_ID, "SettingsV2")
        if old_val ~= "" then
            local parts = {}
            for part in old_val:gmatch("[^|]+") do table.insert(parts, part) end
            
            if parts[1] then
                local i_m, a_c, s_c, s_f = parts[1]:match("([^,]+),([^,]+),([^,]+),([^,]+)")
                G.insert_mode = tonumber(i_m) or 1
                G.auto_close = (a_c == "true")
                G.smart_crop = (s_c == "true")
                G.skip_fx = (s_f == "true")
            end

            local p2 = parts[2]
            if p2 and p2 ~= "" then
                local v_o, p_o, s_o, r_o, v_r, p_r, s_t = p2:match("([^,]+),([^,]+),([^,]+),([^,]+),([^,]+),([^,]+),([^,]+)")
                G.piano_params = {
                    vol_on = (v_o == "true"), pitch_on = (p_o == "true"), step_on = (s_o == "true"), rand_on = (r_o == "true"),
                    vol_range = tonumber(v_r) or 12.0, pitch_shift = tonumber(p_r) or 24.0, step_time = tonumber(s_t) or 0.125
                }
            end
            
            local p3 = parts[3]
            if p3 and p3 ~= "" then
                local w, h = p3:match("([^,]+),([^,]+)")
                if w and h then
                    G._piano_expanded_w = tonumber(w)
                    G._piano_expanded_h = tonumber(h)
                end
            end
        end
    end
end

-- ===================== Engine_DB 转发 =====================
function Eng.SaveDatabase() if EngDB then EngDB.SaveDatabase() end end
function Eng.RescanPhysicalScenes() if EngDB then EngDB.RescanPhysicalScenes() end end
function Eng.LoadDatabase() if EngDB then return EngDB.LoadDatabase() end end
