                    G.active_modal_id = nil
                    G.trigger_progress = false
                    G._clean_notified = nil
                 end
            end
        end,
        btns = {}
    }
}

function Helper.DrawModals(ctx, ui_scale)
    -- [V115.22 Fix] 两阶段渲染：先统一收集所有触发器，再统一渲染
    -- 修复了同帧内"触发立即被 dim 层 hover 检测关闭"的零帧可见 Bug

    -- === 阶段一：批量收集所有 pending triggers（独立遍历，不渲染）===
    local new_modal_id = nil
    for _, cfg in pairs(modal_registry) do
        if cfg.trigger and G[cfg.trigger] then
            new_modal_id = cfg.id
            G[cfg.trigger] = false
            if Logger then Logger.info("UI.Modal", "trigger_fired", {id = cfg.id, trigger = cfg.trigger}) end
        end
    end
    -- 只有当无当前弹窗，或者新触发器有更高优先级时才切换
    if new_modal_id then
        G.active_modal_id = new_modal_id
        G._modal_appeared = false -- 重置出现标志，防止当帧立即关闭
    end

    -- === 阶段二：渲染当前激活的 modal（使用 ipairs 保证确定性顺序）===
    if not G.active_modal_id then return end
    
    for _, cfg in pairs(modal_registry) do
        if G.active_modal_id == cfg.id then
            local title = type(cfg.title) == "function" and cfg.title() or cfg.title
            
            local res = GUI.DrawModal(ctx, title, {
                width = cfg.w * ui_scale, scale = ui_scale, id = cfg.id,
                content_func = cfg.draw,
                G_State = G,
                -- [V115.22] 传入 appeared 标志，防止 dim 层在首帧触发关闭
                _appeared = G._modal_appeared,
                buttons = (function()
                    local b = {}
                    local src = type(cfg.btns) == "function" and cfg.btns() or cfg.btns
                    for _, v in ipairs(src or {}) do 
                        table.insert(b, {label=v.L, color=v.C, act=v.A, w=v.W}) 
                    end
                    return b
                end)()
            })
            
            -- 仅在首帧渲染后才允许 dim 层关闭
            G._modal_appeared = true
            
            if res then
                if Logger then Logger.info("UI.Modal", "modal_action", {id = cfg.id, res = res}) end
                local prevent_close = (cfg.id == "分享预设" or cfg.id == "分享确认") and res == "ok"
                if (res == "close" or res == "cancel" or res == "ok") and not prevent_close then
                    G.active_modal_id = nil
                    G._modal_appeared = false
                end
                if cfg.on_any then cfg.on_any(res) end
            end
            break -- 每帧只渲染一个 modal
        end
    end
end

--- ZONE: EVENT HANDLERS ---

function Helper.HandleGlobalDragDrop(ctx)
    if G.dragging_scene and r.ImGui_IsMouseReleased(ctx, 0) then
        if not r.ImGui_IsWindowHovered(ctx, r.ImGui_HoveredFlags_AnyWindow()) then
            local mx, my = r.GetMousePosition()
            local track, _ = r.GetTrackFromPoint(mx, my)
            local mouse_time = r.GetCursorPosition()
            
            if r.BR_GetMouseCursorContext_Pos then
                mouse_time = r.BR_GetMouseCursorContext_Pos()
            else
                local arrange = r.JS_Window_FindChildByID(r.GetMainHwnd(), 1000)
                if arrange then
                    local _, left, _, right = r.JS_Window_GetRect(arrange)
                    local width = right - left
                    if width > 0 then
                        local startTime, endTime = r.GetSet_ArrangeView2(0, false, 0, 0)
                        mouse_time = startTime + (mx - left) * (endTime - startTime) / width
                    end
                end
            end
            if not mouse_time or mouse_time < 0 then mouse_time = r.GetCursorPosition() end
            
            -- [Industrial Guard] Safety check for the drag target
            if G.dragging_scene and G.dragging_scene ~= "" then
                Eng.InsertScene(G.dragging_scene, mouse_time, track)
            end
        end
        G.dragging_scene = nil 
    end
end

return Helper

  end)(); package.loaded['Archive_UI_Helper'] = _m; return _m
end)()
local Logger       =  (function()
  local _m = (function()
--[[
  * ReaScript Name: Archive_Logger.lua
  * About: Zero-dependency structured file logger for YS_Archive.
  * Author: YS
  * License: GPL v3
  * Version: 1.0
--]]

local r = reaper
local Logger = {}
local _log_path = ""
local _log_dir = ""

local function OpenFolder(path)
    if r.CF_ShellExecute then
        r.CF_ShellExecute(path)
        return
    end
    local os_str = r.GetOS()
    if os_str:match("Win") then
        os.execute('explorer "' .. path:gsub('/', '\\') .. '"')
    else
        os.execute('open "' .. path .. '"')
    end
end

local function CleanupOldLogs(dir_path, days_to_keep)
    local cur_time = os.time()
    local i = 0
    local files_to_delete = {}
    while true do
        local file = r.EnumerateFiles(dir_path, i)
        if not file then break end
        
        if file:match("^archive_") and file:match("%.log$") then
            -- 解析 archive_YYYYMMDD.log 的日期
            local date_str = file:match("archive_(%d%d%d%d%d%d%d%d)%.log")
            if date_str then
                local y = tonumber(date_str:sub(1,4))
                local m = tonumber(date_str:sub(5,6))
                local d = tonumber(date_str:sub(7,8))
                if y and m and d then
                    local file_time = os.time({year=y, month=m, day=d, hour=0, min=0, sec=0})
                    if cur_time - file_time > (days_to_keep * 24 * 60 * 60) then
                        table.insert(files_to_delete, dir_path .. "/" .. file)
                    end
                end
            end
        end
        i = i + 1
    end
    
    for _, fpath in ipairs(files_to_delete) do
        os.remove(fpath)
    end
end

function Logger.Init(lib_path)
    _log_dir = lib_path .. "/_logs"
    r.RecursiveCreateDirectory(_log_dir, 0)
    _log_path = _log_dir .. "/archive_" .. os.date("%Y%m%d") .. ".log"
    
    -- 清理 7 天前的历史日志
    CleanupOldLogs(_log_dir, 7)
    
    Logger.info("Logger", "System Init", {path = _log_path})
end

function Logger.OpenLogFolder()
    if _log_dir ~= "" then
        OpenFolder(_log_dir)
    end
end

local function format_ctx(ctx_table)
    if not ctx_table then return "" end
    local parts = {}
    local keys = {}
    for k in pairs(ctx_table) do table.insert(keys, k) end
    table.sort(keys) -- [Taste Fix] 确保字段顺序固定，易于解析
    
    for _, k in ipairs(keys) do
        table.insert(parts, tostring(k) .. "=" .. tostring(ctx_table[k]))
    end
    return " {" .. table.concat(parts, ", ") .. "}"
end

local function write_log(level, tag, msg, ctx_table)
    if _log_path == "" then return end
    local ctx_str = format_ctx(ctx_table)
    local entry = string.format("[%s][%s][%s] %s%s\n", os.date("%Y-%m-%d %H:%M:%S"), level, tag, msg, ctx_str)
    
    local f = io.open(_log_path, "a")
    if f then 
        f:write(entry)
        f:close() 
    end
end

function Logger.info(tag, msg, ctx_table)
    write_log("INFO", tag, msg, ctx_table)
end

function Logger.warn(tag, msg, ctx_table)
    write_log("WARN", tag, msg, ctx_table)
end

function Logger.error(tag, msg, err_detail)
    -- ERROR 级的 ctx 通常包含 error栈详情
    write_log("ERROR", tag, msg, {detail = tostring(err_detail)})
end

function Logger.debug(tag, msg, ctx_table)
    write_log("DEBUG", tag, msg, ctx_table)
end

return Logger

  end)(); package.loaded['Archive_Logger'] = _m; return _m
end)()
