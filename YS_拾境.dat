                local combo_opened = r.ImGui_BeginCombo(c, "##font_select", cur_f_name, r.ImGui_ComboFlags_HeightLarge())
                r.ImGui_PopStyleColor(c, 2)

                if combo_opened then
                    for i, f in ipairs(FontManager.AvailableScriptFonts) do
                        if i == 2 then -- 在内置“系统默认”与扫描出的列表间增加分割线
                            r.ImGui_Separator(c)
