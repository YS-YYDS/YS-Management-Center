    end

    -- 试用弹窗调度
    if cfg.show_trial_nag_modal then
        UI.DrawTrialNag(ctx, cfg, Core)
        return pop_wrapper(false)
    end

    -- --- 中心化授权引导 (Auth Center 已剥离) ---
    if not cfg.is_auth_passed or cfg.force_show_ui then
        UI.CenterNextWindow(ctx)
        r.ImGui_SetNextWindowFocus(ctx)
        r.ImGui_SetNextWindowSize(ctx, 360, 0, r.ImGui_Cond_Always())
        local f = r.ImGui_WindowFlags_AlwaysAutoResize() | r.ImGui_WindowFlags_NoTitleBar() | r.ImGui_WindowFlags_NoBackground() | r.ImGui_WindowFlags_TopMost()
        local visible, open = r.ImGui_Begin(ctx, "验证引导", nil, f)
        if visible then
            local wx, wy = r.ImGui_GetWindowPos(ctx); local ww, wh = r.ImGui_GetWindowSize(ctx)
            UI.DrawProxyBackground(ctx, wx, wy, ww, wh)
            
            r.ImGui_Dummy(ctx, 0, 15)
            
            local title = "未检测到有效授权"
            local tw = r.ImGui_CalcTextSize(ctx, title)
            r.ImGui_SetCursorPosX(ctx, (ww - tw) / 2)
            r.ImGui_TextColored(ctx, 0xFF6666FF, title)
            
            r.ImGui_Dummy(ctx, 0, 15)
            
            local msg = "请打开【YS脚本管理器】进行免费试用或激活。"
            local mw = r.ImGui_CalcTextSize(ctx, msg)
            r.ImGui_SetCursorPosX(ctx, (ww - mw) / 2)
