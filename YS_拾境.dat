                        if r.ImGui_Selectable(c, f.text .. "##f_" .. i, G.script_font_idx == i) then
                            G.script_font_idx = i
                            r.SetExtState(PRODUCT_ID, "ScriptFontIdx", i, true)
                            G._request_font_reload = true
                        end
                    end
                    r.ImGui_Separator(c)
                    if r.ImGui_Selectable(c, "[+] 添加自定义字体...##add_font") then
                        -- JS_Dialog_BrowseForOpenFiles(title, initialFolder, initialFile, extensionFilter, allowMultiple)
                        local retval, file_list = r.JS_Dialog_BrowseForOpenFiles("选择字体文件 (.ttf / .otf)", "", "", "Font Files (*.ttf;*.otf)\0*.ttf;*.otf\0", false)
                        if retval > 0 and file_list ~= "" then
                            local decoded_f = Utils and Utils.ToUTF8(file_list) or file_list
                            local font_path = decoded_f:gsub("\\", "/")
                            FontManager.AddCustomFont(font_path)
                            FontManager.LoadSystemFonts(true) -- 强制刷新列表
                            -- 自动选中新添加的字体
                            G.script_font_idx = #FontManager.AvailableScriptFonts
                            r.SetExtState(PRODUCT_ID, "ScriptFontIdx", G.script_font_idx, true)
                            G._request_font_reload = true
                        end
                    end
                    r.ImGui_EndCombo(c)
                end
            end)
            
            L.Spacing(4)
            -- [V7.0] 移除冗余的 Debug 期字体提示，回归极简工业风
            
            
            L.Spacing(8)
