-- [V1.9.0 Industrial Kernel]
-- 移除了所有高频调试控制台输出，确保生产环境 0 污染
if not reaper.ImGui_CreateContext then
    reaper.MB("需要 'ReaImGui' 扩展。", "环境错误", 0); return
end

--- [Phase 1] 路径感知与注入 (Genetic Injection)
--- 动态平衡 REAPER 脚本路径，支持 Modules 子目录与 YS_Shared 共享库。
--- @function SetupLoadPath
--- @return string script_path 脚本物理根路径
local function SetupLoadPath()
    local _, script_file = reaper.get_action_context()
    local res_path = reaper.GetResourcePath():gsub("\\", "/"):gsub("/$", "") .. "/"
    local script_path = (script_file and script_file ~= "") and script_file:gsub("\\", "/"):match('^(.+[\\/])') or (res_path .. "Scripts/YS_拾境/")
    return script_path
end
local script_path = SetupLoadPath()

-- Ensure local modules and shared library can be required
local parent_path = script_path:match("^(.*[\\/])[^\\/]+[\\/]$") or script_path
package.path = package.path .. ";" .. script_path .. "Modules/?.lua"
package.path = package.path .. ";" .. parent_path .. "YS_Shared/?.lua"

-- ===================== [YS_Industrial] 模块加载引擎 (Robust Loader) =====================
-- [Phase 1.1] 环境检查与开发者模式 (Environment & DEV_MODE)
local DEV_MODE = false -- 生产模式，禁用热加载
if reaper.HasExtState("YS_Archive", "DEV_MODE") then DEV_MODE = true end

local function SafeLoad(mod_name)
    -- [[ V3.5 PRO ]] 优先从内存读取，极大提升二次启动速度
    if not DEV_MODE and package.loaded[mod_name] then 
        return package.loaded[mod_name] 
    end

    -- 方案 A: 使用 require (受 package.path 路径包围)
    local ok, ret = pcall(require, mod_name)
    if ok then return ret end
    
    -- 方案 B: 使用物理路径 dofile 兜底
    local path = script_path .. "Modules/" .. mod_name .. ".lua"
    local ok2, ret2 = pcall(dofile, path)
    if not ok2 then
        local err_msg = "组件加载失败!\n\n" ..
                      "模块名: " .. mod_name .. "\n" ..
                      "物理路径: " .. path .. "\n\n" ..
                      "错误详情: " .. tostring(ret2) .. "\n\n" ..
                      "建议: 请检查文件是否存在，或尝试将插件包移动至不含特殊字符的路径。"
        reaper.MB(err_msg, "Fatal Error - 拾境 (YS_Archive)", 0)
        return nil
    end
    
    package.loaded[mod_name] = ret2
    return ret2
end

