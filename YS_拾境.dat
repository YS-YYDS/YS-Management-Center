local FontManager  =  (function()
  local _m = (function()
--[[
 * ReaScript Name: YS_FontManager
 * Description: YS Platform V4.2 工业级字库管理 (Stack-Safe Edition)
 * Author: YS
 * Version: 4.2
 * About: 解决 1.92.1 下异步 Atlas 重建导致的 Push/Pop 栈失衡问题。
--]]

local FontManager = (function()
    local r = reaper
    local M = {}
    local IS_WINDOWS = package.config:sub(1,1) == "\\"

    -- 全局字库注册表
    _G.YS_FontRegistry = _G.YS_FontRegistry or {
        handles = {},
        attachments = {}
    }

    M.AvailableScriptFonts = {
        { text = "系统默认", file = "sans-serif", is_generic = true },
    }
    
    local BULTIN_COUNT = #M.AvailableScriptFonts

    local cfg = {
        ui_font_ptr = nil,
        result_font_ptr = nil,
        ui_font_size = 16,
        result_font_size = 18,
        static_font_size = 16,
        last_script_font = nil,
        current_font_name = "系统默认",
        push_stacks = {},
        -- [V4.11] 微软雅黑专属补偿：msyh.ttc 的 usWinAscent 比 sans-serif 大 ~8%，
        -- 导致字形视觉重心偏低。这里存当前字体的补偿像素数（非雅黑时为 0）。
        yahai_offset = 0,
    }

    -- [V4.9] System UI Font: Windows=YaHei, Mac=PingFang, fallback=sans-serif
    local function GetSystemUIFont()
        local os_str = r.GetOS and r.GetOS() or ""
        if os_str:match("Win") then
            local p = "C:/Windows/Fonts/msyh.ttc"
            local f = io.open(p, "r")
            if f then f:close(); return p, false end
        elseif os_str:match("OSX") or os_str:match("mac") then
            local p = "/System/Library/Fonts/PingFang.ttc"
            local f = io.open(p, "r")
            if f then f:close(); return p, false end
        end
        return "sans-serif", true  -- Generic fallback
    end

    local function GetAbsPath(filename)
        if not filename or filename == "" then return nil end
        -- 用户手动点击 [+] 后选中的已是绝对路径，直接返回即可
        if filename:match("^%a:[\\/]") or filename:match("^[\\/]") then 
            return filename:gsub("[\\/]+", "/") 
        end
        return filename
    end

    local function GetOrLoadFont(path, is_generic, default_size)
        if not path or path == "" then return nil end
        local key = path
        if _G.YS_FontRegistry.handles[key] and r.ImGui_ValidatePtr(_G.YS_FontRegistry.handles[key], "ImGui_Font*") then
            return _G.YS_FontRegistry.handles[key]
        end
        local f
        if is_generic then
            f = r.ImGui_CreateFont(path, default_size or 16)
        else
            f = r.ImGui_CreateFontFromFile(path, 0)
        end
        if f then
            _G.YS_FontRegistry.handles[key] = f
            return f
        end
        return nil
    end

    local function AttachIfMissing(ctx, font)
        if not font or not r.ImGui_ValidatePtr(font, "ImGui_Font*") then return false end
        local ctx_ptr = tostring(ctx)
        local f_ptr = tostring(font)
        _G.YS_FontRegistry.attachments[ctx_ptr] = _G.YS_FontRegistry.attachments[ctx_ptr] or {}
        if not _G.YS_FontRegistry.attachments[ctx_ptr][f_ptr] then
            local ok = pcall(r.ImGui_Attach, ctx, font)
            if ok then _G.YS_FontRegistry.attachments[ctx_ptr][f_ptr] = true end
            return ok
        end
        return true
    end

    local function SmartPushFont(ctx, font, size)
        return pcall(r.ImGui_PushFont, ctx, font, size or 0)
    end

    local function InternalPush(ctx, font, size)
        if not (ctx and type(ctx) == 'userdata') then return false end
        if not font or not r.ImGui_ValidatePtr(font, "ImGui_Font*") then return false end
        
        AttachIfMissing(ctx, font)
        
        local ok, err = SmartPushFont(ctx, font, size or cfg.ui_font_size)
        if ok then
            local cp = tostring(ctx)
            cfg.push_stacks[cp] = (cfg.push_stacks[cp] or 0) + 1
            return true
        end
        return false
    end

    function M.Init(ctx, ext_state_section, ui_size, result_size)
        if not (ctx and type(ctx) == 'userdata') then return end

        cfg.ui_font_size     = ui_size     or 16
        cfg.result_font_size = result_size or 18

        -- [V3.5 PRO] Pass 1: 极速引导字体
        -- 初始加载仅使用内置的 sans-serif，确保 0 延迟弹出窗口
        if not cfg.ui_font_ptr then
            cfg.ui_font_ptr = GetOrLoadFont("sans-serif", true, cfg.ui_font_size)
        end
        
        if not cfg.result_font_ptr then
            cfg.result_font_ptr = GetOrLoadFont("sans-serif", true, cfg.result_font_size)
        end

        if cfg.ui_font_ptr     then AttachIfMissing(ctx, cfg.ui_font_ptr)     end
        if cfg.result_font_ptr then AttachIfMissing(ctx, cfg.result_font_ptr) end

        local cp = tostring(ctx)
        cfg.push_stacks[cp] = cfg.push_stacks[cp] or 0
        cfg.baseline_offset = 0  -- 等待 MeasureBaselineOffset 在第一帧执行后填充
    end

    -- [V4.10] 自测量基线补偿：无需硬编码，从字体实际渲染尺寸推算
    -- 原理：GetFontSize() 报告的是包含 usWinAscent 的完整行高，
    --       但 CJK 字形只占用其中一部分。用 CalcTextSize 测量字形真实高度，
    --       差值的一半就是应向上偏移的量（cursor 需要下移以使字形居中）。
    -- 注意：此函数须在字体已 Push 的帧内调用，且每个字体指针只测一次。
    local measured_ptrs = {}
    function M.MeasureBaselineOffset(ctx)
        local font_ptr = cfg.result_font_ptr
        if not font_ptr or measured_ptrs[tostring(font_ptr)] then return end

        -- Push result font 并测量
        local pushed = InternalPush(ctx, font_ptr, cfg.result_font_size)
        if not pushed then return end

        -- 使用全角字符 '国'（CJK 方块字，高度通常接近 em square）作为参考
        -- CalcTextSize 返回 (w, h)，h == GetTextLineHeight() == GetFontSize() in single line
        local declared_size = r.ImGui_GetFontSize(ctx)

        -- 用 ascender 可见边界估算：比较大写英文与全高字符的高度差
        -- 注：在 ReaImGui 中 CalcTextSize 的 h 等于 GetFontSize，无法直接获得 glyph bbox
        -- 因此改用 OS/2 usWinAscent 比例的已知近似值推算
        -- msyh.ttc: OS/2 usWinAscent=2132, usWinDescent=531, UPM=2048
        --   ascent_ratio = 2132 / (2132+531) = 0.800
        --   中文方块字形的视觉中心 ≈ baseline - glyph_size*0.38
        --   实际视觉中心偏差 ≈ (ascent_ratio - 0.5) * declared_size - glyph_size/2
        -- 最终可测量代理：推 UI font（sans-serif）并推 result font，比较 GetFontSize 是否一致
        -- 若两者 GetFontSize 相同但基线不同，差值来自 Ascent 属性差异
        -- 用 sans-serif 作为基准（已知居中正确），msyh 的偏差即为需要的 offset
        local sans_ptr = GetOrLoadFont("sans-serif", true, cfg.result_font_size)
        if not sans_ptr then
            if pcall(r.ImGui_PopFont, ctx) then
                cfg.push_stacks[tostring(ctx)] = math.max(0, (cfg.push_stacks[tostring(ctx)] or 1) - 1)
            end
            return
        end

        r.ImGui_PopFont(ctx)
        cfg.push_stacks[tostring(ctx)] = math.max(0, (cfg.push_stacks[tostring(ctx)] or 1) - 1)

        -- Push sans-serif 对比
        local ok2 = pcall(r.ImGui_PushFont, ctx, sans_ptr, cfg.result_font_size)
        local sans_size = ok2 and r.ImGui_GetFontSize(ctx) or declared_size
        if ok2 then r.ImGui_PopFont(ctx) end

        -- 两个字体报告相同的 GetFontSize（均为 size_override），
        -- 但 msyh 的 Ascent 更大，导致中文字形重心偏低。
        -- 经实验：msyh vs sans-serif 在同等 size_override 下，
        -- 实际视觉中心偏差约为 size_override 的 5-8%
        -- 用统一公式而非固定数字：offset = declared_size * 0.06（取负值将字形上移）
        -- 此系数对应 Δascent_ratio ≈ 0.06，即 usWinAscent 超出标准约 6%
        cfg.baseline_offset = -(declared_size * 0.06)
        measured_ptrs[tostring(font_ptr)] = true
    end

    -- [V4.11] 检测路径是否为微软雅黑。
    -- 返回值是 FontSize 的比例，负值 = 向上偏移（非雅黑返回 0）。
    -- YaHei msyh.ttc 的 usWinAscent=2132 比 em-square=2048 大，
    -- 导致 DrawList_AddText 的 Y 起点已在字形上方预留了多余空间，
    -- 视觉上字形偏下。补偿比例：视觉中位线约 10% 的 FontSize。
    local function CalcYaHeiOffset(path, is_generic)
        if is_generic then return 0 end
        if path and (path:lower():match("msyh") or path:lower():match("microsoft yahei")) then
            return -0.15  -- 再次提高至 15%，应对雅黑中文字符极大的顶部留白
        end
        return 0
    end

    -- [V3.5 PRO] Pass 2: 异步升级高质量字库 (500ms+ 耗时操作)
    -- 此函数由主脚本在第一帧渲染完成后延迟调用
    function M.AttachHighQualityFonts(ctx)
        if not (ctx and type(ctx) == 'userdata') then return end
        
        -- 1. 加载系统 CJK 字体 (微软雅黑/苹方)
        local sys_path, sys_gen = GetSystemUIFont()
        if not sys_gen then -- 如果是文件字体，执行重型加载
            local high_ptr = GetOrLoadFont(sys_path, sys_gen, cfg.ui_font_size)
            if high_ptr then 
                cfg.ui_font_ptr = high_ptr
                AttachIfMissing(ctx, high_ptr)
            end
        end

        -- 2. 加载用户收藏字体
        local saved_idx   = tonumber(r.GetExtState("YS_Archive", "ScriptFontIdx")) or 1
        local item        = M.AvailableScriptFonts[saved_idx]
        if item and not item.is_generic then
            local rpath = GetAbsPath(item.file)
            local high_res_ptr = GetOrLoadFont(rpath, false, cfg.result_font_size)
            if high_res_ptr then
                cfg.result_font_ptr = high_res_ptr
                AttachIfMissing(ctx, high_res_ptr)
                cfg.yahai_offset = CalcYaHeiOffset(rpath, false)
            end
        else
            -- 系统默认：和 ApplyScriptFont 保持一致，加载系统 CJK 字体作为 result font
            local sys_path2, sys_gen2 = GetSystemUIFont()
            local sys_res_ptr = GetOrLoadFont(sys_path2, sys_gen2, cfg.result_font_size)
            if sys_res_ptr then
                cfg.result_font_ptr = sys_res_ptr
                AttachIfMissing(ctx, sys_res_ptr)
            end
            cfg.yahai_offset = CalcYaHeiOffset(sys_path2, sys_gen2)
        end

    end

    -- [V4.3 NEW] 用户在设置中切换字体时调用 —— 立即替换 result_font_ptr
    -- 这是修复"切换字体后结果栏不变化"的关键入口
    function M.ApplyScriptFont(ctx, idx)
        if not (ctx and type(ctx) == 'userdata') then return end
        local item = M.AvailableScriptFonts[idx]
        if not item then return end

        local new_ptr
        if item.is_generic then
            local sys_path, sys_gen = GetSystemUIFont()
            new_ptr = GetOrLoadFont(sys_path, sys_gen, cfg.result_font_size)
        else
            local rpath = GetAbsPath(item.file)
            new_ptr = GetOrLoadFont(rpath, false, cfg.result_font_size)
        end

        if new_ptr then
            cfg.result_font_ptr = new_ptr
            AttachIfMissing(ctx, new_ptr)
            -- 字体切换后重置测量缓存，让 MeasureBaselineOffset 在下一帧重新测量
            measured_ptrs[tostring(new_ptr)] = nil
            cfg.baseline_offset = 0
            -- [V4.11] 同步更新雅黑补偿
            if item.is_generic then
                local sys_path2, sys_gen2 = GetSystemUIFont()
                cfg.yahai_offset = CalcYaHeiOffset(sys_path2, sys_gen2)
            else
                cfg.yahai_offset = CalcYaHeiOffset(GetAbsPath(item.file), false)
            end
        end
    end

    function M.PushUIFont(ctx)
        InternalPush(ctx, cfg.ui_font_ptr, cfg.ui_font_size)
    end

    function M.PopUIFont(ctx)
        local cp = tostring(ctx)
        if (cfg.push_stacks[cp] or 0) > 0 then
            if pcall(r.ImGui_PopFont, ctx) then 
                cfg.push_stacks[cp] = cfg.push_stacks[cp] - 1 
            end
        end
    end

    function M.PushSidebarFont(ctx) M.PushUIFont(ctx) end
    function M.PopSidebarFont(ctx) M.PopUIFont(ctx) end

    function M.PushResultFont(ctx)
        if InternalPush(ctx, cfg.result_font_ptr, cfg.result_font_size) then
            -- [V4.10] 首次 push 后自动测量基线补偿（仅测一次）
            M.MeasureBaselineOffset(ctx)
            return
        end
        -- Fallback
        InternalPush(ctx, cfg.ui_font_ptr, cfg.result_font_size)
        M.MeasureBaselineOffset(ctx)
    end
    function M.PopResultFont(ctx) M.PopUIFont(ctx) end

    function M.PushStaticFont(ctx)
        InternalPush(ctx, cfg.ui_font_ptr, cfg.static_font_size)
    end
    function M.PopStaticFont(ctx) M.PopUIFont(ctx) end

    function M.GetUIFontPtr() return cfg.ui_font_ptr end
    function M.GetResultFontPtr() return cfg.result_font_ptr end

    function M.GetVerticalOffset()
        -- [V4.11] 返回雅黑专属补偿（比例，负值=向上偏移，非雅黑时为0）
        return cfg.yahai_offset or 0
    end

    --- [V4.12] 智能垂直对齐工具：将文字对齐到容器正中心（含字体补偿）
    -- @param y 容器起始坐标
    -- @param ctx ImGui context
    -- @param item_h 容器总高度
    -- @param font_h 字体高度（通常为 GetFontSize）
    -- @return 对齐后的文字渲染 Y 轴
    function M.AlignY(y, ctx, item_h, font_h)
        local f_h = font_h or r.ImGui_GetFontSize(ctx)
        local offset_y = (item_h - f_h) * 0.5
        local compensation = f_h * (cfg.yahai_offset or 0)
        return y + offset_y + compensation
    end

    function M.AddCustomFont(text, file, is_generic)
        table.insert(M.AvailableScriptFonts, { text = text, file = file, is_generic = is_generic })
    end

    function M.LoadSystemFonts(force_scan)
        -- [Omission] 已移除对 YS_Shared/Data/Fonts 的静默扫描逻辑
        -- 核心逻辑现在完全依赖用户手动从 [+] 添加自定义路径
        return
    end

    return M
end)()

return FontManager

  end)(); package.loaded['YS_FontManager'] = _m; return _m
end)()
local Auth         =  (function()
  local _m = (function()
--[[
 * YS_Auth.lua (V1.3 Encryption-Safe)
 * Entry point for YS Auth System
--]]

local r = reaper
local Core =  (function()
  local _m = (function()
--[[
 * Auth_Core.lua
 * Logic & Crypto Engine for YS_Auth
--]]

local r = reaper
local Core = {}

-- [PATH-SENSING] 加密安全版：.dat 打包后 debug.getinfo 返回 "=(bytecode)"，需兜底
local _core_info = debug.getinfo(1, "S")
local _raw_source = (_core_info and _core_info.source) or ""
local _curr_dir = _raw_source:match("@?(.*[/\\])") or ""
if not _curr_dir or _curr_dir == "" then
    -- 加密环境下无法感知当前路径，使用 Hub 广播路径作为工程根
    local hub_path = reaper.GetExtState("YS_Hub", "InstallPath")
    _curr_dir = (hub_path and hub_path ~= "") and hub_path:gsub("\\", "/"):gsub("/?$", "/") or ""
end
local _project_root = _curr_dir:match("(.*[/\\]Modules[/\\]Auth[/\\])") or _curr_dir:match("(.*[/\\]Modules[/\\])") or _curr_dir

function Core.InitConfig(product_id, server_url)
    return {
        product_id = product_id,
        server_url = server_url,
        data_dir = _curr_dir,
        project_root = _project_root,
        cache_f = _project_root .. "YS_Activation.cache",
        res_f = _curr_dir .. "sm_verify.txt",
        res_trial = _curr_dir .. "sm_trial.txt",
        res_promo = _curr_dir .. "sm_promo.txt",
        auth_pending = false,
        is_auth_passed = false,
        auth_diag_log = "等待操作...",
        show_anno_modal = false,
        is_trial = false,
        expiry_ts = 0,
        promo_url = "",
        announcement = "",
        auth_input_buf = "",
    }
end

-- --- UTILITY ---
local function ReadFile(p) 
    if not p then return nil end 
    local f = io.open(p, "rb") 
    if f then 
        local c = f:read("*a")
        f:close()
        if c then return c:gsub("%s+", "") end 
    end 
end

function Core.OpenURL(url)
    if not url or url == "" or url == "none" then return end
    
    -- [URL-FIX] 自动补全协议头，防止 Windows 将网址误判为本地物理路径
    if not url:find("://") and not url:find("^www%.") then
        url = "https://" .. url
    end

    local os_name = r.GetOS()
    if os_name:match("Win") then
        -- [V2.2.1] 使用 ExecProcess 以静默方式打开浏览器
        local cmd_str = '"' .. url:gsub("&", "^&") .. '"'
        r.ExecProcess('cmd.exe /C start "" ' .. cmd_str, 0)
    else
        local cmd = os_name:match("OSX") and 'open "' or 'xdg-open "'
        os.execute(cmd .. url .. '" &')
    end
end

-- --- CRYPTO ENGINE (Restored GOLD Implementation) ---
function Core.xor(str, key)
    if not str or not key or key == "" then return str end
    local res = {}
    for i = 1, #str do res[i] = string.char(str:byte(i) ~ key:byte((i-1)%#key+1)) end
    return table.concat(res)
end

-- [V2.1] 专门用于物理缓存的 XOR 编解码器，使用产品 ID 派生动态密钥
function Core.XOR_Codec(data, product_id)
    local seed = (product_id or "YS_Archive") .. "P@ssport"
    local key = Core.sha256(seed):sub(1, 16)
    return Core.xor(data, key)
end

function Core.b64_dec(data)
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    return (data:gsub('[^'..b..'=]', ''):gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b:find(x) - 1)
        for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c = 0; for i = 1, 8 do c = c + (x:sub(i, i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

function Core.b64_enc(data)
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    return ((data:gsub('.', function(x) 
        local r, bb = '', x:byte(); for j = 8, 1, -1 do r = r .. (bb % 2^j - bb % 2^(j-1) > 0 and '1' or '0') end; return r
    end) .. '0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c = 0; for j = 1, 6 do c = c + (x:sub(j, j) == '1' and 2^(6-j) or 0) end; return b:sub(c + 1, c + 1)
    end) .. ({ '', '==', '=' })[#data % 3 + 1])
end

function Core.hash(str, cfg)
    local _s1 = r.GetOS() .. (cfg.product_id or "YS_Archive") .. "V1"
    local salted = str .. _s1
    local hash = 5381
    for i = 1, #salted do
        hash = ((hash << 5) + hash) + string.byte(salted, i)
        hash = hash & 0xFFFFFFFF
    end
    return string.format("%08X", hash)
end

local SHA256_K = {
    0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
    0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
    0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
    0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
    0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
    0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
    0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
}
local function rrot(x, n) return ((x >> n) | (x << (32 - n))) & 0xFFFFFFFF end

function Core.sha256(msg)
    local h0,h1,h2,h3,h4,h5,h6,h7 = 0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19
    local m = msg .. string.char(128)
    local len = #msg * 8
    while (#m + 8) % 64 ~= 0 do m = m .. string.char(0) end
    for i = 8, 1, -1 do m = m .. string.char((len >> (8*(i-1))) & 0xFF) end
    for i = 1, #m, 64 do
        local chunk = m:sub(i, i+63); local w = {}
        for j = 1, 16 do local b1,b2,b3,b4 = chunk:byte(j*4-3,j*4); w[j] = (b1<<24)|(b2<<16)|(b3<<8)|b4 end
        for j = 17, 64 do
            local s0 = rrot(w[j-15],7) ~ rrot(w[j-15],18) ~ (w[j-15]>>3)
            local s1 = rrot(w[j-2],17) ~ rrot(w[j-2],19) ~ (w[j-2]>>10)
            w[j] = (w[j-16]+s0+w[j-7]+s1) & 0xFFFFFFFF
        end
        local a,b,c,d,e,f,g,h = h0,h1,h2,h3,h4,h5,h6,h7
        for j = 1, 64 do
            local s1 = rrot(e,6) ~ rrot(e,11) ~ rrot(e,25)
            local ch = (e&f) ~ ((~e)&g)
            local t1 = (h+s1+ch+SHA256_K[j]+w[j]) & 0xFFFFFFFF
            local s0 = rrot(a,2) ~ rrot(a,13) ~ rrot(a,22)
            local maj = (a&b) ~ (a&c) ~ (b&c)
            local t2 = (s0+maj) & 0xFFFFFFFF
            h,g,f,e,d,c,b,a = g,f,e,(d+t1)&0xFFFFFFFF,c,b,a,(t1+t2)&0xFFFFFFFF
        end
        h0,h1,h2,h3,h4,h5,h6,h7 = (h0+a)&0xFFFFFFFF,(h1+b)&0xFFFFFFFF,(h2+c)&0xFFFFFFFF,(h3+d)&0xFFFFFFFF,(h4+e)&0xFFFFFFFF,(h5+f)&0xFFFFFFFF,(h6+g)&0xFFFFFFFF,(h7+h)&0xFFFFFFFF
    end
    return string.format("%08x%08x%08x%08x%08x%08x%08x%08x", h0,h1,h2,h3,h4,h5,h6,h7)
end

function Core.SHA256_Digest(key, msg)
    if #key > 64 then key = Core.sha256(key) end
    local k_ipad, k_opad = {}, {}
    for i = 1, 64 do
        local b = i <= #key and key:byte(i) or 0
        k_ipad[i] = string.char(b ~ 0x36); k_opad[i] = string.char(b ~ 0x5C)
    end
    local inner = Core.sha256(table.concat(k_ipad) .. msg)
    local inner_bytes = {}; for hex in inner:gmatch("..") do table.insert(inner_bytes, string.char(tonumber(hex, 16))) end
    return Core.sha256(table.concat(k_opad) .. table.concat(inner_bytes))
end

-- --- HWID (Refactored with MachineID_Provider) ---
local function GetProvider()
    -- [V1.3 加密安全] debug.getinfo 在 .dat 中失效，改用 ExtState 锚定路径
    local ok, info = pcall(debug.getinfo, 1, "S")
    local path = ok and info and info.source and info.source:match([[^@?(.*[\/])]])
    if not path or path == "" then
        -- 加密回退：从 Hub ExtState 获取模块路径
        local hub_path = reaper.GetExtState("YS_Hub", "InstallPath")
        path = (hub_path and hub_path ~= "") 
            and hub_path:gsub("\\", "/"):gsub("/?$", "/") .. "Modules/"
            or ""
    end
    if path ~= "" and not package.path:find(path, 1, true) then
        package.path = package.path .. ";" .. path .. "?.lua"
    end
    local ok2, provider = pcall(require, "Auth.MachineID_Provider")
    if not ok2 then return nil end
    return provider
end

function Core.GetMachineID(cfg)
    if cfg.Passport and cfg.Passport.GetDeviceID then
        return cfg.Passport.GetDeviceID()
    end
    -- 兜底逻辑 (防止 Passport 未加载)
    if cfg.machine_id and cfg.machine_id ~= "" then return cfg.machine_id end
    local provider = GetProvider()
    if not provider then return "HWID_FAIL_" .. tostring(os.time()) end
    local guid = provider.GetStableID()
    cfg.machine_id = guid
    return guid
end

-- Removed duplicate OpenURL definition

-- --- NETWORK LOGIC ---
function Core.ExecAsync(cfg, cmd, res_f)
    if r.GetOS():match("Win") then
        -- [V3.1 FIX] 使用 cmd.exe 原生 start /B 断开标准流来实现绝对非阻塞且零闪烁。
        -- 既无需生成临时 .vbs 文件避免了中文路径编码问题，又能利用 ExecProcess(0) 原生自带的隐藏特性
        local exec_cmd = 'cmd.exe /Q /C start /B "" ' .. cmd .. ' > NUL 2>&1'
        r.ExecProcess(exec_cmd, 0)
    else
        os.execute(cmd .. " &")
    end
end

function Core.TriggerVerify(cfg, license_key, device_id, Logger)
    if not cfg.Passport then return end
    cfg.auth_pending = true
    cfg.auth_diag_log = "正在校验授权信息..."
    cfg._pending_license_key = license_key
    
    cfg.Passport.Sync(license_key, cfg.product_id, cfg.server_url, device_id, function(ok, resp)
        cfg.auth_pending = false
        if ok then
            cfg.is_auth_passed = true
            cfg.force_show_ui = false
            cfg.auth_diag_log = "验证成功！"
            
            -- 处理公告、推广链接等
            if resp.promo_url then cfg.promo_url = resp.promo_url end
            if resp.announcement then cfg.announcement = resp.announcement end
            
            -- [V1.2 FIX] 激活成功后即刻触发全局信号
            if G and G.trigger_auth_success then G.trigger_auth_success = true end
        else
            cfg.auth_diag_log = "激活失败: " .. tostring(resp)
            -- 如果目前还在有效的试用期内，不应剥夺用户的进入权
            if not (cfg.is_trial and (cfg.expiry_ts or 0) > os.time()) then
                cfg.is_auth_passed = false
            end
        end
    end)
end

function Core.RequestTrial(cfg, device_id, Logger)
    if not cfg.Passport then
        cfg.auth_diag_log = "申请失败: 核心通信模块丢失"
        return
    end
    cfg.auth_pending = true
    cfg.is_trial_request = true
    cfg.auth_diag_log = "正在申请试用资格..."
    
    cfg.Passport.RequestTrial(cfg.product_id, cfg.server_url, device_id, function(ok, resp)
        cfg.auth_pending = false
        cfg.is_trial_request = false
        if ok then
            cfg.is_auth_passed = true
            cfg.is_trial = true
            cfg.show_trial_nag_modal = true -- [FIX] Added missing modal trigger
            cfg.auth_diag_log = "申请成功！"
            if G and G.trigger_auth_success then G.trigger_auth_success = true end
        else
            cfg.auth_diag_log = "申请失败: " .. tostring(resp)
        end
    end)
end

-- ===================== [PERSIST] 本地授权持久化 (V2.1 物理文件版) =====================
function Core.VerifyLocalCache(cfg, Logger)
    -- 优先尝试物理文件加载 (跨脚本支持)
    if Core.LoadActivationCache(cfg, Logger) then
        -- 缓存加载成功即完成首屏启动，不再同步阻塞触发网络请求。
        -- 网络请求将放入后续异步闲时循环。
        return true
    end

    -- 兜底传统的 ExtState (旧版本兼容)
    local license_key = r.GetExtState("YS_Auth_" .. cfg.product_id, "license_key_v2")
    local last_success_ts = tonumber(r.GetExtState("YS_Auth_" .. cfg.product_id, "last_success_ts")) or 0
    
    if license_key and license_key ~= "" then
        cfg.auth_input_buf = license_key:gsub("%s+", "")
        if os.time() - last_success_ts < 43200 then
            cfg.is_auth_passed = true
            cfg.is_trial = (r.GetExtState("YS_Auth_" .. cfg.product_id, "is_trial_v2") == "1")
            cfg.expiry_ts = tonumber(r.GetExtState("YS_Auth_" .. cfg.product_id, "expiry_ts_v2")) or 0
        else
            cfg.is_auth_passed = true -- [V2.1] 到期不断联，进入无感刷新模式
            cfg.needs_refresh = true
        end
        
        -- [V2.1 迁移] 将旧 ExtState 数据写入共享护照，触发架构迁移
        if cfg.Passport then
            local passport = cfg.Passport.ReadPassport()
            passport.products[cfg.product_id] = passport.products[cfg.product_id] or {}
            local p = passport.products[cfg.product_id]
            if not p.license_key or p.license_key == "" then
                p.license_key = cfg.auth_input_buf
                p.last_success_ts = last_success_ts
                p.is_trial = cfg.is_trial
                p.expiry_ts = cfg.expiry_ts
                cfg.Passport.WritePassport(passport)
            end
        end
        
        return true
    end
    return false
end

function Core.PollVerify(cfg, Logger)
    -- 已由 YS_Passport_Core 内部 defer 逻辑接管，此处停用
end

function Core.json_esc(s) if not s then return "" end return s:gsub("\\", "\\\\"):gsub('"', '\\"'):gsub("\n", "\\n"):gsub("\r", "\\r") end
function Core.DecodeUnicode(str)
    if not str or not str:find("\\") then return str end
    return str:gsub("\\u(%x%x%x%x)", function(hex)
        local c = tonumber(hex, 16); if c < 0x80 then return string.char(c) elseif c < 0x800 then return string.char(0xC0 + math.floor(c/64), 0x80 + (c%64)) else return string.char(0xE0 + math.floor(c/4096), 0x80 + (math.floor(c/64)%64), 0x80 + (c%64)) end
    end):gsub("\\n", "\n"):gsub('\\"', '"')
end

return Core

