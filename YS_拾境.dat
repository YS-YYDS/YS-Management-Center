            Passport =  (function()
  local _m = (function()
--[[
 * YS_Passport_Core.lua
 * ---------------------------------------------------------
 * [YS-Archetype] 全局授权大脑协议 (Shared Hub Engine)
 * Version: 1.2 (Industrial Standard)
 * ---------------------------------------------------------
 * 职责：
 * 1. 维护全局通行证 YS_Global_Passport.auth。
 * 2. 处理 12h 免检、24h 延迟触发宽限、7d 锁定逻辑。
 * 3. 实现与云端管理中心的一品一码同步。
--]]

local r = reaper
local Core = {}

-- [Constants]
Core.PASSPORT_VERSION = "1.2"
Core.SILENT_PERIOD = 43200             -- 12 小时免检
Core.GRACE_PERIOD  = 86400             -- 24 小时动态宽限
Core.LOCKDOWN_LIMIT = 604800           -- 7 天绝对联网红线
Core.AUTH_FILE = "YS_Global_Passport.auth"

-- [Paths] 确定全局共享目录 (锁定为 YS_管理中心)
local function GetSharedDir()
    -- [V2.1] 优先读取 Hub 写入的全局安装路径，确保加密打包后路径依然锚定
    local hub_path = r.GetExtState("YS_Hub", "InstallPath")
    if hub_path and hub_path ~= "" then
        return hub_path:gsub("\\", "/"):gsub("/?$", "/")
    end

    local _, script_file = r.get_action_context()
    local path = script_file:gsub("\\", "/"):match('^(.+[\\/])') or ""
    
    local hub_root = path:match("(.*[/\\]YS_脚本管理器[/\\])")
    if hub_root then return hub_root end
    
    -- [V3.0] 终极物理雷达 (自动向上寻根，解决开发者多级目录如 Released_Scripts 被阻断的问题)
    local check_dir = path
    for i=1, 3 do 
        if r.file_exists(check_dir .. "YS_脚本管理器/YS_Global_Passport.auth") then
            return check_dir .. "YS_脚本管理器/"
        end
        local up = check_dir:match("^(.*[/\\])[^/\\]+[/\\]?$")
        if not up or up == check_dir then break end
        check_dir = up
    end
    
    -- 标准安装路径兜底
    local parent_dir = path:match("^(.*[/\\])[^/\\]+[/\\]?$") or path
    return parent_dir .. "YS_脚本管理器/"
end
Core.GetSharedDir = GetSharedDir
Core.SHARED_DIR = GetSharedDir() -- 初始化共享目录静态属性


-- ===================== [HWID] 设备指纹 =====================

function Core.GetDeviceID()
    local cached = r.GetExtState("YS_Passport", "DeviceID")
    if cached and #cached >= 12 then return cached end
    
    -- 使用资源路径+系统作为基础生成稳定指纹
    local seed = r.GetResourcePath() .. r.GetOS() .. "YS_HWID_SALT"
    local id = Core.sha256(seed):sub(1, 12):upper() .. "-" .. Core.sha256(seed:reverse()):sub(1, 8):upper()
    
    r.SetExtState("YS_Passport", "DeviceID", id, true)
    return id
end
-- Core.SHARED_DIR = GetSharedDir() -- Removed static assignment

-- ===================== [Crypto] 基础加解密引擎 =====================

function Core.xor(str, key)
    if not str or not key or key == "" then return str end
    local res = {}
    for i = 1, #str do 
        res[i] = string.char(str:byte(i) ~ key:byte((i-1)%#key+1)) 
    end
    return table.concat(res)
end

function Core.GetXorKey()
    local os_str = r.GetOS()
    return Core.sha256(os_str .. "YS_Industrial_Salt_V2.1"):sub(1, 16)
end

-- ===================== [Crypto] 高级加解密 (LDK v2) =====================

local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
function Core.b64_dec(data)
    data = string.gsub(data, '[^'..b..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b:find(x) - 1)
        for i = 6, 1, -1 do r = r..(f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d%d%d%d%d%d', function(x)
        local c = 0
        for i = 1, 8 do c = c + (x:sub(i,i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end):gsub('%d+$', ''))
end

function Core.hmac_sha256(key, msg)
    -- 标准 HMAC-SHA256 实现 (RFC 2104)
    local block_size = 64
    if #key > block_size then
        key = Core.hex_to_bytes(Core.sha256(key))
    end
    while #key < block_size do
        key = key .. string.char(0)
    end
    
    local ipad = {}
    local opad = {}
    for i = 1, block_size do
        local k = key:byte(i)
        ipad[i] = string.char(k ~ 0x36)
        opad[i] = string.char(k ~ 0x5c)
    end
    
    local inner = Core.sha256(table.concat(ipad) .. msg)
    local outer = Core.sha256(table.concat(opad) .. Core.hex_to_bytes(inner))
    return outer
end

function Core.hex_to_bytes(hex)
    local res = {}
    for i = 1, #hex, 2 do
        res[(i+1)/2] = string.char(tonumber(hex:sub(i, i+1), 16))
    end
    return table.concat(res)
end

function Core.DecryptPayload(payload_b64, seed_key, device_id, product_id, is_trial)
    local raw = Core.b64_dec(payload_b64)
    local dev_short = device_id:sub(1, 8)
    
    -- [V3.4 FIX] 对齐服务器 derive_session_key: hmac_sha256(license, product)[:32]
    -- 然后 xor_salt = armor_key[:16]
    local dyn_armor_key = Core.hmac_sha256(seed_key or "", product_id)
    local xor_salt = dyn_armor_key:sub(1, 16)
    
    -- LDK v2 协议：xor_key = device_id[1:8] + xor_salt[1:16]
    local xor_key = dev_short .. xor_salt
    return Core.xor(raw, xor_key)
end

-- ===================== [IO] 通行证持久化流 =====================

--- 从磁盘读取全局通行证
function Core.ReadPassport()
    local path = Core.GetSharedDir() .. Core.AUTH_FILE
    local f = io.open(path, "rb")
    if not f then return { products = {} } end
    local encrypted = f:read("*a")
    f:close()
    if not encrypted or encrypted == "" then return { products = {} } end
    
    local decrypted = Core.xor(encrypted, Core.GetXorKey())
    local ok, data = pcall(function() return Core.JSON_Decode(decrypted) end)
    if ok and data and data.products then return data end
    return { products = {} }
end

--- 将通行证写入磁盘
function Core.WritePassport(data)
    if not data or not data.products then return end
    data.last_update_ts = os.time()
    data.client_version = Core.PASSPORT_VERSION
    
    local json_str = Core.JSON_Encode(data)
    local encrypted = Core.xor(json_str, Core.GetXorKey())
    
    local path = Core.GetSharedDir() .. Core.AUTH_FILE
    local f = io.open(path, "wb")
    if f then
        f:write(encrypted)
        f:close()
        return true
    end
    return false
end

-- ===================== [Debug] 日志助手 =====================
local function Log(msg)
    reaper.ShowConsoleMsg("[Passport] " .. os.date("%H:%M:%S") .. " | " .. tostring(msg) .. "\n")
end

-- ===================== [Logic] 核心状态裁决器 =====================

--- 路径 ANSI 硬化处理 (针对 cmd.exe)
-- 策略1: JS_ReaScriptAPI 提供真正的 UTF-8→ANSI 转换
-- 策略2: 降级到驱动器根目录 (J:\ys_net.dat)，根目录名称永远是 ASCII
--         不使用 %TEMP%：中国用户的 TEMP 路径常含中文用户名
local function ToANSI(path)
    if r.JS_String_UTF8toANSI then
        return r.JS_String_UTF8toANSI(path)
    end
    -- [V2.2] 回归原始：不再做硬编码降级，仅在 JS_API 存在时转换
    return path
end

--- 判断指定产品当前应当执行的状态
-- @param product_id 产品标识 (如 YS_Archive)
-- @return status, info
--   - STATUS_SILENT: 绝度静默 (12h内)
--   - STATUS_GRACE: 宽限期放行 (首次触发24h内)
--   - STATUS_SYNC_FIRST: 联网对账优先 (宽限期过后)
--   - STATUS_LOCKDOWN: 锁定 (7天后)
function Core.CheckStatus(product_id)
    local passport = Core.ReadPassport()
    local p = passport.products[product_id]
    local now = os.time()
    
    -- 如果从未激活且没有试用记录
    if not p then return "STATUS_LOCKDOWN", "未激活" end
    
    local last_success = tonumber(p.last_success_ts) or 0
    local grace_start  = tonumber(p.grace_start_ts) or 0
    local expiry_ts    = tonumber(p.expiry_ts) or 0
    
    -- 0. 防时钟回拨验证
    if now < last_success - 3600 then
        return "STATUS_SYNC_FIRST", "系统时钟异常"
    end
    
    -- 1. 物理过期判断 (具有最高优先级)
    if expiry_ts > 0 and now > expiry_ts then
        return "STATUS_LOCKDOWN", "授权已过期"
    end

    -- 2. 阶段 A: 12h 绝对静默期
    if now - last_success <= Core.SILENT_PERIOD then
        return "STATUS_SILENT", "免检期内"
    end
    
    -- 3. 阶段 B/C: 离线容灾逻辑
    if grace_start == 0 then
        -- 尚未触发宽限，触发首开 1h 记录
        p.grace_start_ts = now
        Core.WritePassport(passport)
        return "STATUS_GRACE", "首次触发宽限(24h内信号)"
    end
    
    -- 判断宽限是否在有效期内
    if now - grace_start <= Core.GRACE_PERIOD then
        return "STATUS_GRACE", "宽限中"
    end
    
    -- 4. 阶段 D: 绝对红线 (7天)
    if now - last_success > Core.LOCKDOWN_LIMIT then
        return "STATUS_LOCKDOWN", "离线时长超过7天，必须联网"
    end
    
    -- 5. 其他情况：宽限已过期，进入对账优先模式
    return "STATUS_SYNC_FIRST", "通过联网对账以刷新授权"
end

-- ===================== [Network] 同步逻辑 =====================

--- 异步对账并更新全家桶 (Multi-Product Update)
function Core.Sync(key, product_id, server_url, device_id, callback)
    local res_f = Core.SHARED_DIR .. "sync_res.txt"
    local f_old = io.open(res_f, "r")
    if f_old then f_old:close(); os.remove(res_f) end
    
    local url = server_url .. "/verify"
    local json_body = string.format('{"license_key":"%s","device_id":"%s","product_id":"%s","version":"2.0"}', key, device_id, product_id)
    local json_file = Core.SHARED_DIR .. "sync_req.json"
    
    local f = io.open(json_file, "w")
    if f then f:write(json_body); f:close() else return false end
    
    local is_win = r.GetOS():match("Win")
    Log("Sync Start | Product: " .. product_id)
    Log("Payload: " .. json_body)
    
    if is_win then
        local win_dir = Core.SHARED_DIR:gsub("/", "\\")
        local vbs_path = win_dir .. "ys_sync.vbs"
        local vbs = 'Set W=CreateObject("WScript.Shell")\n'
            .. 'Set F=CreateObject("Scripting.FileSystemObject")\n'
            .. 'W.CurrentDirectory=F.GetParentFolderName(WScript.ScriptFullName)\n'
            .. string.format('W.Run "cmd.exe /c curl -s -k --connect-timeout 8 -X POST -H ""Content-Type: application/json"" -d @""sync_req.json"" ""%s"" -o ""sync_res.txt""",0,True\n', url)
            .. 'On Error Resume Next:F.DeleteFile "sync_req.json":F.DeleteFile WScript.ScriptFullName\n'
        
        Log("VBS Path: " .. vbs_path)
        Log("VBS Content:\n" .. vbs)
        
        local vf = io.open(vbs_path, "w")
        if vf then vf:write(vbs); vf:close() else Log("Error: Failed to write VBS file!") end
        
        local cmd_line = 'wscript.exe //B "' .. vbs_path .. '"'
        local ansi_cmd = ToANSI(cmd_line)
        Log("ExecProcess: " .. ansi_cmd)
        r.ExecProcess(ansi_cmd, -1) -- [V130-FIX] 改为 -1 (异步执行)，避免阻塞 REAPER 主线程导致 UI 卡顿
    else
        local cmd = string.format('curl -s -k -X POST -H "Content-Type: application/json" -d @%s "%s" -o %s &',
            '"'..json_file..'"', url, '"'..res_f..'"')
        Log("Execute: " .. cmd)
        os.execute(cmd)
    end

    
    -- 定时检测返回结果 (通过 defer 链)
    local start_t = r.time_precise()
    local function poll()
        local rf = io.open(res_f, "rb")
        local content = ""
        if rf then 
            content = rf:read("*a")
            rf:close() 
            Log("Poll: Result file found, length: " .. #content)
            if not content:find("^%s*{") then
                Log("Warning: Content is NOT a valid JSON! Raw content: " .. content)
            end
        end
        
        if content and content:find("^%s*{") then
            os.remove(res_f)
            os.remove(json_file)
            
            -- [V130] 处理 LDK v2 加密荷载 (pcall 保护)
            if content:find('"payload"') then
                local ok_pre, pre = pcall(function() return Core.JSON_Decode(content) end)
                if ok_pre and pre and pre.payload then
                    content = Core.DecryptPayload(pre.payload, key, device_id, product_id, false)
                end
            end

            local ok, resp = pcall(function() return Core.JSON_Decode(content) end)
            
            -- [V130-FIX] Regex Fallback if standard JSON mapping fails due to trailing garbage
            if not resp and content then
                local stat = content:match('"status"%s*:%s*"([^"]+)"')
                local lkey = content:match('"license_key"%s*:%s*"([^"]+)"')
                if stat or lkey then
                    resp = { status = stat, license_key = lkey }
                    ok = true
                end
            end
            
            if ok and resp and resp.status == "success" then
                Core.UpdateProductsFromResponse(resp, product_id, key)
                if callback then callback(true, resp) end
            else
                if callback then callback(false, resp or "Decode Fail") end
            end
            return
        end
        
        if r.time_precise() - start_t > 15 then -- 15s 超时
            if callback then callback(false, "Timeout") end
            return
        end
        r.defer(poll)
    end
    r.defer(poll)
end

--- 申请试用资格
function Core.RequestTrial(product_id, server_url, device_id, callback)
    local res_f = Core.SHARED_DIR .. "trial_res.txt"
    local f_old = io.open(res_f, "r")
    if f_old then f_old:close(); os.remove(res_f) end
    
    local url = server_url .. "/api/request_trial"
    -- [V2.2 FIX] 试用接口参数必须为 hardware_id (副本 1.1-GOLD 版验证)
    local json_body = string.format('{"product_id":"%s","hardware_id":"%s"}', product_id, device_id)
    local json_file = Core.SHARED_DIR .. "trial_req.json"
    
    local f = io.open(json_file, "w")
    if f then f:write(json_body); f:close() else return false end
    
    local is_win = r.GetOS():match("Win")
    Log("Trial Request Start | Product: " .. product_id)
    Log("Payload: " .. json_body)
    
    if is_win then
        local win_dir = Core.SHARED_DIR:gsub("/", "\\")
        local vbs_path = win_dir .. "ys_trial.vbs"
        local vbs = 'Set W=CreateObject("WScript.Shell")\n'
            .. 'Set F=CreateObject("Scripting.FileSystemObject")\n'
            .. 'W.CurrentDirectory=F.GetParentFolderName(WScript.ScriptFullName)\n'
            .. string.format('W.Run "cmd.exe /c curl -s -k --connect-timeout 8 -X POST -H ""Content-Type: application/json"" -d @""trial_req.json"" ""%s"" -o ""trial_res.txt""",0,True\n', url)
            .. 'On Error Resume Next:F.DeleteFile "trial_req.json":F.DeleteFile WScript.ScriptFullName\n'
        
        Log("VBS Path: " .. vbs_path)
        Log("VBS Content:\n" .. vbs)
        
        local vf = io.open(vbs_path, "w")
        if vf then vf:write(vbs); vf:close() else Log("Error: Failed to write VBS file!") end
        
        local cmd_line = 'wscript.exe //B "' .. vbs_path .. '"'
        local ansi_cmd = ToANSI(cmd_line)
        Log("ExecProcess: " .. ansi_cmd)
        r.ExecProcess(ansi_cmd, -1) -- [V130-FIX] 改为 -1 (异步执行)，避免阻塞 REAPER 主线程导致 UI 卡顿
    else
        local cmd = string.format('curl -s -k -X POST -H "Content-Type: application/json" -d @%s "%s" -o %s &',
            '"'..json_file..'"', url, '"'..res_f..'"')
        Log("Execute: " .. cmd)
        os.execute(cmd)
    end

    
    local start_t = r.time_precise()
    local function poll()
        local rf = io.open(res_f, "rb")
        local content = ""
        if rf then 
            content = rf:read("*a")
            rf:close() 
            Log("Poll: Result file found, length: " .. #content)
            if not content:find("^%s*{") then
                Log("Warning: Content is NOT a valid JSON! Raw content: " .. content)
            end
        end
        
        if content and content:find("^%s*{") then
            Log("JSON Header matched! Processing...")
            os.remove(res_f)
            os.remove(json_file)
            
            if content:find('"payload"') then
                Log("Encrypted payload detected. Decrypting...")
                local ok_pre, pre = pcall(function() return Core.JSON_Decode(content) end)
                if ok_pre and pre.payload then
                    content = Core.DecryptPayload(pre.payload, device_id, device_id, product_id, true)
                    Log("Decrypted length: " .. (content and #content or "nil"))
                    if content and #content > 0 then
                        Log("Decrypted Preview (Hex): " .. (content:sub(1,16):gsub(".", function(c) return string.format("%02X ", c:byte()) end)))
                        Log("Decrypted Preview (Text): " .. content:sub(1,32):gsub("[%c]", "."))
                    end
                else
                    Log("Error: Failed to decode pre-payload JSON")
                end
            end

            local ok, resp = pcall(function() return Core.JSON_Decode(content) end)
            
            -- [V130-FIX] Regex Fallback protection
            if not resp and content then
                local stat = content:match('"status"%s*:%s*"([^"]+)"')
                local lkey = content:match('"license_key"%s*:%s*"([^"]+)"')
                if stat or lkey then
                    resp = { status = stat, license_key = lkey }
                    ok = true
                end
            end
            
            -- [V130-FIX] 兼容性：如果 resp 包含 license_key 但没 status，也视为成功
            local is_success = ok and resp and (resp.status == "success" or (resp.license_key and resp.license_key ~= ""))
            
            if is_success then
                local new_key = resp.license_key
                Log("Request Success! Trial key: " .. (new_key or "nil"))
                -- [GOLD-PARITY] 试用成功后立即用新 key 发起正式 Verify，绑定设备并激活计时
                if new_key and new_key ~= "" then
                    Log("Auto-triggering Sync to bind device...")
                    Core.Sync(new_key, product_id, server_url, device_id, function(sync_ok, sync_resp)
                        Log("Auto-Sync result: " .. tostring(sync_ok))
                        if callback then callback(sync_ok, sync_resp) end
                    end)
                else
                    -- 没有 key 时降级保存
                    Core.UpdateProductsFromResponse(resp, product_id, "TRIAL_KEY")
                    if callback then
                        Log("Triggering Success Callback (no key)")
                        callback(true, resp)
                    end
                end
            else
                local err_dump = (type(resp)=="table") and Core.JSON_Encode(resp) or tostring(resp)
                Log("Request Failed! Server resp: " .. err_dump)
                if not ok then Log("Decode error: " .. tostring(resp)) end
                if callback then 
                    Log("Triggering Failure Callback")
                    callback(false, resp or "Trial Fail") 
                end
            end
            return
        else
            if content ~= "" then
                Log("Warning: Content ignored (no JSON header). Content: " .. content:sub(1,100))
            end
        end
        
        if r.time_precise() - start_t > 15 then
            if callback then callback(false, "Timeout") end
            return
        end
        r.defer(poll)
    end
    r.defer(poll)
end

--- 根据服务器返回解析全家桶并入库
function Core.UpdateProductsFromResponse(resp, main_pid, req_key)
    local passport = Core.ReadPassport()
    local now = os.time()
    
    -- 情况 1: 旧接口，仅返回单个产品的详细信息
    local pids = { main_pid }
    -- 情况 2: 支持解析返回包中的 products 字典 (全家桶模式)
    if resp.products and type(resp.products) == "table" then
        pids = {}
        for pid, _ in pairs(resp.products) do table.insert(pids, pid) end
    end

    for _, pid in ipairs(pids) do
        passport.products[pid] = passport.products[pid] or {}
        local p = passport.products[pid]
        
        p.last_success_ts = now
        p.grace_start_ts  = 0 -- 重置宽限时钟
        p.license_key     = req_key or p.license_key -- 补存激活码，供 BackgroundRefresh 使用
        
        -- 优先使用子产品内的过期时间，如果没有则使用顶层过期时间 (Bundle)
        local prod_data = resp.products and resp.products[pid]
        p.expiry_ts       = (prod_data and prod_data.expiry_ts) or resp.expiry_ts or 0
        p.is_trial        = (prod_data and prod_data.is_trial ~= nil and prod_data.is_trial) or resp.is_trial or false
        
        -- 保存最新的消息/推广 (按需)
        passport.last_promo_url = resp.promo_url or passport.last_promo_url
        passport.last_announcement = resp.announcement or passport.last_announcement
    end
    
    Core.WritePassport(passport)
end

-- ===================== [JSON] Minimalist Parser =====================

function Core.JSON_Decode(s)
    if not s or s == "" then return nil end
    s = s:gsub("^\239\187\191", "") -- 移除 BOM
    local pos = 1
    
    local function skip_ws()
        -- [V130-FIX] 增强空白跳过，过滤掉所有控制字符 (0-31) 以及标准空白
        while pos <= #s do
            local c = s:byte(pos)
            if c and c <= 32 then
                pos = pos + 1
            else
                break
            end
        end
    end
    
    local parse_val -- 预声明
    
    local function parse_str()
        local res = ""
        pos = pos + 1 -- 跳过起始引号
        while pos <= #s do
            local c = s:sub(pos, pos)
            if c == '"' then pos = pos + 1; return res end
            if c == "\\" then
                local next_c = s:sub(pos+1, pos+1)
                if next_c == '"' or next_c == "\\" or next_c == "/" then res = res .. next_c
                elseif next_c == "n" then res = res .. "\n"
                elseif next_c == "r" then res = res .. "\r"
                elseif next_c == "t" then res = res .. "\t"
                end
                pos = pos + 2
            else
                res = res .. c
                pos = pos + 1
            end
        end
        return res
    end
    
    local function parse_arr()
        local res = {}
        pos = pos + 1 -- 跳过 [
        skip_ws()
        if s:sub(pos, pos) == "]" then pos = pos + 1; return res end
        while pos <= #s do
            table.insert(res, parse_val())
            skip_ws()
            local c = s:sub(pos, pos)
            if c == "]" then pos = pos + 1; return res end
            if c == "," then pos = pos + 1; skip_ws() end
        end
    end
    
    local function parse_obj()
        local res = {}
        pos = pos + 1 -- 跳过 {
        skip_ws()
        if s:sub(pos, pos) == "}" then pos = pos + 1; return res end
        while pos <= #s do
            local key = parse_val()
            if key == nil then break end -- 遇到无效键或 EOF 时终止并返回已解析的部分，防 crash
            
            skip_ws()
            if s:sub(pos, pos) == "=" or s:sub(pos, pos) == ":" then pos = pos + 1; skip_ws() end
            res[key] = parse_val()
            skip_ws()
            local c = s:sub(pos, pos)
            if c == "}" then pos = pos + 1; return res end
            if c == "," then pos = pos + 1; skip_ws() end
        end
        return res
    end
    
    parse_val = function()
        skip_ws()
        local c = s:sub(pos, pos)
        if c == '"' then return parse_str()
        elseif c == "{" then return parse_obj()
        elseif c == "[" then return parse_arr()
        elseif s:find("^true", pos)  then pos = pos + 4; return true
        elseif s:find("^false", pos) then pos = pos + 5; return false
        elseif s:find("^null", pos)  then pos = pos + 4; return nil
        else
            local n = s:match("^[%d%.%-eE]+", pos)
            if n then pos = pos + #n; return tonumber(n) end
        end
    end
    
    local status, result = pcall(parse_val)
    if not status then
        if r.ShowConsoleMsg then r.ShowConsoleMsg("[YS JSON Error] " .. tostring(result) .. "\n") end
        return nil 
    end
    return result
end

function Core.JSON_Encode(val)
    local function _ser(v)
        local t = type(v)
        if t == "table" then
            -- 判断是否为数组 (简单检测 #t > 0 且 pairs 数量一致)
            local is_arr = #v > 0
            if is_arr then
                local count = 0
                for _ in pairs(v) do count = count + 1 end
                if count ~= #v then is_arr = false end
            end
            
            if is_arr then
                local res = {"["}
                for i = 1, #v do
                    if i > 1 then table.insert(res, ",") end
                    table.insert(res, _ser(v[i]))
                end
                table.insert(res, "]")
                return table.concat(res)
            else
                local res = {"{"}
                local first = true
                for k, v2 in pairs(v) do
                    if not first then table.insert(res, ",") end
                    table.insert(res, string.format("%q:%s", tostring(k), _ser(v2)))
                    first = false
                end
                table.insert(res, "}")
                return table.concat(res)
            end
        elseif t == "string" then return string.format("%q", v)
        elseif t == "number" or t == "boolean" then return tostring(v)
        elseif t == "nil" then return "null"
        end
        return "null"
    end
    return _ser(val)
end

-- ===================== [Crypto] 核心算法支持 (SHA256 Master) =====================

local SHA256_K = {
    0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
    0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
    0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
    0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
    0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
    0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
    0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
}
local function rrot(x, n) return ((x >> n) | (x << (32 - n))) & 0xFFFFFFFF end

function Core.sha256(msg)
    local h0,h1,h2,h3,h4,h5,h6,h7 = 0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19
    local m = msg .. string.char(128)
    local len = #msg * 8
    while (#m + 8) % 64 ~= 0 do m = m .. string.char(0) end
    for i = 8, 1, -1 do m = m .. string.char((len >> (8*(i-1))) & 0xFF) end
    for i = 1, #m, 64 do
        local chunk = m:sub(i, i+63); local w = {}
        for j = 1, 16 do local b1,b2,b3,b4 = chunk:byte(j*4-3,j*4); w[j] = (b1<<24)|(b2<<16)|(b3<<8)|b4 end
        for j = 17, 64 do
            local s0 = rrot(w[j-15],7) ~ rrot(w[j-15],18) ~ (w[j-15]>>3)
            local s1 = rrot(w[j-2],17) ~ rrot(w[j-2],19) ~ (w[j-2]>>10)
            w[j] = (w[j-16]+s0+w[j-7]+s1) & 0xFFFFFFFF
        end
        local a,b,c,d,e,f,g,h = h0,h1,h2,h3,h4,h5,h6,h7
        for j = 1, 64 do
            local s1 = rrot(e,6) ~ rrot(e,11) ~ rrot(e,25)
            local ch = (e&f) ~ ((~e)&g)
            local t1 = (h+s1+ch+SHA256_K[j]+w[j]) & 0xFFFFFFFF
            local s0 = rrot(a,2) ~ rrot(a,13) ~ rrot(a,22)
            local maj = (a&b) ~ (a&c) ~ (b&c)
            local t2 = (s0+maj) & 0xFFFFFFFF
            h,g,f,e,d,c,b,a = g,f,e,(d+t1)&0xFFFFFFFF,c,b,a,(t1+t2)&0xFFFFFFFF
        end
        h0,h1,h2,h3,h4,h5,h6,h7 = (h0+a)&0xFFFFFFFF,(h1+b)&0xFFFFFFFF,(h2+c)&0xFFFFFFFF,(h3+d)&0xFFFFFFFF,(h4+e)&0xFFFFFFFF,(h5+f)&0xFFFFFFFF,(h6+g)&0xFFFFFFFF,(h7+h)&0xFFFFFFFF
    end
    return string.format("%08x%08x%08x%08x%08x%08x%08x%08x", h0,h1,h2,h3,h4,h5,h6,h7)
end

return Core

  end)(); package.loaded['YS_Passport_Core'] = _m; return _m
end)()
        end)
        if not ok or not Passport then
            reaper.ShowConsoleMsg("[Auth] ERROR: Passport Core not found!\n")
            -- 兜底: Hub 未启动 / Passport 丢失时，给出明确提示，不崩溃
            r.ShowMessageBox(
                "授权核心加载失败，请先启动 YS 脚本管理器后再运行此脚本。\n\n由于离线保护极致被触发，在首次关联前需通过授权验证。",
                "YS Auth 保护", 0
            )
            return
        end
        reaper.ShowConsoleMsg("[Auth] Passport loaded from: " .. tostring(Passport.SHARED_DIR) .. "\n")
        cfg.Passport = Passport
        cfg.lib_path = lib_path
        cfg.product_id = product_id
        cfg.server_url = server_url
        cfg.product_name = product_name
        cfg.F = fonts
        
        -- Induct Logger
        if package.loaded["Archive_Logger"] then Logger = package.loaded["Archive_Logger"] end
        
        -- 获取设备 ID
        cfg.machine_id = Core.GetMachineID(cfg)
        cfg.initialized = true
        if Logger then Logger.debug("Auth", "Initialized (V1.3 Engine) for " .. product_name) end
    end

    function M.BootstrapChecks()
        if not cfg.Passport then return end
        local status, info = cfg.Passport.CheckStatus(cfg.product_id)
        if Logger then Logger.debug("Auth", "Bootstrap Status: " .. status .. " (" .. info .. ")") end
        
        -- [V1.2] 更新当前内存状态
        local passport = cfg.Passport.ReadPassport()
        local p = passport.products[cfg.product_id]
        if p then
            cfg.expiry_ts = p.expiry_ts or 0
            cfg.is_trial = p.is_trial or false
            cfg.promo_url = passport.last_promo_url or ""
            cfg.announcement = passport.last_announcement or ""
        end
        
        -- 根据状态决定是否放行
        if status == "STATUS_SILENT" or status == "STATUS_GRACE" then
            cfg.is_auth_passed = true
        else
            cfg.is_auth_passed = false
        end
    end
    
    function M.BackgroundRefresh()
        if not cfg.Passport then return end
        -- [V1.2] 从护照中检索已存储的 Key 以进行静默对账
        local passport = cfg.Passport.ReadPassport()
        local p_data = passport.products and passport.products[cfg.product_id]
        local stored_key = (p_data and p_data.license_key) or ""
        
        -- 如果没有激活码，则不发起同步
        if stored_key == "" then 
            cfg.auth_pending = false -- release lock
            return 
        end

        cfg.Passport.Sync(stored_key, cfg.product_id, cfg.server_url, cfg.machine_id, function(success, resp)
            cfg.auth_pending = false -- 无论成功失败，必须释放锁
            if success then
                M.BootstrapChecks() -- 同步后重新核对状态
                if Logger then Logger.info("Auth", "Background Sync Success") end
            end
        end)
        cfg.last_session_refresh = os.time()
    end

    function M.SetSpareKey(url)
        cfg.spare_url = url
    end

    function M.IsAuthorized(force_verify)
        if not cfg.initialized or not cfg.Passport then return false end
        
        -- 1. 实时获取状态
        local status, info = cfg.Passport.CheckStatus(cfg.product_id)
        
        -- [Sync-First Logic] 联网优先逻辑
        -- 如果处于待对账状态 (STATUS_SYNC_FIRST)，先尝试静默对账
        if status == "STATUS_SYNC_FIRST" and not cfg.auth_pending then
            M.BackgroundRefresh()
            cfg.auth_pending = true -- 临时标记，防止重复触发
        end

        -- 2. 状态放行规则
        if status == "STATUS_SILENT" or status == "STATUS_GRACE" then
            cfg.is_auth_passed = true
        else
            cfg.is_auth_passed = false
        end
        
        -- 强制 UI 标志位
        if cfg.force_show_ui or cfg.show_anno_modal then return false end
        if cfg.is_auth_passed and not cfg.session_nag_done and cfg.is_trial then return false end

        return cfg.is_auth_passed
    end

    function M.DrawAuthUI(ctx)
        if not cfg.initialized then return false end 
        -- [V1.3] 数据已由 Passport 同步，无需独立轮询

        -- [V2.1] 定时静默刷新逻辑 (从护照读取 key，兼容加密打包)
        if cfg.is_auth_passed and os.time() - (cfg.last_session_refresh or 0) > 3600 then
            cfg.last_session_refresh = os.time()
            -- [FIX] 不使用 UI buf，从护照读取已存储的 license_key
            if cfg.Passport then
                local ps = cfg.Passport.ReadPassport()
                local stored_key = ps.products and ps.products[cfg.product_id] and ps.products[cfg.product_id].license_key or ""
                if stored_key ~= "" then
                    Core.TriggerVerify(cfg, stored_key, cfg.machine_id, Logger)
                end
            end
        end
        
        -- 2. 公告弹窗 (优先级高)
        if cfg.show_anno_modal then
            if UI.DrawAnnouncement then UI.DrawAnnouncement(ctx, cfg, Core) end
            return false
        end

        -- 3. 试用提醒 (仅在进入主界面前弹出一次)
        if cfg.is_auth_passed and not cfg.session_nag_done and cfg.is_trial then
            cfg.show_trial_nag_modal = true
            UI.DrawAuthUI(ctx, cfg, M, Core, Logger)
            if not cfg.show_trial_nag_modal then cfg.session_nag_done = true end
            return false
        end

        -- 4. 授权中心 (未授权或强制开启时)
        if not cfg.is_auth_passed or cfg.force_show_ui then
            return UI.DrawAuthUI(ctx, cfg, M, Core, Logger)
        end

        return true
    end

    function M.ShouldExit()
        return cfg.force_exit == true
    end

    function M.GetVersion() return "1.3.0-PRO" end
    function M.GetIndustrialDNA() return "[YS_Industrial] DNA-SOLID" end

    return M
end)()

return Auth

  end)(); package.loaded['YS_Auth'] = _m; return _m
end)()
local Helper       =  (function()
  local _m = (function()
--[[
  * ReaScript Name: Archive_UI_Helper.lua
  * About: Settings panel and Modal UI registry for YS_Archive.
  * Author: YS
  * License: GPL v3
  * Version: 2.0
  * REAPER: 7.0+
  * Extensions: None
--]]

--- ZONE: LIBS ---
local r = reaper
local math = math
local os = os
local string = string

local Helper = {}
local M = Helper -- Alias for internal component usage
local PRODUCT_ID = "YS_Archive"

--- ZONE: DEPENDENCIES (Injected) ---
local G, Icons, Theme, Auth, Eng, PEng, FontManager, GUI, lib_path_ref, State, Utils, Logger

function Helper.Init(g, icons, theme, auth, eng, p_eng, fm, gui, lp, state, u, logger)
    G = g; Icons = icons; Theme = theme; Auth = auth; Eng = eng; PEng = p_eng; FontManager = fm; GUI = gui; lib_path_ref = lp; State = state; Utils = u; Logger = logger
end

--- Internal: Helper for rendering uniform settings rows (Unified V3.0)
--- [EXPORT V7.1] 支持跨模块调用的标准化对齐排版
function M.DrawSettingRow(ctx, label, US, L, widget_func, custom_x_offset)
    local _L = L or (GUI and GUI.LayoutHelper(ctx, US))
    if _L then _L.Text(label) else r.ImGui_Text(ctx, label) end
    
    local offset = custom_x_offset or (200 * US)
    r.ImGui_SameLine(ctx, r.ImGui_GetWindowWidth(ctx) - offset)
    widget_func()
    
    if _L then _L.Spacing(4) else r.ImGui_Spacing(ctx) end
end

--- ZONE: COMPONENTS ---

--- [Fragment] 工业数值微调器 (Stepper)
function M.DrawValueStepper(ctx, label, val, min, max, w_total, config)
    local changed = false
    local new_val = val
    local ui_scale = config.UI_SCALE or 1
    local btn_w = (config.btn_w or 40) * ui_scale
    local ctrl_h = (config.ctrl_h or 34) * ui_scale
    local lcd_w = (w_total or 80 * ui_scale) - (btn_w * 2) - (8 * ui_scale)
    
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_FrameRounding(), 6.0)
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_ChildRounding(), 6.0)
    
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), 0x333333FF) -- Darker button
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Text(), 0xFFFFFFFF)    -- White text for visibility
    if r.ImGui_Button(ctx, "-##dec_"..label, btn_w, ctrl_h) then
        if val > min then new_val = val - 1; changed = true end
    end
    r.ImGui_SameLine(ctx)
    
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_ChildBg(), Theme.COLORS.input_bg)
    if r.ImGui_BeginChild(ctx, "lcd_"..label, lcd_w, ctrl_h, 1) then
        local h_dl = r.ImGui_GetWindowDrawList(ctx)
        local hx1, hy1 = r.ImGui_GetCursorScreenPos(ctx)
        r.ImGui_DrawList_AddLine(h_dl, hx1, hy1, hx1 + lcd_w, hy1, Theme.COLORS.sep_hi, 1.0)
        
        local txt = config.is_pct and string.format("%d%%", math.floor((val / 16) * 100)) or tostring(val)
        local tw, th = r.ImGui_CalcTextSize(ctx, txt)
        r.ImGui_SetCursorPos(ctx, (lcd_w - tw) * 0.5, (ctrl_h - th) * 0.5)
        r.ImGui_Text(ctx, txt)
        r.ImGui_EndChild(ctx)
    end
    r.ImGui_PopStyleColor(ctx)
    r.ImGui_SameLine(ctx)
    
    if r.ImGui_Button(ctx, "+##inc_"..label, btn_w, ctrl_h) then
        if val < max then new_val = val + 1; changed = true end
    end
    r.ImGui_PopStyleColor(ctx, 2) -- Pop Button, Text

    r.ImGui_PopStyleVar(ctx, 2)
    
    return changed, new_val
end

--- [Component] 工业级滑动调节器 (V13.8 Slider with Deferred Execution)
function M.DrawValueSlider(ctx, label, val, min, max, w_total, config)
    local changed = false
    local new_val = val
    local ui_scale = config.UI_SCALE or 1
    local slider_w = (w_total or 180 * ui_scale)
    local ctrl_h = (config.ctrl_h or 24) * ui_scale
    
    r.ImGui_SetNextItemWidth(ctx, slider_w)
    
    -- [Industrial Aesthetics] Deep contrast for the slider frame
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_FrameBg(),       0x101214FF) 
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_FrameBgHovered(), 0x181A1CFF)
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_FrameBgActive(),  0x08090AFF)
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_SliderGrab(),     Theme.COLORS.accent or 0x4488FFFF)
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_SliderGrabActive(), 0x66AAFFFF)
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_FrameRounding(), 6.0 * ui_scale) -- V13.8 Increased rounding
    r.ImGui_PushStyleVar(ctx, r.ImGui_StyleVar_GrabRounding(),  6.0 * ui_scale)
    
    local fmt = config.is_pct and "%d%%" or "%d"
    local rv, nv = r.ImGui_SliderInt(ctx, "##slider_"..label, val, min, max, fmt)
    
    -- [V13.8] Return 'nv' so caller can track interactive state, 
    -- but 'changed' only on release for deferred commitment.
    -- 修复：只在释放鼠标或编辑结束时返回 true，并将新值返回以供保存
    local changed_on_release = r.ImGui_IsItemDeactivatedAfterEdit(ctx)
    
    r.ImGui_PopStyleVar(ctx, 2)
    r.ImGui_PopStyleColor(ctx, 5)
    
    return changed_on_release, nv
end

--- [Component] 工业级胶囊开关 (V7.1 Switch)
function M.DrawSwitch(ctx, label, US, active, color_on)
    local w, h = 34 * US, 18 * US
    local x, y = r.ImGui_GetCursorScreenPos(ctx)
    local dl = r.ImGui_GetWindowDrawList(ctx)
    local changed = false

    -- 绘制前微调高度以对齐文字中线
    r.ImGui_SetCursorPosY(ctx, r.ImGui_GetCursorPosY(ctx) + 2 * US)

    -- 使用隐形按钮捕获交互
    if r.ImGui_InvisibleButton(ctx, "##switch_"..label, w, h) then
        active = not active
        changed = true
    end

    local rounding = h * 0.5
    -- 移除悬停时带来的灰色变化以保持无干扰静默态
    local base_c = active and (color_on or Theme.COLORS.accent) or 0x33333366
    local bg_col = base_c
    
    -- 绘制槽位背景
    r.ImGui_DrawList_AddRectFilled(dl, x, y, x + w, y + h, bg_col, rounding)
    
    -- 绘制滑块
    local dot_r = h * 0.5 - 2.5 * US
    local dot_x = active and (x + w - h * 0.5) or (x + h * 0.5)
    local dot_y = y + h * 0.5
    r.ImGui_DrawList_AddCircleFilled(dl, dot_x, dot_y, dot_r, 0xFFFFFFFF)

    return changed, active
end

