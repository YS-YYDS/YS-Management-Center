local function ApplyUIProps(ctx)
    Theme.Select(G.theme_idx)
    
    if not G.ui_scale then
        local us = reaper.GetExtState("YS_Archive", "UIScale")
        G.ui_scale = tonumber(us) or 1.0
    end
    
    local scaled_ui = 16 * G.ui_scale
    local scaled_result = G.result_font_size * G.ui_scale
    FontManager.Init(ctx, EXTSTATE_SECTION, math.floor(scaled_ui + 0.5), math.floor(scaled_result + 0.5))
    
    -- [V4.3 Fix] 字体切换时立即更新 result_font_ptr
    if G.script_font_idx and FontManager.ApplyScriptFont then
        FontManager.ApplyScriptFont(ctx, G.script_font_idx)
    end
    
    if PEng then PEng.Init(G, Eng, FontManager, Theme, Utils) end
    if PW then PW.Init(G, Theme, Eng, FontManager, GUI) end
    if PModals then PModals.Init(G, Theme, Eng, PEng, FontManager, Helper, GUI) end
    if PI_Module then PI_Module.Init(G, Icons, Theme, Eng, FontManager, GUI, PEng, PW, PModals, Helper) end
end

local function InitApp(ctx)
    G._boot_perf_start = reaper.time_precise()
    
    -- 1. 初始化全局状态 (从磁盘读取持久化设置)
    if State and State.Init then State.Init(Utils) end
    
    -- 2. 同步加载核心组件 (Atomic Sync Load)
